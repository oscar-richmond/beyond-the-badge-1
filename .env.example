# TinaCMS + Vercel environment variables
# Copy this file to .env.local for local TinaCloud mode
# (without these, TinaCMS runs in local file-system mode — no login required)

# Get these from your TinaCloud project dashboard at https://app.tina.io
TINA_CLIENT_ID=
TINA_TOKEN=

# Auto-set by Vercel — do not set manually
# VERCEL_GIT_COMMIT_REF=

# Optional: override which branch Tina commits to
# TINA_BRANCH=main
