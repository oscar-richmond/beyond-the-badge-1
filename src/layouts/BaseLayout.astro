---
import SplashScreen from '../components/SplashScreen.astro';
import Cursor      from '../components/Cursor.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beyond the Badge — Cultural Brand Partnerships',
  description = 'We connect brands with the right spaces in art, sport, entertainment, and community. Through bold partnerships and authentic storytelling, we build emotional resonance that lives beyond the logo.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}logo-monogram.png`} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Custom dot cursor (desktop / fine-pointer only) -->
    <Cursor />

    <!-- Full luxury splash screen (first visit per session) -->
    <SplashScreen />

    <!-- Lightweight page-to-page transition curtain (z-index below splash) -->
    <div id="btb-curtain" aria-hidden="true"></div>

    <slot />

    <style is:global>
      /* ── Page-transition curtain (between pages, not splash) ─────── */
      #btb-curtain {
        position: fixed;
        inset: 0;
        z-index: 9000; /* below splash (9999) */
        background-color: #052715;
        pointer-events: none;
        will-change: transform;
        /* Starts covering the page. JS lifts it to reveal on arrival.
           On first-load with splash: splash (z:9999) is on top so this is invisible. */
        transform: translateY(0);
      }
    </style>

    <!-- Page-to-page transition curtain -->
    <script>
      import { gsap } from 'gsap';
      import { CustomEase } from 'gsap/CustomEase';

      gsap.registerPlugin(CustomEase);
      CustomEase.create('btbEase', '.76, 0, .24, 1');

      const curtain      = document.getElementById('btb-curtain') as HTMLElement | null;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced || !curtain) {
        if (curtain) curtain.style.display = 'none';
        // No curtain animation — signal immediately so reveals aren't blocked.
        window.dispatchEvent(new CustomEvent('btb-ready'));
      } else {
        // ── Page arrival: lift curtain up to reveal the page ─────────────────
        // On first-load WITH splash: splash (z:9999) sits above this (z:9000),
        // so this lift is invisible — splash handles the reveal instead.
        // On subsequent internal-nav arrivals: this lift IS the page reveal.
        gsap.to(curtain, {
          y: '-100%',
          duration: 0.9,
          ease: 'btbEase',
          delay: 0.05,
          onComplete() {
            // Signal all reveal systems that the curtain has lifted and the
            // page is now fully visible. Above-fold elements only animate after
            // this fires, so the user sees them slide in rather than behind the curtain.
            window.dispatchEvent(new CustomEvent('btb-ready'));
          },
        });

        // ── Click → cover page → navigate ────────────────────────────────────
        const HOST = window.location.hostname;

        document.addEventListener('click', (e) => {
          const target = (e.target as Element).closest('a');
          if (!target) return;

          const href = target.getAttribute('href') ?? '';

          if (!href || href.startsWith('#') || href.startsWith('mailto:') ||
              href.startsWith('tel:') || target.target === '_blank') return;

          if (href.startsWith('http') && !href.includes(HOST)) return;

          const dest = new URL(href, window.location.href);
          if (dest.pathname === window.location.pathname) return;

          e.preventDefault();

          // Flag that the next page load is an internal navigation,
          // so the splash screen knows to skip itself.
          sessionStorage.setItem('btb-internal-nav', '1');

          // Reset curtain to top-out-of-view, slide it DOWN to cover page
          gsap.set(curtain, { y: '-100%' });
          gsap.to(curtain, {
            y: '0%',
            duration: 0.85,
            ease: 'btbEase',
            onComplete() {
              window.location.href = dest.href;
            },
          });
        }, true);
      }
    </script>

    <script>
      // No-JS fallback
      document.documentElement.classList.remove('no-js');

      const REVEAL_SEL = '.reveal, .reveal--left, .reveal--right, .reveal--scale, .reveal--clip';

      // ── Immediate reveals ─────────────────────────────────────────────────
      // Elements with [data-reveal-immediate] should NOT wait for btb-ready.
      // They animate during the curtain lift (previous behaviour for about-page images).
      const immediateObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              immediateObs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll<HTMLElement>('[data-reveal-immediate]').forEach(el =>
        immediateObs.observe(el)
      );

      // ── Curtain-gated reveals ─────────────────────────────────────────────
      // All other reveal elements wait for the btb-ready event (curtain lifted).
      function initRevealObserver() {
        // Auto-stagger siblings inside [data-reveal-group]
        document.querySelectorAll('[data-reveal-group]').forEach((group) => {
          Array.from(group.querySelectorAll(REVEAL_SEL)).forEach((child, i) => {
            if (!(child as HTMLElement).hasAttribute('data-reveal-immediate'))
              (child as HTMLElement).style.transitionDelay = `${(i * 0.18).toFixed(2)}s`;
          });
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
        );

        document.querySelectorAll<HTMLElement>(REVEAL_SEL).forEach((el) => {
          // Skip testimonials and elements already handled by the immediate observer
          if (!el.closest('#testimonials') && !el.hasAttribute('data-reveal-immediate'))
            observer.observe(el);
        });
      }

      // Wait for curtain to lift before triggering above-fold reveals.
      window.addEventListener('btb-ready', initRevealObserver, { once: true });
    </script>

    <script>
      import Lenis from 'lenis';

      // Desktop / fine-pointer only — mobile gets native scroll
      const prefersNative = window.matchMedia('(max-width: 767px)').matches
                         || !window.matchMedia('(pointer: fine)').matches;

      if (!prefersNative) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          touchMultiplier: 2,
        });

        // Feed Lenis into rAF — this is what drives the animation
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Anchor link clicks — let Lenis handle them smoothly
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e: MouseEvent) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector<HTMLElement>(id);
            if (!target) return;
            e.preventDefault();
            lenis.scrollTo(target, { offset: -70 });
          });
        });
      }
    </script>


    <script>
      // ── Line-by-line clip reveal + HR draw-in ─────────────────────────────
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const onMobile       = window.matchMedia('(max-width: 767px)').matches;

      // ── Effect 1: Line clip reveal (desktop only, no reduced-motion) ───────
      if (!prefersReduced && !onMobile) {

        // Inject CSS for initial hidden state and revealed state
        const css = document.createElement('style');
        css.textContent = `
          .lr-clip { overflow: hidden; display: block; }
          .lr-inner {
            display: block;
            transform: translateY(110%);
            will-change: transform;
          }
          .lr-clip.lr-visible .lr-inner {
            transform: translateY(0);
          }
        `;
        document.head.appendChild(css);

        // ── Unified per-line reveal ────────────────────────────────────
        // Handles: plain text, inline children (span/em/strong/a), <br> splits.
        // Falls back to single-clip only if block-level children are present.
        const BLOCK_TAGS_LRC = new Set([
          'div','section','article','aside','ul','ol','li','table'
        ]);

        function revealElement(el: HTMLElement): HTMLElement | null {
          const children = Array.from(el.childNodes);

          // Block-level child → single-clip fallback
          if (children.some(n =>
            n.nodeType === Node.ELEMENT_NODE &&
            BLOCK_TAGS_LRC.has((n as Element).tagName.toLowerCase())
          )) {
            const clip = document.createElement('div');
            clip.className = 'lr-clip';
            el.parentNode!.insertBefore(clip, el);
            clip.appendChild(el);
            el.classList.add('lr-inner');
            const revealDelayFallback = parseFloat((el.dataset.revealDelay ?? '0')) || 0;
            el.style.transition = `transform 1.2s cubic-bezier(0.42,0,0.24,1) ${revealDelayFallback.toFixed(2)}s`;
            return clip;
          }

          // Collect atoms: words from text nodes, outerHTML from inline elements, BR sentinels
          type Atom = { html: string; isBr: boolean };
          const atoms: Atom[] = [];

          children.forEach(node => {
            if (node.nodeName === 'BR') {
              atoms.push({ html: '', isBr: true });
            } else if (node.nodeType === Node.TEXT_NODE) {
              (node.textContent || '').split(/\s+/).filter(w => w.length > 0)
                .forEach(w => atoms.push({ html: w, isBr: false }));
            } else if (node.nodeType === Node.ELEMENT_NODE) {
              atoms.push({ html: (node as Element).outerHTML, isBr: false });
            }
          });

          if (atoms.filter(a => !a.isBr).length === 0) return null;

          // Render atoms into measurement spans
          el.innerHTML = '';
          const wrapEls: HTMLElement[] = [];

          atoms.forEach((atom, i) => {
            if (atom.isBr) {
              const s = document.createElement('span');
              s.className = 'lw-br';
              s.style.cssText = 'display:block;height:0;font-size:0;line-height:0';
              el.appendChild(s);
              wrapEls.push(s);
            } else {
              const s = document.createElement('span');
              s.className = 'lw';
              s.style.display = 'inline-block';
              s.innerHTML = atom.html;
              el.appendChild(s);
              wrapEls.push(s);
              const next = atoms[i + 1];
              if (next && !next.isBr) el.appendChild(document.createTextNode(' '));
            }
          });

          // Group by offsetTop; BR sentinels force a new line group
          const lineGroups: string[][] = [];
          let currentTop = -9999;
          let group: string[] = [];

          wrapEls.forEach(w => {
            if (w.classList.contains('lw-br')) {
              if (group.length) { lineGroups.push(group); group = []; }
              currentTop = -9999;
              return;
            }
            const top = w.offsetTop;
            if (Math.abs(top - currentTop) > 3) {
              if (group.length) lineGroups.push(group);
              group = []; currentTop = top;
            }
            group.push(w.innerHTML); // preserves inline HTML (spans, em, etc.)
          });
          if (group.length) lineGroups.push(group);
          if (lineGroups.length === 0) return null;

          // Rebuild: one lr-clip / lr-inner per line
          const revealDelay = parseFloat((el.dataset.revealDelay ?? '0')) || 0;
          el.innerHTML = '';
          lineGroups.forEach((words, i) => {
            const clip  = document.createElement('div');
            clip.className = 'lr-clip';
            const inner = document.createElement('div');
            inner.className = 'lr-inner';
            inner.style.transition =
              `transform 1.2s cubic-bezier(0.42,0,0.24,1) ${(revealDelay + i * 0.12).toFixed(2)}s`;
            // Remove spurious spaces before punctuation produced by the
            // atom-based join (e.g. 'art ,' → 'art,').
            inner.innerHTML = words.join(' ').replace(/ ([,\.;:!?\)])/g, '$1');
            clip.appendChild(inner);
            el.appendChild(clip);
          });

          return el;
        }

        // h1, h2, h3 + body paragraphs — skip structural / chrome / reveal-ancestor elements
        const REVEAL_ANCESTOR = '.reveal, .reveal--left, .reveal--right, .reveal--scale';
        const targets = Array.from(
          document.querySelectorAll<HTMLElement>('h1, h2, h3, p')
        ).filter(el =>
          !el.closest('#testimonials') &&
          !el.closest('nav') &&
          !el.closest('header') &&
          !el.closest('#hero') &&
          !el.closest('.footer') &&
          !el.closest(REVEAL_ANCESTOR)
          // Note: [data-keyword] elements were previously excluded to protect
          // hover listeners, but those now use event delegation on the parent
          // so they survive the DOM rebuild. Exclusion is no longer needed.
        );

        const lineObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Add lr-visible to each lr-clip child so the CSS
              // .lr-clip.lr-visible .lr-inner selector fires correctly.
              // When the element IS the lr-clip (block-fallback), add directly.
              const clips = entry.target.querySelectorAll(':scope > .lr-clip');
              if (clips.length > 0) {
                clips.forEach(clip => clip.classList.add('lr-visible'));
              } else {
                entry.target.classList.add('lr-visible');
              }
              lineObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        // ── Two-phase reveal to eliminate the static→disappear flash ─────────
        //
        // Problem: if revealElement() (which wraps elements and hides them) only
        // runs after btb-ready, the raw text is visible as the curtain lifts,
        // then vanishes, then animates in — a jarring flash.
        //
        // Fix:
        //   Phase 1 — fonts.ready: wrap all targets with revealElement() NOW,
        //             while the curtain is still covering the page. Text is hidden
        //             (translateY 110%) before the user ever sees it.
        //   Phase 2 — btb-ready:  start the lineObserver so in-viewport elements
        //             get lr-visible and begin their slide-in animation just as
        //             the curtain finishes lifting.
        //
        // btbFired flag handles the race where btb-ready fires before fonts load.
        let btbFired = false;
        const onBtbReady = () => { btbFired = true; };
        window.addEventListener('btb-ready', onBtbReady, { once: true });

        (document.fonts?.ready ?? Promise.resolve()).then(() => {
          // Phase 1: wrap + hide (fonts loaded → accurate offsetTop measurements)
          const toObserve: HTMLElement[] = [];
          targets.forEach(el => {
            const observed = revealElement(el);
            if (observed) toObserve.push(observed);
          });

          // Phase 2: start observing — immediately if btb-ready already fired,
          // otherwise wait for it.
          const startObserving = () =>
            toObserve.forEach(el => lineObserver.observe(el));

          if (btbFired) {
            startObserving();
          } else {
            window.addEventListener('btb-ready', startObserving, { once: true });
          }
        });
      }

      // ── Effect 2: HR draw-in ──────────────────────────────────────────────
      const hrCss = document.createElement('style');

      if (prefersReduced) {
        // Show all lines immediately at full width
        hrCss.textContent = `hr { width: 100%; }`;
      } else {
        hrCss.textContent = `
          hr {
            width: 0%;
            transform-origin: left center;
            transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
          }
          hr.line--visible {
            width: 100%;
          }
        `;
      }
      document.head.appendChild(hrCss);

      if (!prefersReduced) {
        // Stagger sibling <hr> elements within the same parent
        document.querySelectorAll<HTMLElement>('hr').forEach(hr => {
          const siblings = Array.from(hr.parentElement?.querySelectorAll('hr') ?? []);
          const idx = siblings.indexOf(hr);
          if (idx > 0) hr.style.transitionDelay = `${(idx * 0.15).toFixed(2)}s`;
        });

        const hrObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('line--visible');
              hrObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });

        document.querySelectorAll('hr').forEach(hr => hrObserver.observe(hr));
      }
    </script>
  </body>
</html>
