---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beyond the Badge — Cultural Brand Partnerships',
  description = 'We connect brands with the right spaces in art, sport, entertainment, and community. Through bold partnerships and authentic storytelling, we build emotional resonance that lives beyond the logo.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      // No-JS fallback: html gets .no-js by default, removed when JS runs
      document.documentElement.classList.remove('no-js');

      const REVEAL_SEL = '.reveal, .reveal--left, .reveal--right, .reveal--scale';

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      // Auto-stagger siblings inside [data-reveal-group]
      document.querySelectorAll('[data-reveal-group]').forEach((group) => {
        Array.from(group.querySelectorAll(REVEAL_SEL)).forEach((child, i) => {
          (child as HTMLElement).style.transitionDelay = `${(i * 0.1).toFixed(1)}s`;
        });
      });

      // Observe all reveal elements except those inside the testimonials section
      document.querySelectorAll<HTMLElement>(REVEAL_SEL).forEach((el) => {
        if (!el.closest('#testimonials')) {
          observer.observe(el);
        }
      });
      // ── Scroll-hold: toggle scroll-snap-align on key sections via IntersectionObserver ──
      // Desktop only — mobile gets unaffected native scroll
      if (!window.matchMedia('(max-width: 767px)').matches) {
        const holdSections = document.querySelectorAll<HTMLElement>('#about, #services, #contact');

        const holdObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('scroll-hold');
              } else {
                entry.target.classList.remove('scroll-hold');
              }
            });
          },
          { threshold: 0 } // fire as soon as even 1px enters the viewport
        );

        holdSections.forEach((el) => holdObserver.observe(el));
      }
    </script>

    <script>
      import Lenis from 'lenis';

      // Desktop / fine-pointer only — mobile gets native scroll
      const prefersNative = window.matchMedia('(max-width: 767px)').matches
                         || !window.matchMedia('(pointer: fine)').matches;

      if (!prefersNative) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          touchMultiplier: 2,
        });

        // Feed Lenis into rAF — this is what drives the animation
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Anchor link clicks — let Lenis handle them smoothly
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e: MouseEvent) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector<HTMLElement>(id);
            if (!target) return;
            e.preventDefault();
            lenis.scrollTo(target, { offset: -70 });
          });
        });
      }
    </script>

  </body>
</html>
