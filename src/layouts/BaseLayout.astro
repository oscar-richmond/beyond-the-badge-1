---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beyond the Badge — Cultural Brand Partnerships',
  description = 'We connect brands with the right spaces in art, sport, entertainment, and community. Through bold partnerships and authentic storytelling, we build emotional resonance that lives beyond the logo.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      // No-JS fallback: html gets .no-js by default, removed when JS runs
      document.documentElement.classList.remove('no-js');

      const REVEAL_SEL = '.reveal, .reveal--left, .reveal--right, .reveal--scale';

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      // Auto-stagger siblings inside [data-reveal-group]
      document.querySelectorAll('[data-reveal-group]').forEach((group) => {
        Array.from(group.querySelectorAll(REVEAL_SEL)).forEach((child, i) => {
          (child as HTMLElement).style.transitionDelay = `${(i * 0.1).toFixed(1)}s`;
        });
      });

      // Observe all reveal elements except those inside the testimonials section
      document.querySelectorAll<HTMLElement>(REVEAL_SEL).forEach((el) => {
        if (!el.closest('#testimonials')) {
          observer.observe(el);
        }
      });
    </script>

    <script>
      // ── Lerp smooth scroll — anchor links only, no wheel interception ────────
      // Regular scroll is 100% native (no preventDefault anywhere).
      // Lerp applies only when the user clicks an anchor link, giving a
      // premium deceleration feel without fighting the user during free scroll.

      const isMobile = window.matchMedia('(max-width: 767px)').matches
                    || !window.matchMedia('(pointer: fine)').matches;

      if (!isMobile) {
        const BASE_LERP      = 0.12;
        const HOLD_LERP      = 0.09; // subtle hold when entering key sections
        const HOLD_THRESHOLD = 0.15; // first 15% of section height

        let targetY  = window.scrollY;
        let currentY = window.scrollY;
        let rafId: ReturnType<typeof requestAnimationFrame> | null = null;

        const holdSections = Array.from(
          document.querySelectorAll<HTMLElement>('#about, #services, #contact')
        );

        function getLerp(): number {
          for (const el of holdSections) {
            const progress = -el.getBoundingClientRect().top / el.offsetHeight;
            if (progress >= 0 && progress < HOLD_THRESHOLD) return HOLD_LERP;
          }
          return BASE_LERP;
        }

        function maxScroll(): number {
          return document.documentElement.scrollHeight - window.innerHeight;
        }

        function tick(): void {
          const factor = getLerp();
          currentY += (targetY - currentY) * factor;

          if (Math.abs(targetY - currentY) < 0.5) {
            currentY = targetY;
            window.scrollTo(0, currentY);
            rafId = null;
          } else {
            window.scrollTo(0, currentY);
            rafId = requestAnimationFrame(tick);
          }
        }

        function lerpTo(y: number): void {
          targetY = Math.max(0, Math.min(maxScroll(), y));
          currentY = window.scrollY; // always start from real current pos
          if (!rafId) rafId = requestAnimationFrame(tick);
        }

        // Keep targetY/currentY in sync during native scrolling
        window.addEventListener('scroll', () => {
          if (!rafId) {
            targetY  = window.scrollY;
            currentY = window.scrollY;
          }
        }, { passive: true });

        // Anchor link clicks: smooth lerp to target
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e: MouseEvent) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector<HTMLElement>(id);
            if (!target) return;
            e.preventDefault();
            lerpTo(target.offsetTop);
          });
        });

        // Re-sync on resize
        window.addEventListener('resize', () => {
          targetY  = window.scrollY;
          currentY = window.scrollY;
        }, { passive: true });
      }
    </script>
  </body>
</html>
