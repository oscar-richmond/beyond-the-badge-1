---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beyond the Badge — Cultural Brand Partnerships',
  description = 'We connect brands with the right spaces in art, sport, entertainment, and community. Through bold partnerships and authentic storytelling, we build emotional resonance that lives beyond the logo.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      // No-JS fallback: html gets .no-js by default, removed when JS runs
      document.documentElement.classList.remove('no-js');

      const REVEAL_SEL = '.reveal, .reveal--left, .reveal--right, .reveal--scale';

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      // Auto-stagger siblings inside [data-reveal-group]
      document.querySelectorAll('[data-reveal-group]').forEach((group) => {
        Array.from(group.querySelectorAll(REVEAL_SEL)).forEach((child, i) => {
          (child as HTMLElement).style.transitionDelay = `${(i * 0.1).toFixed(1)}s`;
        });
      });

      // Observe all reveal elements except those inside the testimonials section
      document.querySelectorAll<HTMLElement>(REVEAL_SEL).forEach((el) => {
        if (!el.closest('#testimonials')) {
          observer.observe(el);
        }
      });
    </script>

    <script>
      import Lenis from 'lenis';

      // Desktop / fine-pointer only — mobile gets native scroll
      const prefersNative = window.matchMedia('(max-width: 767px)').matches
                         || !window.matchMedia('(pointer: fine)').matches;

      if (!prefersNative) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          touchMultiplier: 2,
        });

        // Feed Lenis into rAF — this is what drives the animation
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Anchor link clicks — let Lenis handle them smoothly
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
          a.addEventListener('click', (e: MouseEvent) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector<HTMLElement>(id);
            if (!target) return;
            e.preventDefault();
            lenis.scrollTo(target, { offset: -70 });
          });
        });
      }
    </script>

    <script>
      // ── Line-by-line clip reveal + HR draw-in ─────────────────────────────
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const onMobile       = window.matchMedia('(max-width: 767px)').matches;

      // ── Effect 1: Line clip reveal (desktop only, no reduced-motion) ───────
      if (!prefersReduced && !onMobile) {

        // Inject CSS for initial hidden state and revealed state
        const css = document.createElement('style');
        css.textContent = `
          .lr-clip { overflow: hidden; display: block; }
          .lr-inner { display: block; transform: translateY(105%); }
          .lr-clip.lr-visible .lr-inner {
            transform: translateY(0);
          }
        `;
        document.head.appendChild(css);

        // Split a plain-text element into per-line clip wrappers
        function splitLines(el: HTMLElement) {
          const text = el.textContent?.trim() ?? '';
          if (!text) return;

          // Temporarily wrap each word to measure its line
          el.innerHTML = text
            .split(/\s+/)
            .filter(Boolean)
            .map(w => `<span class="lw" style="display:inline-block">${w}</span>`)
            .join(' ');

          // Group words by vertical position
          const wordEls = Array.from(el.querySelectorAll<HTMLElement>('.lw'));
          const lineGroups: string[][] = [];
          let currentTop = -9999;
          let group: string[] = [];

          wordEls.forEach(w => {
            const top = w.offsetTop;
            if (Math.abs(top - currentTop) > 3) {
              if (group.length) lineGroups.push(group);
              group = [w.textContent?.trim() ?? ''];
              currentTop = top;
            } else {
              group.push(w.textContent?.trim() ?? '');
            }
          });
          if (group.length) lineGroups.push(group);

          // Rebuild with clip+inner wrappers
          el.innerHTML = '';
          lineGroups.forEach((words, i) => {
            const clip  = document.createElement('div');
            clip.className = 'lr-clip';
            const inner = document.createElement('div');
            inner.className = 'lr-inner';
            inner.textContent = words.join(' ');
            inner.style.transition =
              `transform 0.9s cubic-bezier(0.16,1,0.3,1) ${(i * 0.08).toFixed(2)}s`;
            clip.appendChild(inner);
            el.appendChild(clip);
          });

          return el; // observe the element itself
        }

        // Wrap a rich-HTML element (has child elements) in a single clip
        function wrapBlock(el: HTMLElement): HTMLElement {
          const clip = document.createElement('div');
          clip.className = 'lr-clip';
          el.parentNode!.insertBefore(clip, el);
          clip.appendChild(el);
          el.classList.add('lr-inner');
          el.style.transition = 'transform 0.9s cubic-bezier(0.16,1,0.3,1)';
          return clip; // observe the clip wrapper
        }

        // Collect target headings — skip testimonials, nav, header, hero,
        // and anything already inside a .reveal* ancestor (its parent handles reveal)
        const REVEAL_ANCESTOR = '.reveal, .reveal--left, .reveal--right, .reveal--scale';
        const targets = Array.from(
          document.querySelectorAll<HTMLElement>('h2, h3')
        ).filter(el =>
          !el.closest('#testimonials') &&
          !el.closest('nav') &&
          !el.closest('header') &&
          !el.closest('#hero') &&
          !el.closest(REVEAL_ANCESTOR)   // skip elements covered by existing system
        );

        const lineObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('lr-visible');
              lineObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        // Fonts must be loaded so line measurements are accurate
        (document.fonts?.ready ?? Promise.resolve()).then(() => {
          targets.forEach(el => {
            const hasHtmlChildren = Array.from(el.childNodes)
              .some(n => n.nodeType === Node.ELEMENT_NODE);
            const observed = hasHtmlChildren ? wrapBlock(el) : (splitLines(el), el);
            lineObserver.observe(observed);
          });
        });
      }

      // ── Effect 2: HR draw-in ──────────────────────────────────────────────
      const hrCss = document.createElement('style');

      if (prefersReduced) {
        // Show all lines immediately at full width
        hrCss.textContent = `hr { width: 100%; }`;
      } else {
        hrCss.textContent = `
          hr {
            width: 0%;
            transform-origin: left center;
            transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
          }
          hr.line--visible {
            width: 100%;
          }
        `;
      }
      document.head.appendChild(hrCss);

      if (!prefersReduced) {
        // Stagger sibling <hr> elements within the same parent
        document.querySelectorAll<HTMLElement>('hr').forEach(hr => {
          const siblings = Array.from(hr.parentElement?.querySelectorAll('hr') ?? []);
          const idx = siblings.indexOf(hr);
          if (idx > 0) hr.style.transitionDelay = `${(idx * 0.15).toFixed(2)}s`;
        });

        const hrObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('line--visible');
              hrObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });

        document.querySelectorAll('hr').forEach(hr => hrObserver.observe(hr));
      }
    </script>
  </body>
</html>
