---
---

<section class="about section" id="about">

  <div class="container">
    <div class="about__content">
      <p class="about__intro">
        Led by industry leader <a href="/about#founder" class="about__laura-link"><em>Laura Wood</em></a> who spent a decade as Global Director of Brand Partnerships, Experience and Collections at JLR, our mission is to help brands move beyond surface-level marketing and into meaningful cultural participation.
      </p>
    </div>

    <div class="about__visual" style="transition-delay: 0.15s;">
      <div class="about__image-grid" data-reveal-group>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(01)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-1.jpg')`}></div>
        </div>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(02)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-2.jpg')`}></div>
        </div>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(03)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-3.jpg')`}></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    background: transparent;
    overflow: hidden;
    padding: var(--section-padding-y) 0;
  }

  .about__watermark {
    position: absolute;
    top: -5%;
    left: -5%;
    height: 120%;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .about__watermark-img {
    height: 100%;
    width: auto;
    opacity: 0.03;
    filter: invert(1);
  }

  .about__content {
    position: relative;
    z-index: 1;
    max-width: 1092px; /* 1028 + 64 */
    margin-bottom: clamp(48px, 12vw, 256px);
  }

  .about__intro {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 400; /* regular */
    line-height: 48px;
    letter-spacing: 0.05em; /* 5% */
    color: var(--color-text-dark);
    margin-bottom: 24px;
  }

  .about__highlight,
  .about__brand {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "hght" 1000;
    color: #8CB7A0;
  }

  /* 'Laura Wood' link — matches the italic highlight style */
  .about__statement {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-text-dark);
  }

  .about__visual {
    position: relative;
    z-index: 1;
  }

  .about__image-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 330px));
    gap: 32px;
    justify-content: flex-end;
  }

  .about__image-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .about__image-label {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-dark-section);
  }

  .about__image-item {
    height: 440px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-divider-light);
  }

  @media (max-width: 768px) {
    .about__image-grid {
      grid-template-columns: 1fr 1fr;
      max-width: 100%;
    }

    .about__content {
      margin-bottom: 64px;
    }
  }

  @media (max-width: 480px) {
    .about__image-grid {
      grid-template-columns: 1fr;
    }

    .about__image-item {
      height: 220px;
    }
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .about__intro {
      font-size: 34px;    /* 36px × 0.944 */
      line-height: 45px;  /* 48px × 0.9375 */
    }
    .about__image-item {
      height: 396px;  /* 440px × 0.90 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .about__intro {
      font-size: 32px;    /* 34px × 0.941 */
      line-height: 41px;  /* 45px × 0.90 */
    }
    .about__image-grid {
      grid-template-columns: repeat(3, minmax(0, 297px));  /* 330px × 0.90 — keeps portrait ratio at 297×356 */
      gap: 29px;  /* 32px × 0.90 */
    }
    .about__image-item {
      height: 356px;  /* 396px × 0.90 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .about__intro {
      font-size: 30px;    /* 32px × 0.94 */
      line-height: 37px;  /* 41px × 0.90 */
    }
    .about__image-grid {
      grid-template-columns: repeat(3, minmax(0, 267px));  /* 297px × 0.90 — portrait ratio maintained at 267×320 */
      gap: 26px;  /* 29px × 0.90 */
    }
    .about__image-item {
      height: 320px;  /* 356px × 0.90 */
    }
  }
  /* ── 390px ─────────────────────────────────────────────────────────── */
  /* The 1024px block (below) comes later in the cascade and overrides the
     480px block's grid-template-columns:1fr back to 3 columns at 390px.
     This 390px block re-asserts the correct single-column layout and
     makes each image square. */
  @media (max-width: 390px) {
    .about__image-grid {
      grid-template-columns: 1fr;   /* 1 column — overrides 1024px 3-column rule */
    }

    .about__image-item {
      height: auto;       /* override fixed px heights from 480px + 1024px blocks */
      aspect-ratio: 1 / 1; /* square */
    }
  }

  /* ── 450px: Pro Max spacing + gap controls ────────────────────────── */
  @media (max-width: 500px) {
    /* Gap 1: hero pb=0, so this 120px is the full video→paragraph gap */
    /* Gap 2 prep: zero bottom so Services padding-top controls that gap */
    .about {
      padding-top: 120px;
      padding-bottom: 0;
    }

    .about__image-grid { grid-template-columns: 1fr; }
    .about__image-item { height: auto; aspect-ratio: 1 / 1; }
  }
</style>
