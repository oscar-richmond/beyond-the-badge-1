---
---

<section class="about section" id="about">

  <div class="container">
    <div class="about__content">
      <p class="about__intro">
        At <span class="about__brand">Beyond the Badge</span>, we believe cultural relevance isn't earned through logos, it's built through legacy. Led by industry leader Laura Wood who spent a decade as Global Director of Brand Partnerships, Experience and Collections at JLR, our mission is to help brands move beyond surface-level marketing and into meaningful cultural participation.
      </p>
    </div>

    <div class="about__visual" style="transition-delay: 0.15s;">
      <div class="about__image-grid" data-reveal-group>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(01)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-1.jpg')`}></div>
        </div>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(02)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-2.jpg')`}></div>
        </div>
        <div class="about__image-wrapper reveal--scale">
          <span class="about__image-label">(03)</span>
          <div class="about__image-item" style={`background-image: url('${import.meta.env.BASE_URL}about-3.jpg')`}></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    background-color: var(--color-cream);
    overflow: hidden;
    padding: var(--section-padding-y) 0;
  }

  .about__watermark {
    position: absolute;
    top: -5%;
    left: -5%;
    height: 120%;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .about__watermark-img {
    height: 100%;
    width: auto;
    opacity: 0.03;
    filter: invert(1);
  }

  .about__content {
    position: relative;
    z-index: 1;
    max-width: 1092px; /* 1028 + 64 */
    margin-bottom: clamp(48px, 12vw, 256px);
  }

  .about__intro {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 400; /* regular */
    line-height: 48px;
    letter-spacing: 0.05em; /* 5% */
    color: var(--color-text-dark);
    margin-bottom: 24px;
  }

  .about__highlight,
  .about__brand {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "HGHT" 1000;
    color: #8CB7A0;
  }

  .about__statement {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-text-dark);
  }

  .about__visual {
    position: relative;
    z-index: 1;
  }

  .about__image-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 330px));
    gap: 32px;
    justify-content: flex-end;
  }

  .about__image-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .about__image-label {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-dark-section);
  }

  .about__image-item {
    height: 440px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-divider-light);
  }

  @media (max-width: 768px) {
    .about__image-grid {
      grid-template-columns: 1fr 1fr;
      max-width: 100%;
    }

    .about__content {
      margin-bottom: 48px;
    }
  }

  @media (max-width: 480px) {
    .about__image-grid {
      grid-template-columns: 1fr;
    }

    .about__image-item {
      height: 220px;
    }
  }
</style>
