---
const base = import.meta.env.BASE_URL + '/';

const testimonials = [
  {
    name: 'Clara Whitlock',
    title: 'Global Brand Lead, Elara Group',
    quoteBefore: '\u201cBeyond the Badge took our unshaped ambition and turned it into cultural ',
    quoteHighlight: 'resonance',
    quoteAfter: ' \u2014 they didn\u2019t just understand our brand, they understood the cultural spaces we wanted to reach with a level of trust we never thought we\u2019d command.\u201d',
    image: `${base}about-1.jpg`,
  },
  {
    name: 'Arthur Bennett',
    title: 'Creative Director, Studio North',
    quoteBefore: '\u201cGreat partnerships aren\u2019t built overnight \u2014 they\u2019re built on trust, shared values, and a team that knows exactly how to ',
    quoteHighlight: 'connect',
    quoteAfter: ' the right people with the right moments in culture.\u201d',
    image: `${base}about-2.jpg`,
  },
  {
    name: 'Julian Thorne',
    title: 'Head of Brand, Meridian',
    quoteBefore: '\u201cWhat sets Beyond the Badge apart is how deeply they understand ',
    quoteHighlight: 'culture',
    quoteAfter: '. They don\u2019t chase it \u2014 they\u2019re already there, and they bring you with them.\u201d',
    image: `${base}about-3.jpg`,
  },
];
---

<section class="testimonials section" id="testimonials">
  <div class="container">

    <div class="testimonials__header reveal">
      <h2 class="testimonials__heading">Words from our clients</h2>
    </div>

    <hr class="testimonials__rule" />

    <div class="testimonials__body">

      <!-- Left: name list -->
      <nav class="testimonials__names" aria-label="Testimonial navigation">
        {testimonials.map((t, i) => (
          <button
            class={`testimonials__name-btn${i === 0 ? ' active' : ''}`}
            data-index={i}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            <span class="testimonials__arrow" aria-hidden="true">&rarr;</span>
            <span class="testimonials__name-text">{t.name}</span>
          </button>
        ))}
      </nav>

      <!-- Centre: portrait photo (grid-stacked for crossfade) -->
      <div class="testimonials__photo-wrap">
        {testimonials.map((t, i) => (
          <div class={`testimonials__photo-item${i === 0 ? ' active' : ''}`} data-index={i}>
            <img src={t.image} alt={t.name} class="testimonials__photo-img" />
          </div>
        ))}
      </div>

      <!-- Right: quote (grid-stacked for crossfade) -->
      <div class="testimonials__quote-wrap">
        {testimonials.map((t, i) => (
          <div class={`testimonials__quote-item${i === 0 ? ' active' : ''}`} data-index={i}>
            <blockquote class="testimonials__quote-text">
              {t.quoteBefore}<em class="testimonials__highlight">{t.quoteHighlight}</em>{t.quoteAfter}
            </blockquote>
            <footer class="testimonials__attribution">
              <span class="testimonials__client-name">{t.name}</span>
              <span class="testimonials__client-role">{t.title}</span>
            </footer>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: #f8f2ed;
    padding: var(--section-padding-y) 0;
  }

  .testimonials__heading {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.5vw, 1.3rem);
    font-weight: 500;
    color: var(--color-text-dark);
    margin-bottom: 32px;
  }

  .testimonials__rule {
    border: none;
    border-top: 1px solid rgba(26, 58, 42, 0.15);
    margin: 0 0 56px;
  }

  /* ── Body grid ── */
  .testimonials__body {
    display: grid;
    grid-template-columns: 20% 25% 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: start;
  }

  /* ── Left: name list ── */
  .testimonials__names {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 8px;
  }

  .testimonials__name-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(26, 58, 42, 0.1);
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    font-weight: 400;
    color: var(--color-text-dark);
    text-align: left;
    cursor: pointer;
    transition: color 0.25s ease;
  }

  .testimonials__name-btn:first-child {
    border-top: 1px solid rgba(26, 58, 42, 0.1);
  }

  .testimonials__arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    font-size: 0.9em;
    flex-shrink: 0;
    color: #004f26;
  }

  .testimonials__name-btn.active,
  .testimonials__name-btn:hover {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .testimonials__name-btn.active .testimonials__arrow,
  .testimonials__name-btn:hover .testimonials__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Centre: photo ── */
  .testimonials__photo-wrap {
    display: grid;
    aspect-ratio: 4 / 5;
  }

  .testimonials__photo-item {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .testimonials__photo-item.active {
    opacity: 1;
  }

  .testimonials__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
  }

  /* ── Right: quote ── */
  .testimonials__quote-wrap {
    display: grid;
    padding-top: 8px;
  }

  .testimonials__quote-item {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .testimonials__quote-item.active {
    opacity: 1;
    pointer-events: auto;
  }

  .testimonials__quote-text {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-text-dark);
    font-style: normal;
    margin: 0 0 32px;
  }

  .testimonials__highlight {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: "wght" 500, "HGHT" 800;
    color: #004f26;
  }

  .testimonials__attribution {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid rgba(26, 58, 42, 0.12);
    padding-top: 20px;
  }

  .testimonials__client-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .testimonials__client-role {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .testimonials__body {
      grid-template-columns: 24% 28% 1fr;
    }
  }

  @media (max-width: 768px) {
    .testimonials__body {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .testimonials__names {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0;
    }

    .testimonials__name-btn {
      padding: 10px 16px 10px 0;
      border: none;
      border-bottom: 2px solid transparent;
    }

    .testimonials__name-btn.active {
      border-bottom-color: #004f26;
    }

    .testimonials__photo-wrap {
      aspect-ratio: 3 / 2;
      max-width: 360px;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.testimonials__name-btn');
  const photos = document.querySelectorAll('.testimonials__photo-item');
  const quotes = document.querySelectorAll('.testimonials__quote-item');

  let current = 0;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;

  function activate(index: number) {
    if (index === current) return;
    current = index;

    buttons.forEach((btn, i) => {
      btn.classList.toggle('active', i === index);
      btn.setAttribute('aria-pressed', String(i === index));
    });
    photos.forEach((p, i) => p.classList.toggle('active', i === index));
    quotes.forEach((q, i) => q.classList.toggle('active', i === index));
  }

  buttons.forEach((btn, i) => {
    // Click — immediate
    btn.addEventListener('click', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
      activate(i);
    });

    // Hover — 200ms delay to avoid flickering
    btn.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 200);
    });

    btn.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });
  });
</script>
