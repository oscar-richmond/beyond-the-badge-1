  // non-button touches. This tells Chrome "JS owns this gesture" before any
  // scroll can start. We then manually handle exit-section scrolling for the
  // first/last testimonial edge cases.
  // Note: pointer events (pointerdown/pointerup) fire BEFORE touch events, so
  // our pointerup-based button handler is unaffected by this preventDefault.
  if (tMobile) {
    const stickyEl = document.querySelector<HTMLElement>('.testimonials-sticky');
    let swipeStartY = 0;
    let swipeStartX = 0;

    stickyEl?.addEventListener('touchstart', (e: TouchEvent) => {
      if ((e.target as Element).closest('button, a, [role="button"]')) {
        swipeStartY = -1; // sentinel — pointer events handle this tap
        return;           // do NOT preventDefault — old-iOS needs it for pointerup fallback
      }
      swipeStartY = e.touches[0].clientY;
      swipeStartX = e.touches[0].clientX;
      // Prevent BEFORE Chrome decides scroll direction — the only reliable fix.
      e.preventDefault();
    }, { passive: false });

    stickyEl?.addEventListener('touchmove', (e: TouchEvent) => {
      if (swipeStartY === -1) return;
      e.preventDefault(); // keep suppressing throughout gesture
