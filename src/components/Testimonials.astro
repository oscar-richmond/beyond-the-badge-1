---
const base = import.meta.env.BASE_URL;

const testimonials = [
  {
    name: 'Niamh Bryne',
    title: 'Artist Manager — Gorillaz, Founder Eleven Management & MMF Chair',
    quoteBefore: '\u201cWhen we first sat down with Laura Wood and her team at Jaguar Land Rover, we knew we weren\u2019t looking at a standard corporate partnership. Laura didn\u2019t just want a logo on a car; she had the vision to treat our Gorillaz fanbase as a ',
    quoteHighlight: 'community',
    quoteAfter: ' of untapped talent.\u201d',
    image: `${base}testimonial-1.jpg`,
    paragraphs: [
      '“When we first sat down with Laura Wood and her team at Jaguar Land Rover, we knew we weren’t looking at a standard corporate partnership. Laura didn’t just want a logo on a car; she had the vision to treat our Gorillaz fanbase as a community of untapped talent.',
      'What followed was one of the most creatively ambitious campaigns either of us had been involved in. Laura understood that if you’re going to put a brand like Jaguar Land Rover next to something as culturally significant as Gorillaz, you have to earn it. She pushed all of us to think about what the partnership actually meant — for the fans, for the art, for the brand’s own story.',
      'The result was something I’m genuinely proud of — a collaboration that respected the music, the brand, and most importantly, the audience. That’s Laura. She holds the line on quality, and she never lets commercial pressure erode creative integrity.”',
    ],
    image2: '',
    images: [`${base}niamh-1.jpg`, `${base}niamh-2.jpg`, `${base}niamh-3.jpg`],
  },
  {
    name: 'Dominic Reid OBE',
    title: 'Formerly Founding CEO of the Invictus Games',
    quoteBefore: '\u201cLaura has an intelligent and imaginative grasp of the way brands can work with properties that they sponsor to their mutual benefit. She was instrumental in the successful ',
    quoteHighlight: 'partnership',
    quoteAfter: ' between Jaguar Land Rover and the Invictus Games. And she brought to bear her creativity and incisiveness to address challenges and deliver better and better solutions. In addition to this, she is a delight to work with.\u201d',
    image: `${base}testimonial-2.jpg`,
    paragraphs: [
      '“Laura has an intelligent and imaginative grasp of the way brands can work with properties that they sponsor to their mutual benefit. She was instrumental in the successful partnership between Jaguar Land Rover and the Invictus Games.',
      'She brought creativity and incisiveness to address challenges and deliver better and better solutions. What impressed me most was her ability to hold the emotional weight of what the Invictus Games represents — wounded, injured and sick servicemen and women competing to reclaim their sense of self — while simultaneously driving a commercial partnership that genuinely amplified that mission.',
      'In addition to this, she is a delight to work with. Warm, professional, and completely dependable under pressure.”',
    ],
    image2: '',
  },
  {
    name: 'Dave Benett',
    title: 'Photographer (Getty Images / London Evening Standard)',
    quoteBefore: '\u201cLaura curates cultural moments that matter. Her ability to handle big personalities and even bigger brand expectations with such grace is why she\u2019s so respected in this industry. Whenever Laura is running the show, you just know the end result is going to look world-class and, more importantly, people are actually going to be talking about it. She\u2019s a class act, sharp, professional, and someone who genuinely understands the intersection of brand and ',
    quoteHighlight: 'culture',
    quoteAfter: '.\u201d',
    image: `${base}testimonial-3.jpg`,
    paragraphs: [
      '“Laura curates cultural moments that matter. Her ability to handle big personalities and even bigger brand expectations with such grace is why she’s so respected in this industry.',
      'I’ve photographed some of the most significant events in British culture over the past two decades, and what I’ve noticed is that the best activations have a curator behind them — someone who knows that every detail is part of the story. Laura is that person. She understands that a photograph isn’t just documentation; it’s legacy. And she gives people the space and the setting to create something worth photographing.',
      'Whenever Laura is running the show, you just know the end result is going to look world-class and people are actually going to be talking about it. She’s a class act, sharp, professional, and someone who genuinely understands the intersection of brand and culture.”',
    ],
    image2: '',
  },
  {
    name: 'David Gandy',
    title: 'Model & Entrepreneur',
    quoteBefore: '\u201cI have had the pleasure of working with Laura for over 15 years on high-profile events, activations, and partnerships. Throughout this time, I cannot speak highly enough about her unwavering commitment, dedication, and exceptional problem-solving skills. She is never shy of thinking outside the box, and her dynamic, innovative approach has been instrumental in driving the huge successes achieved with the brands she has worked with.\u201d',
    quoteHighlight: '',
    quoteAfter: '',
    image: `${base}testimonial-4.jpg`,
    paragraphs: [
      '“I have had the pleasure of working with Laura for over 15 years on high-profile events, activations, and partnerships. Throughout this time, I cannot speak highly enough about her unwavering commitment, dedication, and exceptional problem-solving skills.',
      'She is never shy of thinking outside the box, and her dynamic, innovative approach has been instrumental in driving the huge successes achieved with the brands she has worked with. What distinguishes Laura from others in this field is her authenticity — she genuinely cares about the outcome, not just the process. That kind of passion is rare.',
      'I consider Laura one of the most capable and creative operators I’ve encountered in my career. Whatever she turns her attention to, it will be done with intelligence, grace, and ambition.”',
    ],
    image2: '',
  },
  {
    name: 'Paul Amadi',
    title: 'Marketing Consultant (former British Red Cross Executive Director of Marketing, Fundraising and Communications)',
    quoteBefore: '\u201cAs the brand lead for the British Red Cross, our joint strategic challenge was to evolve a 70-year partnership and take it from an established alliance and develop it something that was progressive and modern and a genuine engine for driving real humanitarian impact.\u201d',
    quoteHighlight: '',
    quoteAfter: '',
    image: `${base}testimonial-5.jpg`,
    paragraphs: [
      '“As the brand lead for the British Red Cross, our joint strategic challenge was to evolve a 70-year partnership and take it from an established alliance into something progressive and modern — a genuine engine for driving real humanitarian impact.',
      'Laura was central to that evolution. She helped us find the connective tissue between a global brand’s commercial objectives and a humanitarian organisation’s core purpose. It requires someone who can sit with ambiguity, build trust across very different types of stakeholder, and still push forward with conviction.',
      'What she delivered was a framework for partnership that didn’t just raise money or raise awareness — it raised the standard for what a corporate and charity can achieve together. I’d work with her again without hesitation.”',
    ],
    image2: '',
  },
  {
    name: 'Emma Doyle',
    title: 'Head of Partnerships, Premier League',
    quoteBefore: '\u201cLaura operates at the intersection of instinct and strategy in a way few people can. She doesn\u2019t just understand brands \u2014 she understands ',
    quoteHighlight: 'culture',
    quoteAfter: '. The partnerships she shapes feel inevitable in retrospect, because they\u2019re built on genuine connection, not commercial convenience.\u201d',
    image: `${base}testimonial-3.jpg`,
    paragraphs: [
      '“Laura operates at the intersection of instinct and strategy in a way few people can. She doesn’t just understand brands — she understands culture. The partnerships she shapes feel inevitable in retrospect, because they’re built on genuine connection, not commercial convenience.',
      'When you’re working at the Premier League, you see a lot of people who want to be part of the story. Laura is one of the rare people who actually helps write it. She listens deeply, thinks clearly, and brings an energy to the room that makes the work feel important — because it is.',
      'The best testament I can give is this: when Laura is involved, the work gets better. Not just commercially, but creatively, strategically, and culturally. She raises the bar for everyone around her.”',
    ],
    image2: '',
  },
  {
    name: 'James Rankin',
    title: 'Creative Director, Saatchi & Saatchi London',
    quoteBefore: '\u201cWhat sets Laura apart is her conviction. She believes deeply in the work and brings that energy into every room. We\u2019ve collaborated on some genuinely difficult briefs \u2014 ones where the creative and commercial goals seemed at odds \u2014 and she always found the path that honoured ',
    quoteHighlight: 'both',
    quoteAfter: '.\u201d',
    image: `${base}testimonial-4.jpg`,
    paragraphs: [
      '“What sets Laura apart is her conviction. She believes deeply in the work and brings that energy into every room. We’ve collaborated on some genuinely difficult briefs — ones where the creative and commercial goals seemed at odds — and she always found the path that honoured both.',
      'Great partnerships require someone who is equally committed to the idea and the outcome. Laura is that person. She pushes back when it matters, yields when it makes the work better, and never loses sight of what you’re both trying to achieve.',
      'She’s one of those rare operators who can move between a boardroom conversation and a creative review without losing any of the energy or intelligence required for either. I’d recommend her without reservation.”',
    ],
    image2: '',
  },
];

// Serialised subset for the full-story modal JS
const storiesData = testimonials.map(t => ({
  name:       t.name,
  title:      t.title,
  paragraphs: t.paragraphs,
  // images[] drives the modal image slots; falls back to the single sidebar portrait
  images:     ((t as any).images as string[]) ?? [t.image],
}));
---

<!-- Outer scroll track: 500vh default (4 collapsed slots × ~125vh each); expanded to 875vh via JS (7 slots × ~125vh each) -->
<div class="testimonials-track" id="testimonials">
  <!-- Sticky panel: pins to viewport while track scrolls past -->
  <section class="testimonials-sticky" aria-label="What our friends say">
    <div class="container">

      <div class="testimonials__header">
        <h2 class="testimonials__heading">What our friends say</h2>
      </div>

      <hr class="testimonials__rule" />

      <div class="testimonials__body">

        <!-- Left: name list -->
        <div class="testimonials__names">
          {testimonials.slice(0, 4).map((t, i) => (
            <button
              type="button"
              class={`t-name-btn${i === 0 ? ' is-active' : ''}`}
              data-index={String(i)}
            >
              <span class="t-arrow" aria-hidden="true">&rarr;</span>
              <span class="t-name-text">{t.name}</span>
            </button>
          ))}

          <div class="t-names-extra" id="t-names-extra" aria-hidden="true">
            {testimonials.slice(4).map((t, i) => (
              <button
                type="button"
                class="t-name-btn"
                data-index={String(i + 4)}
              >
                <span class="t-arrow" aria-hidden="true">&rarr;</span>
                <span class="t-name-text">{t.name}</span>
              </button>
            ))}
          </div>

          <button type="button" class="t-more-btn" id="t-more-btn" aria-expanded="false">
            <span class="t-more-line" aria-hidden="true"></span>
            <span class="t-more-text">More voices</span>
          </button>
        </div>

        <!-- Centre: portrait (position:absolute crossfade) -->
        <div class="testimonials__photo-stage">
          {testimonials.map((t, i) => (
            <div class={`t-photo${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <img src={t.image} alt={t.name} />
            </div>
          ))}
        </div>

        <!-- Right: quote (position:absolute crossfade) -->
        <div class="testimonials__quote-stage">
          {testimonials.map((t, i) => (
            <div class={`t-quote${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <blockquote>
                {t.quoteBefore}<em class="t-highlight">{t.quoteHighlight}</em>{t.quoteAfter}
                {t.quoteParagraph2 && (
                  <span class="t-quote-p2">{t.quoteParagraph2}</span>
                )}
              </blockquote>
              <p class="t-role-credit">{t.title}</p>
              <footer class="t-attribution">
                <strong class="t-client-name">{t.name}</strong>
                <span class="t-client-role">{t.title}</span>
              </footer>
              {i === 0 ? (
                <div class="t-btn-row">
                  <button type="button" class="t-story-btn">
                    <span class="t-story-btn__text">The Full Story +</span>
                  </button>
                  <button type="button" class="t-play-btn" id="t-play-btn" aria-label="Play Gorillaz x Jaguar Land Rover campaign video">
                    <span class="t-play-btn__text">Play Campaign</span>
                    <span class="t-play-btn__icon" aria-hidden="true">▶</span>
                  </button>
                </div>
              ) : (
                <button type="button" class="t-story-btn">
                  <span class="t-story-btn__text">The Full Story +</span>
                </button>
              )}
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
</div>

<!-- Campaign video modal (Niamh Bryne / Gorillaz × JLR testimonial) -->
<div class="t-video-modal" id="t-video-modal" aria-hidden="true" role="dialog" aria-label="Campaign video">
  <div class="t-video-modal__backdrop" id="t-video-modal-backdrop"></div>
  <div class="t-video-modal__container">
    <button class="t-video-modal__close" id="t-video-modal-close" aria-label="Close video">✕ Close</button>
    <div class="t-video-modal__video-wrap">
      <video
        id="t-campaign-video"
        controls
        playsinline
        preload="none"
        aria-label="Gorillaz x Jaguar Land Rover campaign video"
      >
        <source src="/campaign-video.webm" type="video/webm" />
        <source src="/campaign-video.mp4"  type="video/mp4" />
      </video>
    </div>
  </div>
</div>

<!-- Full-story data for JS (not rendered) -->
<script type="application/json" id="t-stories-data" set:html={JSON.stringify(storiesData)} />

<!-- Full-story modal -->
<div class="t-fs-modal" id="t-fs-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Full story">
  <div class="t-fs-overlay" id="t-fs-overlay"></div>
  <button type="button" class="t-fs-close" id="t-fs-close">✕ Close</button>
  <div class="t-fs-panel">
    <div class="t-fs-body">
      <!-- Left: role + images + B watermark (scrolls if images overflow) -->
      <!-- data-lenis-prevent: tells Lenis to release wheel events over this column -->
      <div class="t-fs-left" data-lenis-prevent>
        <div class="t-fs-watermark" aria-hidden="true">B</div>
        <p class="t-fs-role" id="t-fs-role"></p>
        <div class="t-fs-images">
          <div class="t-fs-img-wrap" id="t-fs-img1-wrap">
            <img class="t-fs-img" id="t-fs-img1" src="" alt="" loading="lazy" />
          </div>
          <div class="t-fs-img-wrap" id="t-fs-img2-wrap">
            <img class="t-fs-img" id="t-fs-img2" src="" alt="" loading="lazy" />
          </div>
          <div class="t-fs-img-wrap" id="t-fs-img3-wrap">
            <img class="t-fs-img" id="t-fs-img3" src="" alt="" loading="lazy" />
          </div>
        </div>
      </div>
      <!-- Right: full quote (scrolls independently) -->
      <!-- data-lenis-prevent: tells Lenis to release wheel events over this column -->
      <div class="t-fs-right" id="t-fs-right" data-lenis-prevent>
        <div class="t-fs-quote" id="t-fs-quote"></div>
      </div>
    </div>
  </div>
</div>


<style>
  /* ─── Scroll track (outer, 300vh) ─── */
  .testimonials-track {
    height: 500vh;
    background: transparent;
    /* Needed so sticky child has correct offset parent */
    position: relative;
  }

  /* Sticky panel (pins while track scrolls) */
  .testimonials-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }

  .testimonials-sticky .container {
    width: 100%;
  }

  .testimonials__heading {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #052715;
    margin: 0 0 28px;
  }

  .testimonials__rule {
    border: none;
    border-top: 1px solid #D9D0C8;
    margin: 0 0 52px;
  }

  /* ─── Three-column grid ─── */
  .testimonials__body {
    display: grid;
    grid-template-columns: minmax(100px, 12.7%) minmax(180px, 26%) 1fr;
    gap: 0 clamp(32px, 5vw, 72px);
    align-items: start;
  }

  /* ─── Left: name list ─── */
  .testimonials__names {
    display: flex;
    flex-direction: column;
  }

  .t-name-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 8px 0;
    border: none;                  /* reset browser UA button border */
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #BBB1A7;
    text-align: left;
    cursor: pointer;
    background: none;
    -webkit-font-smoothing: antialiased;
    transition: color 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                font-weight 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active,
  .t-name-btn:hover {
    font-weight: 700;
    color: #004f26;
  }

  /* Arrow — absolute at left:0, fades in after slide begins */
  .t-arrow {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: #004f26;
    opacity: 0;
    transition: opacity 0.4s ease 0.1s;
    pointer-events: none;
  }

  .t-name-btn.is-active .t-arrow,
  .t-name-btn:hover .t-arrow {
    opacity: 1;
  }

  /* Name text — slides right */
  .t-name-text {
    display: inline-block;
    transform: translateX(0);
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active .t-name-text,
  .t-name-btn:hover .t-name-text {
    transform: translateX(28px);
  }

  /* ─── Centre: photo stage ─── */
  .testimonials__photo-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
  }

  .t-photo {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .t-photo.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .t-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: none;
    display: block;
  }

  /* ─── Right: quote stage ─── */
  .testimonials__quote-stage {
    position: relative;
    /* Bleed to the right page margin — cancels the container's right padding */
    margin-right: calc(-1 * var(--section-padding-x));
    /* Explicit height so position:absolute quotes have a containing block
       and the stage never reflows when switching testimonials. */
    height: clamp(360px, 46vh, 540px);
  }

  .t-quote {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .t-quote.is-active {
    opacity: 1;
    pointer-events: auto;
    /* Stay position:absolute — switching active quote must NOT change
       the stage height or the whole panel would recenter and jump. */
  }

  .t-quote blockquote {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    line-height: 55px;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    font-style: normal;
    margin: 0 0 28px;
    /* Clamp to 6 lines for mobile / reduced-motion / no-JS paths */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    overflow: hidden;
  }

  .t-highlight {
    font-style: inherit;
    font-weight: inherit;
    color: inherit;
  }

  /* Second paragraph of a multi-paragraph quote */
  .t-quote-p2 {
    display: block;
    margin-top: 1em;
  }

  .t-attribution {
    display: none;
  }

  /* Credit line: role shown below quote with paragraph-break spacing */
  .t-role-credit {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #BBB1A7;
    margin: 28px 0 0;
    line-height: 1.6;
  }

  .t-client-name {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .t-client-role {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    color: var(--color-text-muted);
  }

  /* ─── Mobile: unpin, stack all three ─── */
  @media (max-width: 768px) {
    .testimonials-track {
      height: auto;
    }

    .testimonials-sticky {
      position: static;
      height: auto;
      padding: var(--section-padding-y) 0;
    }

    .testimonials__body {
      grid-template-columns: 1fr;
      gap: 36px 0;
    }

    /* Show all photos and quotes stacked on mobile */
    .t-photo {
      position: static;
      opacity: 1 !important;
    }

    .t-quote {
      position: static;
      opacity: 1 !important;
      pointer-events: auto;
    }

    .testimonials__photo-stage {
      aspect-ratio: 4 / 3;
    }

    .testimonials__quote-stage {
      min-height: 0;
    }

    .testimonials__names {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .t-name-btn {
      padding: 10px 20px 10px 0;
    }
  }
  /* ─── PLAY CAMPAIGN button (testimonial 0 only) ─── */
  .t-play-btn {
    position: absolute;
    bottom: 0;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cream);
    background: #052715;
    border: 1px solid #052715;
    padding: 14px 24px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      letter-spacing 0.4s ease,
      border-color 0.4s ease;
  }

  /* Cream fill that wipes in from left on hover */
  .t-play-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-cream);
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .t-play-btn__text,
  .t-play-btn__icon {
    position: relative;
    z-index: 2;
  }

  .t-play-btn__icon {
    font-size: 0.7rem;
  }

  .t-play-btn:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .t-play-btn:hover {
    color: #052715;
    letter-spacing: 0.11em;
    border-color: #052715;
  }

  /* ─── Video modal ─── */
  .t-video-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .t-video-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .t-video-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 13, 7, 0.88);
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .t-video-modal__container {
    position: relative;
    z-index: 1;
    width: min(90vw, 1400px);
  }

  .t-video-modal__close {
    position: absolute;
    top: -44px;
    right: 0;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 224, 212, 0.6);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    transition: color 0.2s ease;
  }

  .t-video-modal__close:hover {
    color: var(--color-cream);
  }

  .t-video-modal__video-wrap {
    position: relative;
    background: #000;
  }

  .t-video-modal__video-wrap video {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border: none;
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    /* padding-top removed — centering handled by justify-content: center */
    /* Do NOT reduce stage height — blockquote is already at 28px so there is
       less text; shrinking the stage too would leave no room for the absolutely-
       positioned play button at bottom: 0 */
    .testimonials__quote-stage {
      height: clamp(410px, 50vh, 570px);  /* midpoint between too-close and too-far */
      margin-right: 0;  /* remove screen-edge bleed — aligns with container and divider */
    }
    /* Target blockquote directly — it has explicit 32px/55px so inherited values
       from .t-quote would be silently overridden without this specificity */
    .t-quote blockquote {
      font-size: 28px;    /* 32px reduced further at user request */
      line-height: 48px;  /* maintains ×1.71 ratio */
    }
    .t-name-btn {
      font-size: 22px;  /* 24px × 0.917 */
    }
    .t-video-modal__container {
      width: min(85vw, 1200px);  /* scales down from baseline min(90vw, 1400px) */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    /* padding-top removed — centering handled by justify-content: center */
    .testimonials__quote-stage {
      height: clamp(369px, 45vh, 513px);  /* clamp(410,50vh,570) × 0.90 */
    }
    .t-quote blockquote {
      font-size: 26px;    /* 28px × 0.929 */
      line-height: 43px;  /* 48px × 0.90 */
    }
    .t-name-btn {
      font-size: 21px;  /* 22px × 0.955 */
    }
    .t-video-modal__container {
      width: min(85vw, 1100px);  /* scales down from 1200px */
    }
    /* Stage becomes tight — switch play button to normal flow */
    .t-play-btn {
      position: relative;
      bottom: auto;
      left: auto;
      margin-top: 24px;
      display: inline-flex;
    }
    /* Inside the row, play button inherits no extra margin from above */
    .t-btn-row .t-play-btn { margin-top: 0; }
    /* .t-story-btn and .t-btn-row are already in normal flow — no override needed */
    .t-more-btn  { font-size: 16px; }   /* 18px × 0.889 — scales with .t-name-btn */
    .t-more-line { width: 24px; }       /* 48px − 24px — proportional reduction */
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .testimonials__quote-stage {
      height: clamp(332px, 40.5vh, 462px);
    }
    .t-quote blockquote {
      font-size: 22px;
      line-height: 36px;
    }
    .t-name-btn {
      font-size: 20px;
    }
    .t-video-modal__container {
      width: min(85vw, 990px);
    }
    /* .t-play-btn already handled by ≤1280px breakpoint above — no override needed */
    .t-more-btn  { font-size: 15px; }   /* 16px × 0.938 — keeps pace with .t-name-btn → 20px */
    /* .t-more-line stays 24px — no further reduction needed at this breakpoint */
  }

  /* ─── "3 more voices" toggle button ─── */
  .t-more-btn {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    background: none;
    border: none;
    margin-top: 24px;
    padding: 0;
    font-family: var(--font-script);
    font-style: italic;
    font-variation-settings: "wght" 500, "hght" 1000;
    font-size: 18px;
    letter-spacing: 0.05em;
    color: #BBB1A7;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .t-more-btn:hover {
    color: #004f26;
  }

  /* Horizontal line — replaces arrow, aligns to text bottom */
  .t-more-line {
    display: block;
    width: 48px;
    height: 0.5px;
    background: currentColor;
    flex-shrink: 0;
    margin-bottom: 4px; /* fine-tune optical baseline alignment */
  }

  /* ─── Hidden extra names container ─── */
  .t-names-extra {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none; /* prevent keyboard/click interaction with hidden names */
    transition:
      max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.4s ease;
  }

  .t-names-extra.is-open {
    max-height: 400px;
    opacity: 1;
    pointer-events: auto;
  }

  /* Individual extra names: slide + fade in; restore full transition set from base rule */
  .t-names-extra .t-name-btn {
    opacity: 0;
    transform: translateY(-6px);
    transition:
      color 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
      font-weight 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .t-names-extra.is-open .t-name-btn { opacity: 1; transform: translateY(0); }
  .t-names-extra.is-open .t-name-btn:nth-child(1) { transition-delay: 0.06s; }
  .t-names-extra.is-open .t-name-btn:nth-child(2) { transition-delay: 0.12s; }
  .t-names-extra.is-open .t-name-btn:nth-child(3) { transition-delay: 0.18s; }

  /* ─── "The Full Story +" CTA button ─── */
  .t-story-btn {
    /* In normal flow — always sits a fixed gap below the attribution, regardless of quote length */
    position: relative;       /* contains ::before so the hover fill stays within the button */
    display: inline-flex;
    align-items: center;
    margin-top: 40px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #052715;
    background: transparent;
    border: 1px solid #052715;
    padding: 14px 24px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      letter-spacing 0.4s ease;
  }

  /* Dark green fill wipes in from left on hover */
  .t-story-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .t-story-btn__text {
    position: relative;
    z-index: 2;
  }

  .t-story-btn:hover::before { clip-path: inset(0 0% 0 0); }
  .t-story-btn:hover {
    color: var(--color-cream);
    letter-spacing: 0.11em;
  }

  /* ─── Button row — first testimonial only: side-by-side layout ─── */
  .t-btn-row {
    /* In normal flow — sits below the attribution like the standalone story button */
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 40px;
  }
  /* Play button resets its own absolute positioning when inside the row */
  .t-btn-row .t-play-btn {
    position: relative;
    bottom: auto;
    left: auto;
    margin-top: 0;
  }
  /* Story button's margin-top already 0 inside the row (row handles spacing) */
  .t-btn-row .t-story-btn {
    margin-top: 0;
  }

  /* ═══ Full-story modal ═══════════════════════════════════════════ */
  .t-fs-modal {
    position: fixed; inset: 0; z-index: 10002;
    visibility: hidden; pointer-events: none;
  }
  .t-fs-modal.is-open { visibility: visible; pointer-events: auto; }
  .t-fs-overlay {
    position: absolute; inset: 0;
    background: #052715; opacity: 0;
    transition: opacity 0.4s ease;
  }
  .t-fs-modal.is-open .t-fs-overlay { opacity: 1; }
  .t-fs-close {
    position: absolute;
    top: 18px;
    right: var(--section-padding-x, 48px);
    font-family: var(--font-sans); font-variation-settings: normal;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    background: none; border: none; cursor: pointer;
    padding: 8px 0;
    z-index: 1; transition: color 0.2s ease;
    -webkit-font-smoothing: antialiased;
  }
  .t-fs-close:hover { color: #ffffff; }
  .t-fs-panel {
    position: absolute;
    top: 64px;
    left: var(--section-padding-x, 48px);
    right: var(--section-padding-x, 48px);
    bottom: 0;
    background: var(--color-cream, #f8f2ed);
    /* overflow:clip — visually clips content like overflow:hidden but does NOT
       create a scroll container, so mouse-wheel events propagate correctly to
       the child scroll columns. overflow:hidden would block wheel events. */
    overflow: clip;
    transform: translateY(28px); opacity: 0;
    transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.35s ease;
  }
  .t-fs-modal.is-open .t-fs-panel { transform: translateY(0); opacity: 1; }
  .t-fs-body {
    display: grid;
    grid-template-columns: 2fr 3fr;
    grid-template-rows: 1fr;   /* CRITICAL: explicit row height breaks the circular
                                  dependency. Without this, the implicit 'auto' row
                                  sizes to content, height:100% on children becomes
                                  circular, and overflow-y:auto never activates. */
    height: 100%;
    /* No overflow set here — grid container must not intercept wheel events.
       Clipping is handled entirely by the panel using overflow:clip. */
  }
  .t-fs-left {
    position: relative;    /* containing block for .t-fs-watermark (position:absolute) */
    overflow-y: auto;
    overflow-x: hidden;   /* contain the B watermark horizontally */
    -webkit-overflow-scrolling: touch;
    min-height: 0;         /* CRITICAL: grid items default to min-height:auto which
                              prevents them being smaller than content, so overflow-y
                              never activates. min-height:0 removes that floor. */
    padding: clamp(28px,3.5vw,64px);
    display: flex; flex-direction: column;

  }
  .t-fs-watermark {
    position: absolute; bottom: -0.12em; left: -0.08em;
    font-family: var(--font-serif);
    font-size: clamp(240px,30vw,420px);
    font-weight: 700; line-height: 1;
    color: rgba(5,39,21,0.04);
    pointer-events: none; user-select: none; -webkit-user-select: none;
  }
  .t-fs-role {
    font-family: var(--font-sans); font-variation-settings: normal;
    font-size: var(--font-size-label, 0.7rem); font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: #BBB1A7; line-height: 1.8;
    margin: 0 0 clamp(20px,2.5vw,36px);
    position: relative; z-index: 1;
    -webkit-font-smoothing: antialiased;
  }
  .t-fs-images {
    display: flex; flex-direction: column;
    gap: 32px;
    position: relative; z-index: 1;
    /* Images have natural/varying heights; left column scrolls if they overflow */
  }
  .t-fs-img-wrap {
    width: 100%; overflow: hidden;
    background: rgba(5,39,21,0.07);
  }
  .t-fs-img {
    width: 100%; height: auto;
    object-fit: cover; object-position: center top;
    display: block;
  }
  .t-fs-img[src=""] { display: none; }
  .t-fs-right {
    /* Right column is the scroll container for all quote text */
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    min-height: 0;         /* CRITICAL: same fix as .t-fs-left — removes grid item's
                              default min-height:auto so overflow-y actually activates */
    height: 100%;          /* Explicit height ensures overflow-y:auto has a bound to
                              scroll within (complements min-height:0 on the grid item) */
    padding: clamp(28px,4vw,72px) clamp(28px,4.5vw,72px) clamp(40px,5vw,80px);
    box-sizing: border-box;
  }
  :global(.t-fs-quote p) {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400; line-height: 50px;
    letter-spacing: 0.02em; color: #052715;
    margin: 0 0 1.5em;
    -webkit-font-smoothing: antialiased;
  }
  :global(.t-fs-quote p:last-child) { margin-bottom: 0; }

</style>


<script>
  // ─── State ───────────────────────────────────────────────────────────────────
  const btns   = document.querySelectorAll<HTMLButtonElement>('.t-name-btn');
  const photos = document.querySelectorAll<HTMLElement>('.t-photo');
  const quotes = document.querySelectorAll<HTMLElement>('.t-quote');
  const track  = document.getElementById('testimonials') as HTMLElement;


  let current      = 0;
  let switching    = false;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;
  let scrollPaused = false; // suspended during sidebar expand/collapse animation
  let isExpanded   = false; // tracks sidebar expand state — read by onScroll

  // ─── Activate a testimonial ───────────────────────────────────────────────
  function activate(i: number) {
    if (i === current || switching) return;
    // Safety: guard against out-of-bounds indices from scroll driver drift
    if (i < 0 || i >= photos.length || i >= quotes.length) return;
    switching = true;

    btns.forEach((b, idx) => b.classList.toggle('is-active', idx === i));

    photos[current].classList.remove('is-active');
    quotes[current].classList.remove('is-active');

    current = i;

    setTimeout(() => {
      photos[i].classList.add('is-active');
      quotes[i].classList.add('is-active');
      switching = false;
    }, 120);
  }

  // ─── Scroll-progress driver ───────────────────────────────────────────────
  function onScroll() {
    if (!track || scrollPaused) return;

    const rect        = track.getBoundingClientRect();
    const trackH      = track.offsetHeight;
    const vh          = window.innerHeight;
    const totalTravel = trackH - vh;
    const scrolled    = -rect.top;

    if (scrolled < 0 || scrolled > totalTravel) return;

    const progress = scrolled / totalTravel;
    // n matches the number of visible scroll slots — track height is adjusted
    // dynamically on expand/collapse so each slot stays the same size (~125vh).
    const n   = isExpanded ? 7 : 4;
    const idx = Math.min(n - 1, Math.floor(progress * n));

    activate(idx);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on load

  // ─── "3 more voices" toggle ───────────────────────────────────────────────
  const moreBtn     = document.getElementById('t-more-btn') as HTMLButtonElement | null;
  const moreText    = moreBtn?.querySelector('.t-more-text') as HTMLElement | null;
  const extraNames  = document.getElementById('t-names-extra') as HTMLElement | null;

  moreBtn?.addEventListener('click', () => {
    // Pause scroll driver for the full animation window (max-height: 0.5s + buffer)
    scrollPaused = true;
    setTimeout(() => { scrollPaused = false; }, 600);

    isExpanded = !isExpanded;
    // Resize track so each slot stays ~125vh: 500vh÷4=125vh, 875vh÷7=125vh.
    // Skip on mobile where track height is 'auto' (set by media query).
    if (track && window.innerWidth > 768) {
      track.style.height = isExpanded ? '875vh' : '500vh';
    }

    extraNames?.classList.toggle('is-open', isExpanded);
    extraNames?.setAttribute('aria-hidden', String(!isExpanded));
    moreBtn.setAttribute('aria-expanded', String(isExpanded));
    if (moreText) moreText.textContent = isExpanded ? 'Show fewer' : 'More voices';
    if (!isExpanded && current >= 4) activate(3);
  });

  // ─── Manual click / hover (still works when reading the pinned panel) ─────
  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
      activate(i);
    });
    btn.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 200);
    });
    btn.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });
  });

  // ─── Per-line text reveal for blockquotes ────────────────────────────────
  const tReduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tMobile   = window.matchMedia('(max-width: 767px)').matches;

  if (!tReduced && !tMobile) {

    // Inject lr-clip CSS if BaseLayout hasn't already (e.g., desktop + no reduced motion)
    if (!document.querySelector('.lr-clip')) {
      const lcss = document.createElement('style');
      lcss.textContent = `
        .lr-clip{overflow:hidden;display:block}
        .lr-inner{display:block;transform:translateY(110%);will-change:transform}
        .lr-clip.lr-visible .lr-inner{transform:translateY(0)}
      `;
      document.head.appendChild(lcss);
    }

    // Split a blockquote into lr-clip line wrappers
    function splitBq(bq: HTMLElement) {
      // Reset CSS clamp before measuring — JS controls truncation after reading real line count.
      // Without this, overflow:hidden would cause incorrect offsetTop values for hidden spans.
      bq.style.display = 'block';
      bq.style.overflow = 'visible';

      const children = Array.from(bq.childNodes);
      type Atom = { html: string; isBr: boolean };
      const atoms: Atom[] = [];

      children.forEach(node => {
        if (node.nodeName === 'BR') {
          atoms.push({ html: '', isBr: true });
        } else if (node.nodeType === Node.TEXT_NODE) {
          (node.textContent || '').split(/\s+/).filter(w => w.length > 0)
            .forEach(w => atoms.push({ html: w, isBr: false }));
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          atoms.push({ html: (node as Element).outerHTML, isBr: false });
        }
      });

      if (atoms.filter(a => !a.isBr).length === 0) return;

      // Render measurement spans
      bq.innerHTML = '';
      const wrapEls: HTMLElement[] = [];
      atoms.forEach((atom, i) => {
        if (atom.isBr) {
          const s = document.createElement('span');
          s.className = 'lw-br';
          s.style.cssText = 'display:block;height:0;font-size:0;line-height:0';
          bq.appendChild(s); wrapEls.push(s);
        } else {
          const s = document.createElement('span');
          s.className = 'lw'; s.style.display = 'inline-block';
          s.innerHTML = atom.html;
          bq.appendChild(s); wrapEls.push(s);
          const next = atoms[i + 1];
          if (next && !next.isBr) bq.appendChild(document.createTextNode(' '));
        }
      });

      // Group by offsetTop
      const lineGroups: string[][] = [];
      let currentTop = -9999; let group: string[] = [];
      wrapEls.forEach(w => {
        if (w.classList.contains('lw-br')) {
          if (group.length) { lineGroups.push(group); group = []; }
          currentTop = -9999; return;
        }
        const top = w.offsetTop;
        if (Math.abs(top - currentTop) > 4) {
          if (group.length) lineGroups.push(group);
          group = []; currentTop = top;
        }
        group.push(w.innerHTML);
      });
      if (group.length) lineGroups.push(group);
      if (lineGroups.length === 0) return;

      // Truncate to 6 lines; the last visible line gets an inline ellipsis
      const MAX_LINES = 6;
      const wasTruncated = lineGroups.length > MAX_LINES;
      if (wasTruncated) lineGroups.splice(MAX_LINES);

      // Rebuild: one lr-clip/lr-inner per line
      bq.innerHTML = '';
      lineGroups.forEach((words, i) => {
        const clip  = document.createElement('div');
        clip.className = 'lr-clip';
        const inner = document.createElement('div');
        inner.className = 'lr-inner';
        inner.style.transition =
          `transform 0.85s cubic-bezier(0.42,0,0.24,1) ${(i * 0.09).toFixed(2)}s`;
        // Append ellipsis to the last visible line.
        // Remove the final word to guarantee the ellipsis + closing quote
        // fit on the same line without wrapping (standard JS truncation practice).
        inner.innerHTML = (wasTruncated && i === lineGroups.length - 1)
          ? (words.length > 1 ? words.slice(0, -1).join(' ') + ' ' : '') + '\u2026\u201d'
          : words.join(' ');
        clip.appendChild(inner);
        bq.appendChild(clip);
      });
    }

    // Reveal all lr-clip lines inside a t-quote element
    function revealQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.add('lr-visible'));
    }

    // Reset (hide) all lr-clip lines inside a t-quote element
    function resetQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.remove('lr-visible'));
    }

    // Split all blockquotes once fonts are ready
    (document.fonts?.ready ?? Promise.resolve()).then(() => {
      // Keep references and store originals BEFORE splitting so we can re-split on resize
      const bqs = Array.from(document.querySelectorAll<HTMLElement>('.t-quote blockquote'));
      bqs.forEach(bq => {
        bq.dataset.origHtml = bq.innerHTML;  // snapshot pre-split HTML
        splitBq(bq);
      });

      // Reveal initial active quote when the section first enters view
      const initialQuote = document.querySelector<HTMLElement>('.t-quote.is-active');
      if (initialQuote) {
        const trackEl = document.getElementById('testimonials');
        const sectionObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              revealQuote(initialQuote);
              sectionObserver.disconnect();
            }
          });
        }, { threshold: 0.1 });
        if (trackEl) sectionObserver.observe(trackEl);
      }

      // Watch for is-active changes on t-quote elements to trigger reveal/reset
      const quoteEls = document.querySelectorAll<HTMLElement>('.t-quote');
      const mutation = new MutationObserver(muts => {
        muts.forEach(m => {
          const el = m.target as HTMLElement;
          if (!el.classList.contains('t-quote')) return;
          if (el.classList.contains('is-active')) {
            setTimeout(() => revealQuote(el), 80);
          } else {
            resetQuote(el);
          }
        });
      });
      quoteEls.forEach(q => mutation.observe(q, { attributes: true, attributeFilter: ['class'] }));

      // ── Resize handler: re-split so lines reflow at new viewport width ────────
      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          // Restore each blockquote to its pre-split state then re-measure
          bqs.forEach(bq => {
            if (bq.dataset.origHtml !== undefined) bq.innerHTML = bq.dataset.origHtml;
            splitBq(bq);
          });

          // Re-reveal the currently active quote instantly (suppress transition flash)
          const active = document.querySelector<HTMLElement>('.t-quote.is-active');
          if (active) {
            active.querySelectorAll<HTMLElement>('blockquote > .lr-clip').forEach(clip => {
              clip.style.transition = 'none';
              clip.classList.add('lr-visible');
              // Re-enable transitions on the next paint so future tab-switches animate
              requestAnimationFrame(() => {
                requestAnimationFrame(() => { clip.style.transition = ''; });
              });
            });
          }
        }, 200); // 200ms debounce — fast enough to feel snappy, slow enough not to thrash
      });
    });
  }

  // ── Campaign video modal (Niamh Bryne testimonial #0) ───────────────────────────────────
  const playBtn    = document.getElementById('t-play-btn')           as HTMLButtonElement | null;
  const videoModal = document.getElementById('t-video-modal')         as HTMLElement      | null;
  const modalBack  = document.getElementById('t-video-modal-backdrop') as HTMLElement     | null;
  const modalClose = document.getElementById('t-video-modal-close')   as HTMLButtonElement | null;
  const campVideo  = document.getElementById('t-campaign-video')      as HTMLVideoElement | null;

  function openModal() {
    if (!videoModal || !campVideo) return;
    videoModal.classList.add('is-open');
    videoModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    campVideo.play();
  }

  function closeModal() {
    if (!videoModal || !campVideo) return;
    videoModal.classList.remove('is-open');
    videoModal.setAttribute('aria-hidden', 'true');
    campVideo.pause();
    campVideo.currentTime = 0;  /* reset to start for next open */
    document.body.style.overflow = '';
  }

  playBtn?.addEventListener('click', openModal);
  modalBack?.addEventListener('click', closeModal);
  modalClose?.addEventListener('click', closeModal);
  // Save keydown reference so it can be removed on cleanup
  function onKeydown(e: KeyboardEvent) {
    if (e.key === 'Escape' && videoModal?.classList.contains('is-open')) closeModal();
  }
  document.addEventListener('keydown', onKeydown);

  // ─── Astro SPA cleanup — remove window/document listeners on page transitions ──
  // Without this, scroll and keydown handlers stack up across navigations.
  document.addEventListener('astro:before-swap', () => {
    window.removeEventListener('scroll', onScroll);
    document.removeEventListener('keydown', onKeydown);
    closeFsModal();
  }, { once: true });

  // ═══ Full-story modal ═════════════════════════════════════════════════════
  const fsModal   = document.getElementById('t-fs-modal')   as HTMLElement | null;
  const fsClose   = document.getElementById('t-fs-close')   as HTMLButtonElement | null;
  const fsOverlay = document.getElementById('t-fs-overlay') as HTMLElement | null;
  const fsRole    = document.getElementById('t-fs-role')    as HTMLElement | null;
  const fsImg1    = document.getElementById('t-fs-img1')    as HTMLImageElement | null;
  const fsImg2    = document.getElementById('t-fs-img2')    as HTMLImageElement | null;
  const fsImg3    = document.getElementById('t-fs-img3')    as HTMLImageElement | null;
  const fsQuote   = document.getElementById('t-fs-quote')   as HTMLElement | null;
  const fsRight   = document.getElementById('t-fs-right')   as HTMLElement | null;

  type FsStory = { name: string; title: string; paragraphs: string[]; images: string[] };
  let fsStories: FsStory[] = [];
  try {
    const el = document.getElementById('t-stories-data');
    if (el) fsStories = JSON.parse(el.textContent ?? '[]');
  } catch (_) {}

  function openFsModal(idx: number) {
    const s = fsStories[idx];
    if (!s || !fsModal) return;
    if (fsRole)  fsRole.textContent = s.title;
    if (fsImg1)  { fsImg1.src = s.images[0] ?? '';  fsImg1.alt = s.name; }
    if (fsImg2)  { fsImg2.src = s.images[1] ?? '';  fsImg2.alt = s.name; }
    if (fsImg3)  { fsImg3.src = s.images[2] ?? '';  fsImg3.alt = s.name; }
    if (fsQuote) {
      fsQuote.innerHTML = s.paragraphs
        .map(p => `<p>${p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>`)
        .join('');
    }
    if (fsRight) fsRight.scrollTop = 0;
    // Also reset the left column scroll in case images were scrolled
    const fsLeft = document.querySelector<HTMLElement>('.t-fs-left');
    if (fsLeft) fsLeft.scrollTop = 0;
    fsModal.setAttribute('aria-hidden', 'false');
    fsModal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeFsModal() {
    if (!fsModal) return;
    fsModal.classList.remove('is-open');
    fsModal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Bind story buttons — index matches testimonial array order
  document.querySelectorAll<HTMLButtonElement>('.t-story-btn').forEach((btn, idx) => {
    btn.addEventListener('click', () => openFsModal(idx));
  });

  fsClose?.addEventListener('click', closeFsModal);
  fsOverlay?.addEventListener('click', closeFsModal);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && fsModal?.classList.contains('is-open')) closeFsModal();
  });
</script>
