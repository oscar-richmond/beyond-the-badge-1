---
const base = import.meta.env.BASE_URL + '/';

const testimonials = [
  {
    name: 'Clara Whitlock',
    title: 'Global Brand Lead, Elara Group',
    quoteBefore: '\u201cBeyond the Badge took our unshaped ambition and turned it into cultural ',
    quoteHighlight: 'resonance',
    quoteAfter: ' \u2014 they didn\u2019t just understand our brand, they understood the cultural spaces we wanted to reach with a level of trust we never thought we\u2019d command.\u201d',
    image: `${base}about-1.jpg`,
  },
  {
    name: 'Arthur Bennett',
    title: 'Creative Director, Studio North',
    quoteBefore: '\u201cGreat partnerships aren\u2019t built overnight \u2014 they\u2019re built on trust, shared values, and a team that knows exactly how to ',
    quoteHighlight: 'connect',
    quoteAfter: ' the right people with the right moments in culture.\u201d',
    image: `${base}about-2.jpg`,
  },
  {
    name: 'Julian Thorne',
    title: 'Head of Brand, Meridian',
    quoteBefore: '\u201cWhat sets Beyond the Badge apart is how deeply they understand ',
    quoteHighlight: 'culture',
    quoteAfter: '. They don\u2019t chase it \u2014 they\u2019re already there, and they bring you with them.\u201d',
    image: `${base}about-3.jpg`,
  },
];
---

<section class="testimonials section" id="testimonials">
  <div class="container">

    <div class="testimonials__header">
      <h2 class="testimonials__heading">Words from our clients</h2>
    </div>

    <hr class="testimonials__rule" />

    <div class="testimonials__body">

      <!-- Left: name list -->
      <div class="testimonials__names">
        {testimonials.map((t, i) => (
          <button
            class={`t-name-btn${i === 0 ? ' is-active' : ''}`}
            data-index={String(i)}
          >
            <span class="t-arrow">&rarr;</span>
            {t.name}
          </button>
        ))}
      </div>

      <!-- Centre: portrait (position:absolute crossfade) -->
      <div class="testimonials__photo-stage">
        {testimonials.map((t, i) => (
          <div class={`t-photo${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
            <img src={t.image} alt={t.name} />
          </div>
        ))}
      </div>

      <!-- Right: quote (position:absolute crossfade) -->
      <div class="testimonials__quote-stage">
        {testimonials.map((t, i) => (
          <div class={`t-quote${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
            <blockquote>
              {t.quoteBefore}<em class="t-highlight">{t.quoteHighlight}</em>{t.quoteAfter}
            </blockquote>
            <footer class="t-attribution">
              <strong class="t-client-name">{t.name}</strong>
              <span class="t-client-role">{t.title}</span>
            </footer>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: #f8f2ed;
    padding: var(--section-padding-y) 0;
  }

  .testimonials__heading {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 500;
    color: var(--color-text-dark);
    margin: 0 0 28px;
  }

  .testimonials__rule {
    border: none;
    border-top: 1px solid rgba(26, 58, 42, 0.18);
    margin: 0 0 52px;
  }

  /* ─── Three-column grid ─── */
  .testimonials__body {
    display: grid;
    grid-template-columns: minmax(140px, 20%) minmax(180px, 26%) 1fr;
    gap: 0 clamp(32px, 5vw, 72px);
    align-items: start;
  }

  /* ─── Left: name list ─── */
  .testimonials__names {
    display: flex;
    flex-direction: column;
  }

  .t-name-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 16px 0;
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    opacity: 0.45;
    text-align: left;
    cursor: pointer;
    background: none;
    transition: font-weight 0.35s ease, opacity 0.35s ease;
  }

  .testimonials__names .t-name-btn:last-child {
    border: none;
  }

  .t-arrow {
    color: #004f26;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
    display: inline-block;
  }

  .t-name-btn.is-active,
  .t-name-btn:hover {
    font-weight: 700;
    opacity: 1;
  }

  .t-name-btn.is-active .t-arrow,
  .t-name-btn:hover .t-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ─── Centre: photo stage ─── */
  .testimonials__photo-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
  }

  .t-photo {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .t-photo.is-active {
    opacity: 1;
  }

  .t-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(1);
    display: block;
  }

  /* ─── Right: quote stage ─── */
  .testimonials__quote-stage {
    position: relative;
    /* min-height keeps layout stable even when inactive quotes collapse */
    min-height: 280px;
  }

  .t-quote {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .t-quote.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .t-quote blockquote {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 400;
    line-height: 57px;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    font-style: normal;
    margin: 0 0 28px;
  }

  .t-highlight {
    font-style: italic;
    font-weight: 500;
    color: #004f26;
  }

  .t-attribution {
    display: none;
  }

  .t-client-name {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .t-client-role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .testimonials__body {
      grid-template-columns: 1fr;
      gap: 36px 0;
    }

    .testimonials__names {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px 0;
    }

    .t-name-btn {
      padding: 10px 20px 10px 0;
      border: none;
      border-bottom: 2px solid transparent;
    }

    .t-name-btn.is-active {
      border-bottom-color: #004f26;
    }

    .testimonials__photo-stage {
      aspect-ratio: 4 / 3;
    }

    .testimonials__quote-stage {
      min-height: 0;
    }
  }
</style>

<script>
  const btns   = document.querySelectorAll<HTMLButtonElement>('.t-name-btn');
  const photos = document.querySelectorAll<HTMLElement>('.t-photo');
  const quotes = document.querySelectorAll<HTMLElement>('.t-quote');

  let current = 0;
  let timer: ReturnType<typeof setTimeout> | null = null;
  let switching = false;

  function activate(i: number) {
    if (i === current || switching) return;
    switching = true;

    // Update name buttons immediately
    btns.forEach((b, idx) => b.classList.toggle('is-active', idx === i));

    // Fade out old photo & quote
    photos[current].classList.remove('is-active');
    quotes[current].classList.remove('is-active');

    const prev = current;
    current = i;

    // After brief gap, fade in new photo & quote
    setTimeout(() => {
      photos[i].classList.add('is-active');
      quotes[i].classList.add('is-active');
      switching = false;
    }, 120);
  }

  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (timer) clearTimeout(timer);
      activate(i);
    });
    btn.addEventListener('mouseenter', () => {
      timer = setTimeout(() => activate(i), 200);
    });
    btn.addEventListener('mouseleave', () => {
      if (timer) clearTimeout(timer);
    });
  });
</script>
