<script>
  import { gsap } from 'gsap';
  import { CustomEase } from 'gsap/CustomEase';
  gsap.registerPlugin(CustomEase);
  // Site-signature easing — same curve used on page transitions and button fills
  CustomEase.create('luxury', '.76,0,.24,1');
  // ─── State ───────────────────────────────────────────────────────────────────
  const btns   = document.querySelectorAll<HTMLButtonElement>('.t-name-btn');
  const photos = document.querySelectorAll<HTMLElement>('.t-photo');
  const quotes = document.querySelectorAll<HTMLElement>('.t-quote');
  const track  = document.getElementById('testimonials') as HTMLElement;


  let current      = 0;
  let switching    = false;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;
  let scrollPaused = false; // suspended during sidebar expand/collapse animation
  let isExpanded   = window.innerWidth <= 768; // at ≤768px all 7 testimonials are in the carousel by default
  // After a swipe snap, lock onScroll to only activate this index for 300ms
  // (prevents iOS residual scroll events from re-activating the wrong slot).
  // Unlike scrollPaused, onScroll still RUNS — the carousel feels unchanged.
  let snapTarget   = -1;

  // ─── Activate a testimonial ───────────────────────────────────────────────
  function activate(i: number) {
    if (i === current || switching) return;
    // Safety: guard against out-of-bounds indices from scroll driver drift
    if (i < 0 || i >= photos.length || i >= quotes.length) return;
    switching = true;

    btns.forEach((b, idx) => b.classList.toggle('is-active', idx === i));

    photos[current].classList.remove('is-active');
    quotes[current].classList.remove('is-active');

    current = i;

    setTimeout(() => {
      photos[i].classList.add('is-active');
      quotes[i].classList.add('is-active');
      switching = false;
    }, 120);
  }

  // ─── Scroll-progress driver ───────────────────────────────────────────────
  function onScroll() {
    if (!track || scrollPaused) return;

    const rect        = track.getBoundingClientRect();
    const trackH      = track.offsetHeight;
    const vh          = window.innerHeight;
    const totalTravel = trackH - vh;
    const scrolled    = -rect.top;

    if (scrolled < 0 || scrolled > totalTravel) return;

    const progress = scrolled / totalTravel;
    // n matches the number of visible scroll slots — track height is adjusted
    // dynamically on expand/collapse so each slot stays the same size (~125vh).
    const n   = isExpanded ? 7 : 5;
    const idx = Math.min(n - 1, Math.floor(progress * n));

    // Desktop: wheel handler owns all advancement.
    // Lenis momentum advances current through multiple slots during one gesture,
    // so letting onScroll run freely would make wheel snaps jump 2-3 slots.
    // Only confirm a snap that the wheel handler already initiated.
    if (!tMobile) {
      if (snapTarget >= 0 && idx === snapTarget) activate(idx);
      return;
    }

    // Mobile: proportional scroll driver with snap-guard.
    if (snapTarget >= 0 && idx !== snapTarget) return;
    activate(idx);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on load

  // ─── "3 more voices" toggle ───────────────────────────────────────────────
  const moreBtn     = document.getElementById('t-more-btn') as HTMLButtonElement | null;
  const moreText    = moreBtn?.querySelector('.t-more-text') as HTMLElement | null;
  const extraNames  = document.getElementById('t-names-extra') as HTMLElement | null;

  moreBtn?.addEventListener('click', () => {
    // Pause scroll driver for the full animation window (max-height: 0.5s + buffer)
    scrollPaused = true;
    setTimeout(() => { scrollPaused = false; }, 600);

    isExpanded = !isExpanded;
    // Resize track so each slot stays ~125vh: 625vh÷5=125vh, 875vh÷7=125vh.
    // Skip on mobile where track height is 'auto' (set by media query).
    if (track && window.innerWidth > 768) {
      track.style.height = isExpanded ? '875vh' : '625vh';
    }

    extraNames?.classList.toggle('is-open', isExpanded);
    extraNames?.setAttribute('aria-hidden', String(!isExpanded));
    moreBtn.setAttribute('aria-expanded', String(isExpanded));
    if (moreText) moreText.textContent = isExpanded ? 'Show fewer' : 'More voices';
    if (!isExpanded && current >= 5) activate(4);
  });

  // ─── Manual click / hover (still works when reading the pinned panel) ─────
  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
      activate(i);
    });
    btn.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 200);
    });
    btn.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });
  });

  // ─── Per-line text reveal for blockquotes ────────────────────────────────
  const tReduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tMobile   = window.matchMedia('(max-width: 768px)').matches;

  if (!tReduced && !tMobile) {

    // Inject lr-clip CSS if BaseLayout hasn't already (e.g., desktop + no reduced motion)
    if (!document.querySelector('.lr-clip')) {
      const lcss = document.createElement('style');
      lcss.textContent = `
        .lr-clip{overflow:hidden;display:block}
        .lr-inner{display:block;transform:translateY(110%);will-change:transform}
        .lr-clip.lr-visible .lr-inner{transform:translateY(0)}
      `;
      document.head.appendChild(lcss);
    }

    // Split a blockquote into lr-clip line wrappers
    function splitBq(bq: HTMLElement) {
      // Reset CSS clamp before measuring — JS controls truncation after reading real line count.
      // Without this, overflow:hidden would cause incorrect offsetTop values for hidden spans.
      bq.style.display = 'block';
      bq.style.overflow = 'visible';

      const children = Array.from(bq.childNodes);
      type Atom = { html: string; isBr: boolean };
      const atoms: Atom[] = [];

      children.forEach(node => {
        if (node.nodeName === 'BR') {
          atoms.push({ html: '', isBr: true });
        } else if (node.nodeType === Node.TEXT_NODE) {
          (node.textContent || '').split(/\s+/).filter(w => w.length > 0)
            .forEach(w => atoms.push({ html: w, isBr: false }));
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          atoms.push({ html: (node as Element).outerHTML, isBr: false });
        }
      });

      if (atoms.filter(a => !a.isBr).length === 0) return;

      // Render measurement spans
      bq.innerHTML = '';
      const wrapEls: HTMLElement[] = [];
      atoms.forEach((atom, i) => {
        if (atom.isBr) {
          const s = document.createElement('span');
          s.className = 'lw-br';
          s.style.cssText = 'display:block;height:0;font-size:0;line-height:0';
          bq.appendChild(s); wrapEls.push(s);
        } else {
          const s = document.createElement('span');
          s.className = 'lw'; s.style.display = 'inline-block';
          s.innerHTML = atom.html;
          bq.appendChild(s); wrapEls.push(s);
          const next = atoms[i + 1];
          if (next && !next.isBr) bq.appendChild(document.createTextNode(' '));
        }
      });

      // Group by offsetTop
      const lineGroups: string[][] = [];
      let currentTop = -9999; let group: string[] = [];
      wrapEls.forEach(w => {
        if (w.classList.contains('lw-br')) {
          if (group.length) { lineGroups.push(group); group = []; }
          currentTop = -9999; return;
        }
        const top = w.offsetTop;
        if (Math.abs(top - currentTop) > 4) {
          if (group.length) lineGroups.push(group);
          group = []; currentTop = top;
        }
        group.push(w.innerHTML);
      });
      if (group.length) lineGroups.push(group);
      if (lineGroups.length === 0) return;

      // Truncate to 6 lines; the last visible line gets an inline ellipsis
      const MAX_LINES = 6;
      const wasTruncated = lineGroups.length > MAX_LINES;
      if (wasTruncated) lineGroups.splice(MAX_LINES);

      // Rebuild: one lr-clip/lr-inner per line
      bq.innerHTML = '';
      lineGroups.forEach((words, i) => {
        const clip  = document.createElement('div');
        clip.className = 'lr-clip';
        const inner = document.createElement('div');
        inner.className = 'lr-inner';
        inner.style.transition =
          `transform 0.85s cubic-bezier(0.42,0,0.24,1) ${(i * 0.09).toFixed(2)}s`;
        // Append ellipsis to the last visible line.
        // Remove the final word to guarantee the ellipsis + closing quote
        // fit on the same line without wrapping (standard JS truncation practice).
        inner.innerHTML = (wasTruncated && i === lineGroups.length - 1)
          ? (words.length > 1 ? words.slice(0, -1).join(' ') + ' ' : '') + '\u2026\u201d'
          : words.join(' ');
        clip.appendChild(inner);
        bq.appendChild(clip);
      });
    }

    // Reveal all lr-clip lines inside a t-quote element
    function revealQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.add('lr-visible'));
    }

    // Reset (hide) all lr-clip lines inside a t-quote element
    function resetQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.remove('lr-visible'));
    }

    // Split all blockquotes once fonts are ready
    (document.fonts?.ready ?? Promise.resolve()).then(() => {
      // Keep references and store originals BEFORE splitting so we can re-split on resize
      const bqs = Array.from(document.querySelectorAll<HTMLElement>('.t-quote blockquote'));
      bqs.forEach(bq => {
        bq.dataset.origHtml = bq.innerHTML;  // snapshot pre-split HTML
        splitBq(bq);
      });

      // Reveal initial active quote when the section first enters view
      const initialQuote = document.querySelector<HTMLElement>('.t-quote.is-active');
      if (initialQuote) {
        const trackEl = document.getElementById('testimonials');
        const sectionObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              revealQuote(initialQuote);
              sectionObserver.disconnect();
            }
          });
        }, { threshold: 0.1 });
        if (trackEl) sectionObserver.observe(trackEl);
      }

      // Watch for is-active changes on t-quote elements to trigger reveal/reset
      const quoteEls = document.querySelectorAll<HTMLElement>('.t-quote');
      const mutation = new MutationObserver(muts => {
        muts.forEach(m => {
          const el = m.target as HTMLElement;
          if (!el.classList.contains('t-quote')) return;
          if (el.classList.contains('is-active')) {
            setTimeout(() => revealQuote(el), 80);
          } else {
            resetQuote(el);
          }
        });
      });
      quoteEls.forEach(q => mutation.observe(q, { attributes: true, attributeFilter: ['class'] }));

      // ── Resize handler: re-split so lines reflow at new viewport width ────────
      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          // Restore each blockquote to its pre-split state then re-measure
          bqs.forEach(bq => {
            if (bq.dataset.origHtml !== undefined) bq.innerHTML = bq.dataset.origHtml;
            splitBq(bq);
          });

          // Re-reveal the currently active quote instantly (suppress transition flash)
          const active = document.querySelector<HTMLElement>('.t-quote.is-active');
          if (active) {
            active.querySelectorAll<HTMLElement>('blockquote > .lr-clip').forEach(clip => {
              clip.style.transition = 'none';
              clip.classList.add('lr-visible');
              // Re-enable transitions on the next paint so future tab-switches animate
              requestAnimationFrame(() => {
                requestAnimationFrame(() => { clip.style.transition = ''; });
              });
            });
          }
        }, 200); // 200ms debounce — fast enough to feel snappy, slow enough not to thrash
      });
    });
  }

  // ── Mobile (≤768px): truncate each quote to exactly 8 lines ending with closing "
  if (tMobile) {
    const MAX_H = 8 * 28 * 1.65; // 8 lines × 28px × 1.65 line-height ≈ 369.6px
    document.querySelectorAll<HTMLElement>('.t-quote blockquote').forEach(bq => {
      // Lift clamp to measure full height
      bq.style.setProperty('display',            'block',   'important');
      bq.style.setProperty('overflow',           'visible', 'important');
      bq.style.setProperty('-webkit-line-clamp', 'unset',   'important');
      const fullH = bq.scrollHeight;
      bq.style.removeProperty('display');
      bq.style.removeProperty('overflow');
      bq.style.removeProperty('-webkit-line-clamp');

      if (fullH <= MAX_H + 2) return; // fits — closing " already present in data

      // Binary-search cutpoint; strip any trailing closing curly-quote first
      const raw = (bq.textContent || '').replace(/\u201d\s*$/, '').trimEnd();
      bq.style.setProperty('display',            'block',   'important');
      bq.style.setProperty('overflow',           'visible', 'important');
      bq.style.setProperty('-webkit-line-clamp', 'unset',   'important');
      let lo = 0, hi = raw.length;
      while (lo < hi - 1) {
        const mid = (lo + hi) >> 1;
        bq.textContent = raw.slice(0, mid) + '\u2026\u201d';
        bq.scrollHeight <= MAX_H + 2 ? (lo = mid) : (hi = mid);
      }
      bq.textContent = raw.slice(0, lo).trimEnd() + '\u2026\u201d';
      bq.style.removeProperty('display');
      bq.style.removeProperty('overflow');
      bq.style.removeProperty('-webkit-line-clamp');
    });
