    stickyEl?.addEventListener('touchend', (e: TouchEvent) => {
      if (swipeStartY === -1 || !track) return;

      const dy    = swipeStartY - e.changedTouches[0].clientY; // +ve = finger up = advance
      const dx    = Math.abs(e.changedTouches[0].clientX - swipeStartX);
      const dyAbs = Math.abs(dy);

      // Ignore taps (<10px) and horizontal gestures
      if (dyAbs < 10 || dx > dyAbs) return;

      const n      = isExpanded ? 7 : 5;
      const target = dy > 0
        ? Math.min(n - 1, current + 1)   // finger up   → next
        : Math.max(0,      current - 1);  // finger down → prev

      const trackTop    = track.getBoundingClientRect().top + window.scrollY;
      const totalTravel = track.offsetHeight - window.innerHeight;

      if (target !== current) {
        // Snap to target slot centre
        window.scrollTo({ top: trackTop + ((target + 0.5) / n) * totalTravel, behavior: 'auto' });
        snapTarget = target;
        setTimeout(() => { snapTarget = -1; }, 200);
        activate(target);
      } else {
        // At edge — scroll past the section
        if (dy > 0) {
          // Past last testimonial → enter next section
          window.scrollTo({ top: trackTop + totalTravel + 80, behavior: 'smooth' });
        } else {
          // Before first testimonial → scroll above section
          window.scrollTo({ top: Math.max(0, trackTop - 80), behavior: 'smooth' });
        }
      }
    }, { passive: true });
  }

  // ── Wheel/trackpad snap (all breakpoints) ────────────────────────────────────
  // Strategy: separate "snap-blocking" from "scroll-blocking".
  //
  // The problem with a fixed debounce: Mac trackpad momentum emits wheel events
  // for 1-3 seconds. Calling e.preventDefault() on ALL of them leaves the user
  // completely stuck. But NOT calling it lets Lenis advance the page further.
  //
  // Solution: once we have snapped for a gesture, we stop blocking scroll
  // (no preventDefault / stopPropagation on momentum tail), letting Lenis handle
  // the remaining momentum naturally. onScroll is disabled on desktop so Lenis
  // drifting the page slightly does NOT advance the testimonial. We only block
  // the SNAP action (gestureSnapped guard) using timestamp-gap detection:
  // if the gap between two wheel events is > GESTURE_END_MS, it's a new gesture.
  {
    const stickyWheel    = document.querySelector<HTMLElement>('.testimonials-sticky');
    const GESTURE_END_MS = 300; // gap this long = new deliberate gesture
    let   gestureSnapped = false;
    let   lastWheelTime  = 0;

    stickyWheel?.addEventListener('wheel', (e: WheelEvent) => {
      if (!track) return;

      const rect = track.getBoundingClientRect();
      const inZone = rect.top <= 0 && rect.bottom >= window.innerHeight;

      // Outside the sticky zone → let Lenis handle freely, reset snap state
      if (!inZone) {
        gestureSnapped = false;
        return;
      }

      // ── Gesture-new detection ────────────────────────────────────────────
      const now = Date.now();
      const gap = now - lastWheelTime;
      lastWheelTime = now;
      if (gap > GESTURE_END_MS) {
        gestureSnapped = false; // enough silence = new gesture
      }

      if (gestureSnapped) {
        // Already snapped for this gesture.
        // Do NOT preventDefault — let momentum reach Lenis naturally.
        // onScroll is disabled on desktop so no testimonial will advance.
        return;
      }

      // ── First event of a new gesture: take ownership ─────────────────────
      e.preventDefault();
      e.stopPropagation();

      const n           = isExpanded ? 7 : 5;
      const trackTop    = track.getBoundingClientRect().top + window.scrollY;
      const totalTravel = track.offsetHeight - window.innerHeight;
      const target      = e.deltaY > 0
        ? Math.min(n - 1, current + 1)
        : Math.max(0,      current - 1);

      gestureSnapped = true; // block further snaps in this gesture

      if (target !== current) {
        const snapY = trackTop + ((target + 0.5) / n) * totalTravel;

        snapTarget = target;
        setTimeout(() => { snapTarget = -1; }, 700);

        const lenis = (window as any).__lenis;
        if (lenis) {
          lenis.stop();
          window.scrollTo({ top: snapY, behavior: 'instant' });
          requestAnimationFrame(() => lenis.start());
        } else {
          window.scrollTo({ top: snapY, behavior: 'auto' });
        }

        activate(target);
      } else {
        // At edge — scroll past the section so user isn't trapped
        const lenis = (window as any).__lenis;
        if (e.deltaY > 0) {
          const exitY = trackTop + totalTravel + 80;
          lenis ? lenis.scrollTo(exitY) : window.scrollTo({ top: exitY, behavior: 'smooth' });
        } else {
          const exitY = Math.max(0, trackTop - 80);
          lenis ? lenis.scrollTo(exitY) : window.scrollTo({ top: exitY, behavior: 'smooth' });
        }
      }
    }, { passive: false });
  }

  // ── Campaign video modal (Stephanie Wenborn #1 and Niamh Bryne #3) ─────────────────────
  // Sources are driven by data-video-webm / data-video-mp4 on each .t-play-btn so the same
  // modal element serves both testimonials without duplicating markup.
  const playBtns   = document.querySelectorAll<HTMLButtonElement>('.t-play-btn');
  const videoModal  = document.getElementById('t-video-modal')          as HTMLElement      | null;
  const modalBack   = document.getElementById('t-video-modal-backdrop') as HTMLElement      | null;
  const modalClose  = document.getElementById('t-video-modal-close')    as HTMLButtonElement | null;
  const campVideo   = document.getElementById('t-campaign-video')       as HTMLVideoElement | null;
  const campSrcWebm = document.getElementById('t-campaign-src-webm')    as HTMLSourceElement | null;
  const campSrcMp4  = document.getElementById('t-campaign-src-mp4')     as HTMLSourceElement | null;

  function openModal(webmSrc: string, mp4Src: string) {
    if (!videoModal || !campVideo) return;
    if (campSrcWebm) campSrcWebm.src = webmSrc;
    if (campSrcMp4)  campSrcMp4.src  = mp4Src;
    campVideo.load();                       // reload decoder with new sources
    videoModal.classList.add('is-open');
    videoModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    campVideo.play().catch(() => {});       // autoplay may be blocked; user can tap ▶
  }

  function closeModal() {
    if (!videoModal || !campVideo) return;
    videoModal.classList.remove('is-open');
    videoModal.setAttribute('aria-hidden', 'true');
    campVideo.pause();
    campVideo.currentTime = 0;
    // Clear sources to release the video resource
    if (campSrcWebm) campSrcWebm.src = '';
    if (campSrcMp4)  campSrcMp4.src  = '';
    campVideo.load();
    document.body.style.overflow = '';
  }

  playBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      openModal(
        btn.dataset.videoWebm ?? '',
        btn.dataset.videoMp4  ?? '',
      );
    });
  });
  modalBack?.addEventListener('click', closeModal);
  modalClose?.addEventListener('click', closeModal);
  // Save keydown reference so it can be removed on cleanup
  function onKeydown(e: KeyboardEvent) {
    if (e.key === 'Escape' && videoModal?.classList.contains('is-open')) closeModal();
  }
  document.addEventListener('keydown', onKeydown);

  // ─── Astro SPA cleanup — remove window/document listeners on page transitions ──
  // Without this, scroll and keydown handlers stack up across navigations.
  document.addEventListener('astro:before-swap', () => {
    window.removeEventListener('scroll', onScroll);
    document.removeEventListener('keydown', onKeydown);
    closeFsModal(true); // instant — page curtain already covers the transition
  }, { once: true });

  // ── bfcache restoration: force-close any open modal ──────────────────────
  // If a modal was open when the user navigated away, bfcache freezes that
  // state. Pressing Back restores it instantly — modal is still "open" and
  // body.overflow is still hidden. The pageshow handler in BaseLayout clears
  // the overflow; this handler closes the modals themselves cleanly.
  window.addEventListener('pageshow', (event) => {
    if (!(event as PageTransitionEvent).persisted) return;
    closeFsModal(true);
    closeModal();
  });

  // ═══ Full-story modal ═════════════════════════════════════════════════════
  const fsModal   = document.getElementById('t-fs-modal')   as HTMLElement | null;
  const fsClose   = document.getElementById('t-fs-close')   as HTMLButtonElement | null;
  const fsOverlay = document.getElementById('t-fs-overlay') as HTMLElement | null;
  const fsRole    = document.getElementById('t-fs-role')    as HTMLElement | null;
  const fsName    = document.getElementById('t-fs-name')    as HTMLElement | null;
  const fsImg1    = document.getElementById('t-fs-img1')    as HTMLImageElement | null;
  const fsImg2    = document.getElementById('t-fs-img2')    as HTMLImageElement | null;
  const fsImg3    = document.getElementById('t-fs-img3')    as HTMLImageElement | null;
  const fsImg4    = document.getElementById('t-fs-img4')    as HTMLImageElement | null;
  const fsImg5    = document.getElementById('t-fs-img5')    as HTMLImageElement | null;
  const fsQuote   = document.getElementById('t-fs-quote')   as HTMLElement | null;
  const fsRight   = document.getElementById('t-fs-right')   as HTMLElement | null;
  const fsLeft    = document.querySelector<HTMLElement>('.t-fs-left');
  const fsPanel   = document.querySelector<HTMLElement>('.t-fs-panel');

  // Running timeline reference — killed before each new open/close
  let fsTl: gsap.core.Timeline | null = null;

  type FsStory = { name: string; title: string; paragraphs: string[]; images: string[] };
  let fsStories: FsStory[] = [];
  try {
    const el = document.getElementById('t-stories-data');
    if (el) fsStories = JSON.parse(el.textContent ?? '[]');
  } catch (_) {}

  function openFsModal(idx: number) {
    const s = fsStories[idx];
    if (!s || !fsModal || !fsPanel) return;

    // Kill any in-progress close animation
    fsTl?.kill();

    // Populate content
    if (fsName)  fsName.textContent  = s.name;
    if (fsRole)  fsRole.textContent  = s.title;
    if (fsImg1)  { fsImg1.src = s.images[0] ?? '';  fsImg1.alt = s.name; }
    if (fsImg2)  { fsImg2.src = s.images[1] ?? '';  fsImg2.alt = s.name; }
    if (fsImg3)  { fsImg3.src = s.images[2] ?? '';  fsImg3.alt = s.name; }
    if (fsImg4)  { fsImg4.src = s.images[3] ?? '';  fsImg4.alt = s.name; }
    if (fsImg5)  { fsImg5.src = s.images[4] ?? '';  fsImg5.alt = s.name; }
    // Hide unused image slots so they leave no gap
    [fsImg1, fsImg2, fsImg3, fsImg4, fsImg5].forEach((img, i) => {
      const wrap = document.getElementById(`t-fs-img${i + 1}-wrap`);
      if (wrap) wrap.style.display = (s.images[i] ? '' : 'none');
    });
    if (fsQuote) {
      fsQuote.innerHTML = s.paragraphs
        .map(p => `<p>${p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>`)
        .join('');
    }
    if (fsPanel) fsPanel.scrollTop = 0;

    // Set initial animation states before making the modal visible
    gsap.set(fsPanel,   { opacity: 0, y: 52, scale: 0.97 });
    gsap.set(fsLeft,    { opacity: 0, x: -28 });
    gsap.set(fsRight,   { opacity: 0, y: 28 });
    gsap.set(fsClose,   { opacity: 0 });
    gsap.set(fsOverlay, { opacity: 0 });

    // Make modal visible (visibility:visible + pointer-events:auto)
    fsModal.setAttribute('aria-hidden', 'false');
    fsModal.classList.add('is-open');
    document.body.style.overflow = 'hidden';

    // ── Staggered luxury open sequence ──────────────────────────────────────
    // Dark overlay fades in first, then the cream panel rises with a subtle
    // scale (depth cue), then columns stagger in from their natural directions.
    fsTl = gsap.timeline();
    fsTl
      .to(fsOverlay, { opacity: 1,                 duration: 0.45, ease: 'power2.out'  }, 0)
      .to(fsPanel,   { opacity: 1, y: 0, scale: 1, duration: 0.72, ease: 'luxury'      }, 0.04)
      .to(fsClose,   { opacity: 1,                 duration: 0.30, ease: 'power2.out'  }, 0.30)
      .to(fsLeft,    { opacity: 1, x: 0,           duration: 0.55, ease: 'power3.out'  }, 0.30)
      .to(fsRight,   { opacity: 1, y: 0,           duration: 0.55, ease: 'power3.out'  }, 0.42);
  }

  function closeFsModal(instant = false) {
    if (!fsModal) return;

    fsTl?.kill();

    if (instant) {
      // Page navigation — close immediately, curtain covers it
      fsModal.classList.remove('is-open');
      fsModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      gsap.set([fsPanel, fsLeft, fsRight, fsClose, fsOverlay], { clearProps: 'all' });
      return;
    }

    // ── Animated close — content out, panel sinks, overlay clears ───────────
    fsTl = gsap.timeline({
      onComplete: () => {
        fsModal!.classList.remove('is-open');
        fsModal!.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        gsap.set([fsPanel, fsLeft, fsRight, fsClose, fsOverlay], { clearProps: 'all' });
      },
    });
    fsTl
      // Last in, first out — mirrors the open stagger in reverse
      .to(fsRight,   { opacity: 0, y: 28,            duration: 0.38, ease: 'power3.in'  }, 0)
      .to(fsLeft,    { opacity: 0, x: -28,            duration: 0.38, ease: 'power3.in'  }, 0.10)
      .to(fsClose,   { opacity: 0,                   duration: 0.22, ease: 'power2.in'  }, 0.10)
      .to(fsPanel,   { opacity: 0, y: 52, scale: 0.97, duration: 0.55, ease: 'power2.in'  }, 0.26)
      .to(fsOverlay, { opacity: 0,                   duration: 0.45, ease: 'power2.in'  }, 0.30);
  }

  // Bind story buttons via pointerup (not click).
  // On Chrome, click can be suppressed when a parent element has touch event
  // listeners. pointerup fires directly from the pointer event pipeline,
  // bypassing that suppression on both Chrome and Safari.
  document.querySelectorAll<HTMLButtonElement>('.t-story-btn').forEach((btn, idx) => {
    let ptrDownY = 0;
    btn.addEventListener('pointerdown', (e: PointerEvent) => { ptrDownY = e.clientY; });
    btn.addEventListener('pointerup', (e: PointerEvent) => {
      // Only open if the pointer barely moved (<20px) — i.e. it was a tap not a drag
      if (Math.abs(e.clientY - ptrDownY) < 20) openFsModal(idx);
    });
  });
  fsClose?.addEventListener('click',   () => closeFsModal());
  fsOverlay?.addEventListener('click', () => closeFsModal());

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && fsModal?.classList.contains('is-open')) closeFsModal();
  });
</script>
