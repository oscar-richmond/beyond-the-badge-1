---
const base = import.meta.env.BASE_URL;

const testimonials = [
  {
    name: 'Niamh Bryne',
    title: 'Artist Manager — Gorillaz, Founder Eleven Management & MMF Chair',
    quoteBefore: '\u201cWhen we first sat down with Laura Wood and her team at Jaguar Land Rover, we knew we weren\u2019t looking at a standard corporate partnership. Laura didn\u2019t just want a logo on a car; she had the vision to treat our Gorillaz fanbase as a ',
    quoteHighlight: 'community',
    quoteAfter: ' of untapped talent.\u201d',
    image: `${base}testimonial-1.jpg`,
  },
  {
    name: 'Dominic Reid OBE',
    title: 'Formerly Founding CEO of the Invictus Games',
    quoteBefore: '\u201cLaura has an intelligent and imaginative grasp of the way brands can work with properties that they sponsor to their mutual benefit. She was instrumental in the successful ',
    quoteHighlight: 'partnership',
    quoteAfter: ' between Jaguar Land Rover and the Invictus Games. And she brought to bear her creativity and incisiveness to address challenges and deliver better and better solutions. In addition to this, she is a delight to work with.\u201d',
    image: `${base}testimonial-2.jpg`,
  },
  {
    name: 'Dave Benett',
    title: 'Photographer (Getty Images / London Evening Standard)',
    quoteBefore: '\u201cLaura curates cultural moments that matter. Her ability to handle big personalities and even bigger brand expectations with such grace is why she\u2019s so respected in this industry. Whenever Laura is running the show, you just know the end result is going to look world-class and, more importantly, people are actually going to be talking about it. She\u2019s a class act, sharp, professional, and someone who genuinely understands the intersection of brand and ',
    quoteHighlight: 'culture',
    quoteAfter: '.\u201d',
    image: `${base}testimonial-3.jpg`,
  },
  {
    name: 'David Gandy',
    title: 'Model & Entrepreneur',
    quoteBefore: '\u201cI have had the pleasure of working with Laura for over 15 years on high-profile events, activations, and partnerships. Throughout this time, I cannot speak highly enough about her unwavering commitment, dedication, and exceptional problem-solving skills. She is never shy of thinking outside the box, and her dynamic, innovative approach has been instrumental in driving the huge successes achieved with the brands she has worked with.\u201d',
    quoteHighlight: '',
    quoteAfter: '',
    image: `${base}testimonial-4.jpg`,
  },
  {
    name: 'Paul Amadi',
    title: 'Marketing Consultant (former British Red Cross Executive Director of Marketing, Fundraising and Communications)',
    quoteBefore: '\u201cAs the brand lead for the British Red Cross, our joint strategic challenge was to evolve a 70-year partnership and take it from an established alliance and develop it something that was progressive and modern and a genuine engine for driving real humanitarian impact.\u201d',
    quoteHighlight: '',
    quoteAfter: '',
    image: `${base}testimonial-5.jpg`,
  },
];
---

<!-- Outer scroll track: 500vh gives 400vh of sticky scroll distance (5 × ~80vh per testimonial) -->
<div class="testimonials-track" id="testimonials">
  <!-- Sticky panel: pins to viewport while track scrolls past -->
  <section class="testimonials-sticky" aria-label="What our friends say">
    <div class="container">

      <div class="testimonials__header">
        <h2 class="testimonials__heading">What our friends say</h2>
      </div>

      <hr class="testimonials__rule" />

      <div class="testimonials__body">

        <!-- Left: name list -->
        <div class="testimonials__names">
          {testimonials.map((t, i) => (
            <button
              class={`t-name-btn${i === 0 ? ' is-active' : ''}`}
              data-index={String(i)}
            >
              <span class="t-arrow" aria-hidden="true">&rarr;</span>
              <span class="t-name-text">{t.name}</span>
            </button>
          ))}
        </div>

        <!-- Centre: portrait (position:absolute crossfade) -->
        <div class="testimonials__photo-stage">
          {testimonials.map((t, i) => (
            <div class={`t-photo${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <img src={t.image} alt={t.name} />
            </div>
          ))}
        </div>

        <!-- Right: quote (position:absolute crossfade) -->
        <div class="testimonials__quote-stage">
          {testimonials.map((t, i) => (
            <div class={`t-quote${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <blockquote>
                {t.quoteBefore}<em class="t-highlight">{t.quoteHighlight}</em>{t.quoteAfter}
                {t.quoteParagraph2 && (
                  <span class="t-quote-p2">{t.quoteParagraph2}</span>
                )}
              </blockquote>
              <p class="t-role-credit">{t.title}</p>
              <footer class="t-attribution">
                <strong class="t-client-name">{t.name}</strong>
                <span class="t-client-role">{t.title}</span>
              </footer>
              {i === 0 && (
                <button class="t-play-btn" id="t-play-btn" aria-label="Play Gorillaz x Jaguar Land Rover campaign video">
                  <span class="t-play-btn__text">Play Campaign</span>
                  <span class="t-play-btn__icon" aria-hidden="true">▶</span>
                </button>
              )}
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
</div>

<!-- Campaign video modal (Niamh Bryne / Gorillaz × JLR testimonial) -->
<div class="t-video-modal" id="t-video-modal" aria-hidden="true" role="dialog" aria-label="Campaign video">
  <div class="t-video-modal__backdrop" id="t-video-modal-backdrop"></div>
  <div class="t-video-modal__container">
    <button class="t-video-modal__close" id="t-video-modal-close" aria-label="Close video">✕ Close</button>
    <div class="t-video-modal__video-wrap">
      <video
        id="t-campaign-video"
        controls
        playsinline
        preload="none"
        aria-label="Gorillaz x Jaguar Land Rover campaign video"
      >
        <source src="/campaign-video.webm" type="video/webm" />
        <source src="/campaign-video.mp4"  type="video/mp4" />
      </video>
    </div>
  </div>
</div>

<style>
  /* ─── Scroll track (outer, 300vh) ─── */
  .testimonials-track {
    height: 500vh;
    background: transparent;
    /* Needed so sticky child has correct offset parent */
    position: relative;
  }

  /* Sticky panel (pins while track scrolls) */
  .testimonials-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: center;  /* vertically centred in viewport */
    overflow: hidden;
  }

  .testimonials-sticky .container {
    width: 100%;
  }

  .testimonials__heading {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #052715;
    margin: 0 0 28px;
  }

  .testimonials__rule {
    border: none;
    border-top: 1px solid #D9D0C8;
    margin: 0 0 52px;
  }

  /* ─── Three-column grid ─── */
  .testimonials__body {
    display: grid;
    grid-template-columns: minmax(100px, 12.7%) minmax(180px, 26%) 1fr;
    gap: 0 clamp(32px, 5vw, 72px);
    align-items: start;
  }

  /* ─── Left: name list ─── */
  .testimonials__names {
    display: flex;
    flex-direction: column;
  }

  .t-name-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 16px 0;
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #BBB1A7;
    text-align: left;
    cursor: pointer;
    background: none;
    transition: color 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                font-weight 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active,
  .t-name-btn:hover {
    font-weight: 700;
    color: #004f26;
  }

  /* Arrow — absolute at left:0, fades in after slide begins */
  .t-arrow {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: #004f26;
    opacity: 0;
    transition: opacity 0.4s ease 0.1s;
    pointer-events: none;
  }

  .t-name-btn.is-active .t-arrow,
  .t-name-btn:hover .t-arrow {
    opacity: 1;
  }

  /* Name text — slides right */
  .t-name-text {
    display: inline-block;
    transform: translateX(0);
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active .t-name-text,
  .t-name-btn:hover .t-name-text {
    transform: translateX(28px);
  }

  /* ─── Centre: photo stage ─── */
  .testimonials__photo-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
  }

  .t-photo {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .t-photo.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .t-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: none;
    display: block;
  }

  /* ─── Right: quote stage ─── */
  .testimonials__quote-stage {
    position: relative;
    /* Bleed to the right page margin — cancels the container's right padding */
    margin-right: calc(-1 * var(--section-padding-x));
    /* Explicit height so position:absolute quotes have a containing block
       and the stage never reflows when switching testimonials. */
    height: clamp(360px, 46vh, 540px);
  }

  .t-quote {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .t-quote.is-active {
    opacity: 1;
    pointer-events: auto;
    /* Stay position:absolute — switching active quote must NOT change
       the stage height or the whole panel would recenter and jump. */
  }

  .t-quote blockquote {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    line-height: 55px;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    font-style: normal;
    margin: 0 0 28px;
  }

  .t-highlight {
    font-style: inherit;
    font-weight: inherit;
    color: inherit;
  }

  /* Second paragraph of a multi-paragraph quote */
  .t-quote-p2 {
    display: block;
    margin-top: 1em;
  }

  .t-attribution {
    display: none;
  }

  /* Credit line: role shown below quote with paragraph-break spacing */
  .t-role-credit {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #BBB1A7;
    margin: 28px 0 0;
    line-height: 1.6;
  }

  .t-client-name {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .t-client-role {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    color: var(--color-text-muted);
  }

  /* ─── Mobile: unpin, stack all three ─── */
  @media (max-width: 768px) {
    .testimonials-track {
      height: auto;
    }

    .testimonials-sticky {
      position: static;
      height: auto;
      padding: var(--section-padding-y) 0;
    }

    .testimonials__body {
      grid-template-columns: 1fr;
      gap: 36px 0;
    }

    /* Show all photos and quotes stacked on mobile */
    .t-photo {
      position: static;
      opacity: 1 !important;
    }

    .t-quote {
      position: static;
      opacity: 1 !important;
      pointer-events: auto;
    }

    .testimonials__photo-stage {
      aspect-ratio: 4 / 3;
    }

    .testimonials__quote-stage {
      min-height: 0;
    }

    .testimonials__names {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .t-name-btn {
      padding: 10px 20px 10px 0;
    }
  }
  /* ─── PLAY CAMPAIGN button (testimonial 0 only) ─── */
  .t-play-btn {
    position: absolute;
    bottom: 0;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #052715;
    background: transparent;
    border: 1px solid #052715;
    padding: 14px 24px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      letter-spacing 0.4s ease,
      border-color 0.4s ease;
  }

  /* Green fill that wipes in from left on hover */
  .t-play-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .t-play-btn__text,
  .t-play-btn__icon {
    position: relative;
    z-index: 2;
  }

  .t-play-btn__icon {
    font-size: 0.7rem;
  }

  .t-play-btn:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .t-play-btn:hover {
    color: var(--color-cream);
    letter-spacing: 0.11em;
    border-color: #052715;
  }

  /* ─── Video modal ─── */
  .t-video-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .t-video-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .t-video-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 13, 7, 0.88);
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .t-video-modal__container {
    position: relative;
    z-index: 1;
    width: min(90vw, 1400px);
  }

  .t-video-modal__close {
    position: absolute;
    top: -44px;
    right: 0;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 224, 212, 0.6);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    transition: color 0.2s ease;
  }

  .t-video-modal__close:hover {
    color: var(--color-cream);
  }

  .t-video-modal__video-wrap {
    position: relative;
    background: #000;
  }

  .t-video-modal__video-wrap video {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border: none;
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    /* padding-top removed — centering handled by justify-content: center */
    /* Do NOT reduce stage height — blockquote is already at 28px so there is
       less text; shrinking the stage too would leave no room for the absolutely-
       positioned play button at bottom: 0 */
    .testimonials__quote-stage {
      height: clamp(410px, 50vh, 570px);  /* midpoint between too-close and too-far */
      margin-right: 0;  /* remove screen-edge bleed — aligns with container and divider */
    }
    /* Target blockquote directly — it has explicit 32px/55px so inherited values
       from .t-quote would be silently overridden without this specificity */
    .t-quote blockquote {
      font-size: 28px;    /* 32px reduced further at user request */
      line-height: 48px;  /* maintains ×1.71 ratio */
    }
    .t-name-btn {
      font-size: 22px;  /* 24px × 0.917 */
    }
    .t-video-modal__container {
      width: min(85vw, 1200px);  /* scales down from baseline min(90vw, 1400px) */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    /* padding-top removed — centering handled by justify-content: center */
    .testimonials__quote-stage {
      height: clamp(369px, 45vh, 513px);  /* clamp(410,50vh,570) × 0.90 */
    }
    .t-quote blockquote {
      font-size: 26px;    /* 28px × 0.929 */
      line-height: 43px;  /* 48px × 0.90 */
    }
    .t-name-btn {
      font-size: 21px;  /* 22px × 0.955 */
    }
    .t-video-modal__container {
      width: min(85vw, 1100px);  /* scales down from 1200px */
    }
    /* Stage becomes tight at short viewport heights — switch play button
       to normal flow so it can never overlap the credit text above it. */
    .t-play-btn {
      position: relative;  /* keeps ::before contained to button; relative = same flow as static */
      bottom: auto;
      left: auto;
      margin-top: 24px;
      display: inline-flex;
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    /* padding-top removed — centering handled by justify-content: center */
    .testimonials__quote-stage {
      height: clamp(332px, 40.5vh, 462px);  /* clamp(369,45vh,513) × 0.90 */
    }
    .t-quote blockquote {
      font-size: 22px;    /* 24px − 2px (user request) */
      line-height: 36px;  /* 39px scaled proportionally */
    }
    .t-name-btn {
      font-size: 20px;  /* 21px × 0.952 */
    }
    .t-video-modal__container {
      width: min(85vw, 990px);  /* scales down from 1100px */
    }
    /* Play button: at 1024px the stage is tight so bottom:0 overlaps the
       credit text. Return to normal flow so it sits naturally below the
       t-role-credit paragraph without overlap. */
    .t-play-btn {
      position: relative;  /* keeps ::before contained to button; relative = same flow as static */
      bottom: auto;
      left: auto;
      margin-top: 24px;
      display: inline-flex;
    }
  }

</style>

<script>
  // ─── State ───────────────────────────────────────────────────────────────────
  const btns   = document.querySelectorAll<HTMLButtonElement>('.t-name-btn');
  const photos = document.querySelectorAll<HTMLElement>('.t-photo');
  const quotes = document.querySelectorAll<HTMLElement>('.t-quote');
  const track  = document.getElementById('testimonials') as HTMLElement;


  let current  = 0;
  let switching = false;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;

  // ─── Activate a testimonial ───────────────────────────────────────────────
  function activate(i: number) {
    if (i === current || switching) return;
    switching = true;

    btns.forEach((b, idx) => b.classList.toggle('is-active', idx === i));

    photos[current].classList.remove('is-active');
    quotes[current].classList.remove('is-active');

    current = i;

    setTimeout(() => {
      photos[i].classList.add('is-active');
      quotes[i].classList.add('is-active');
      switching = false;
    }, 120);
  }

  // ─── Scroll-progress driver ───────────────────────────────────────────────
  function onScroll() {
    if (!track) return;

    const rect           = track.getBoundingClientRect();
    const trackH         = track.offsetHeight;          // 300vh
    const vh             = window.innerHeight;
    const totalTravel    = trackH - vh;                 // 200vh — usable scroll range
    const scrolled       = -rect.top;                  // px scrolled into the track

    // Only drive when inside the sticky zone
    if (scrolled < 0 || scrolled > totalTravel) return;

    const progress = scrolled / totalTravel;           // 0 → 1
    const n        = btns.length;
    const idx      = Math.min(n - 1, Math.floor(progress * n));

    activate(idx);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on load

  // ─── Manual click / hover (still works when reading the pinned panel) ─────
  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
      activate(i);
    });
    btn.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 200);
    });
    btn.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });
  });

  // ─── Per-line text reveal for blockquotes ────────────────────────────────
  const tReduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tMobile   = window.matchMedia('(max-width: 767px)').matches;

  if (!tReduced && !tMobile) {

    // Inject lr-clip CSS if BaseLayout hasn't already (e.g., desktop + no reduced motion)
    if (!document.querySelector('.lr-clip')) {
      const lcss = document.createElement('style');
      lcss.textContent = `
        .lr-clip{overflow:hidden;display:block}
        .lr-inner{display:block;transform:translateY(110%);will-change:transform}
        .lr-clip.lr-visible .lr-inner{transform:translateY(0)}
      `;
      document.head.appendChild(lcss);
    }

    // Split a blockquote into lr-clip line wrappers
    function splitBq(bq: HTMLElement) {
      const children = Array.from(bq.childNodes);
      type Atom = { html: string; isBr: boolean };
      const atoms: Atom[] = [];

      children.forEach(node => {
        if (node.nodeName === 'BR') {
          atoms.push({ html: '', isBr: true });
        } else if (node.nodeType === Node.TEXT_NODE) {
          (node.textContent || '').split(/\s+/).filter(w => w.length > 0)
            .forEach(w => atoms.push({ html: w, isBr: false }));
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          atoms.push({ html: (node as Element).outerHTML, isBr: false });
        }
      });

      if (atoms.filter(a => !a.isBr).length === 0) return;

      // Render measurement spans
      bq.innerHTML = '';
      const wrapEls: HTMLElement[] = [];
      atoms.forEach((atom, i) => {
        if (atom.isBr) {
          const s = document.createElement('span');
          s.className = 'lw-br';
          s.style.cssText = 'display:block;height:0;font-size:0;line-height:0';
          bq.appendChild(s); wrapEls.push(s);
        } else {
          const s = document.createElement('span');
          s.className = 'lw'; s.style.display = 'inline-block';
          s.innerHTML = atom.html;
          bq.appendChild(s); wrapEls.push(s);
          const next = atoms[i + 1];
          if (next && !next.isBr) bq.appendChild(document.createTextNode(' '));
        }
      });

      // Group by offsetTop
      const lineGroups: string[][] = [];
      let currentTop = -9999; let group: string[] = [];
      wrapEls.forEach(w => {
        if (w.classList.contains('lw-br')) {
          if (group.length) { lineGroups.push(group); group = []; }
          currentTop = -9999; return;
        }
        const top = w.offsetTop;
        if (Math.abs(top - currentTop) > 3) {
          if (group.length) lineGroups.push(group);
          group = []; currentTop = top;
        }
        group.push(w.innerHTML);
      });
      if (group.length) lineGroups.push(group);
      if (lineGroups.length === 0) return;

      // Rebuild: one lr-clip/lr-inner per line
      bq.innerHTML = '';
      lineGroups.forEach((words, i) => {
        const clip  = document.createElement('div');
        clip.className = 'lr-clip';
        const inner = document.createElement('div');
        inner.className = 'lr-inner';
        inner.style.transition =
          `transform 0.85s cubic-bezier(0.42,0,0.24,1) ${(i * 0.09).toFixed(2)}s`;
        inner.innerHTML = words.join(' ');
        clip.appendChild(inner);
        bq.appendChild(clip);
      });
    }

    // Reveal all lr-clip lines inside a t-quote element
    function revealQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.add('lr-visible'));
    }

    // Reset (hide) all lr-clip lines inside a t-quote element
    function resetQuote(quoteEl: HTMLElement) {
      quoteEl.querySelectorAll<HTMLElement>('blockquote > .lr-clip')
        .forEach(clip => clip.classList.remove('lr-visible'));
    }

    // Split all blockquotes once fonts are ready
    (document.fonts?.ready ?? Promise.resolve()).then(() => {
      // Keep references and store originals BEFORE splitting so we can re-split on resize
      const bqs = Array.from(document.querySelectorAll<HTMLElement>('.t-quote blockquote'));
      bqs.forEach(bq => {
        bq.dataset.origHtml = bq.innerHTML;  // snapshot pre-split HTML
        splitBq(bq);
      });

      // Reveal initial active quote when the section first enters view
      const initialQuote = document.querySelector<HTMLElement>('.t-quote.is-active');
      if (initialQuote) {
        const trackEl = document.getElementById('testimonials');
        const sectionObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              revealQuote(initialQuote);
              sectionObserver.disconnect();
            }
          });
        }, { threshold: 0.1 });
        if (trackEl) sectionObserver.observe(trackEl);
      }

      // Watch for is-active changes on t-quote elements to trigger reveal/reset
      const quoteEls = document.querySelectorAll<HTMLElement>('.t-quote');
      const mutation = new MutationObserver(muts => {
        muts.forEach(m => {
          const el = m.target as HTMLElement;
          if (!el.classList.contains('t-quote')) return;
          if (el.classList.contains('is-active')) {
            setTimeout(() => revealQuote(el), 80);
          } else {
            resetQuote(el);
          }
        });
      });
      quoteEls.forEach(q => mutation.observe(q, { attributes: true, attributeFilter: ['class'] }));

      // ── Resize handler: re-split so lines reflow at new viewport width ────────
      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          // Restore each blockquote to its pre-split state then re-measure
          bqs.forEach(bq => {
            if (bq.dataset.origHtml !== undefined) bq.innerHTML = bq.dataset.origHtml;
            splitBq(bq);
          });

          // Re-reveal the currently active quote instantly (suppress transition flash)
          const active = document.querySelector<HTMLElement>('.t-quote.is-active');
          if (active) {
            active.querySelectorAll<HTMLElement>('blockquote > .lr-clip').forEach(clip => {
              clip.style.transition = 'none';
              clip.classList.add('lr-visible');
              // Re-enable transitions on the next paint so future tab-switches animate
              requestAnimationFrame(() => {
                requestAnimationFrame(() => { clip.style.transition = ''; });
              });
            });
          }
        }, 200); // 200ms debounce — fast enough to feel snappy, slow enough not to thrash
      });
    });
  }

  // ── Campaign video modal (Niamh Bryne testimonial #0) ───────────────────────────────────
  const playBtn    = document.getElementById('t-play-btn')           as HTMLButtonElement | null;
  const videoModal = document.getElementById('t-video-modal')         as HTMLElement      | null;
  const modalBack  = document.getElementById('t-video-modal-backdrop') as HTMLElement     | null;
  const modalClose = document.getElementById('t-video-modal-close')   as HTMLButtonElement | null;
  const campVideo  = document.getElementById('t-campaign-video')      as HTMLVideoElement | null;

  function openModal() {
    if (!videoModal || !campVideo) return;
    videoModal.classList.add('is-open');
    videoModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    campVideo.play();
  }

  function closeModal() {
    if (!videoModal || !campVideo) return;
    videoModal.classList.remove('is-open');
    videoModal.setAttribute('aria-hidden', 'true');
    campVideo.pause();
    campVideo.currentTime = 0;  /* reset to start for next open */
    document.body.style.overflow = '';
  }

  playBtn?.addEventListener('click', openModal);
  modalBack?.addEventListener('click', closeModal);
  modalClose?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && videoModal?.classList.contains('is-open')) closeModal();
  });
</script>
