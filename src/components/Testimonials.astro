---
const base = import.meta.env.BASE_URL + '/';

const testimonials = [
  {
    name: 'Clara Whitlock',
    title: 'Global Brand Lead, Elara Group',
    quoteBefore: '\u201cBeyond the Badge took our unshaped ambition and turned it into cultural ',
    quoteHighlight: 'resonance',
    quoteAfter: ' \u2014 they didn\u2019t just understand our brand, they understood the cultural spaces we wanted to reach with a level of trust we never thought we\u2019d command.\u201d',
    image: `${base}about-1.jpg`,
  },
  {
    name: 'Arthur Bennett',
    title: 'Creative Director, Studio North',
    quoteBefore: '\u201cGreat partnerships aren\u2019t built overnight \u2014 they\u2019re built on trust, shared values, and a team that knows exactly how to ',
    quoteHighlight: 'connect',
    quoteAfter: ' the right people with the right moments in culture.\u201d',
    image: `${base}about-2.jpg`,
  },
  {
    name: 'Julian Thorne',
    title: 'Head of Brand, Meridian',
    quoteBefore: '\u201cWhat sets Beyond the Badge apart is how deeply they understand ',
    quoteHighlight: 'culture',
    quoteAfter: '. They don\u2019t chase it \u2014 they\u2019re already there, and they bring you with them.\u201d',
    image: `${base}about-3.jpg`,
  },
];
---

<!-- Outer scroll track: 300vh gives 200vh of sticky scroll distance (3 × ~67vh per testimonial) -->
<div class="testimonials-track" id="testimonials">
  <!-- Sticky panel: pins to viewport while track scrolls past -->
  <section class="testimonials-sticky" aria-label="Words from our clients">
    <div class="container">

      <div class="testimonials__header">
        <h2 class="testimonials__heading">Words from our clients</h2>
      </div>

      <hr class="testimonials__rule" />

      <div class="testimonials__body">

        <!-- Left: name list -->
        <div class="testimonials__names">
          {testimonials.map((t, i) => (
            <button
              class={`t-name-btn${i === 0 ? ' is-active' : ''}`}
              data-index={String(i)}
            >
              <span class="t-arrow" aria-hidden="true">&rarr;</span>
              <span class="t-name-text">{t.name}</span>
            </button>
          ))}
        </div>

        <!-- Centre: portrait (position:absolute crossfade) -->
        <div class="testimonials__photo-stage">
          {testimonials.map((t, i) => (
            <div class={`t-photo${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <img src={t.image} alt={t.name} />
            </div>
          ))}
        </div>

        <!-- Right: quote (position:absolute crossfade) -->
        <div class="testimonials__quote-stage">
          {testimonials.map((t, i) => (
            <div class={`t-quote${i === 0 ? ' is-active' : ''}`} data-index={String(i)}>
              <blockquote>
                {t.quoteBefore}<em class="t-highlight">{t.quoteHighlight}</em>{t.quoteAfter}
              </blockquote>
              <footer class="t-attribution">
                <strong class="t-client-name">{t.name}</strong>
                <span class="t-client-role">{t.title}</span>
              </footer>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
</div>

<style>
  /* ─── Scroll track (outer, 300vh) ─── */
  .testimonials-track {
    height: 300vh;
    background-color: #ffffff;
    /* Needed so sticky child has correct offset parent */
    position: relative;
  }

  /* ─── Sticky panel (pins while track scrolls) ─── */
  .testimonials-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .testimonials-sticky .container {
    width: 100%;
  }

  .testimonials__heading {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 500;
    color: var(--color-text-dark);
    margin: 0 0 28px;
  }

  .testimonials__rule {
    border: none;
    border-top: 1px solid rgba(26, 58, 42, 0.18);
    margin: 0 0 52px;
  }

  /* ─── Three-column grid ─── */
  .testimonials__body {
    display: grid;
    grid-template-columns: minmax(140px, 20%) minmax(180px, 26%) 1fr;
    gap: 0 clamp(32px, 5vw, 72px);
    align-items: start;
  }

  /* ─── Left: name list ─── */
  .testimonials__names {
    display: flex;
    flex-direction: column;
  }

  .t-name-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 16px 0;
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #9a9a8a;
    text-align: left;
    cursor: pointer;
    background: none;
    transition: color 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                font-weight 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active,
  .t-name-btn:hover {
    font-weight: 700;
    color: #004f26;
  }

  /* Arrow — absolute at left:0, fades in after slide begins */
  .t-arrow {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: #004f26;
    opacity: 0;
    transition: opacity 0.4s ease 0.1s;
    pointer-events: none;
  }

  .t-name-btn.is-active .t-arrow,
  .t-name-btn:hover .t-arrow {
    opacity: 1;
  }

  /* Name text — slides right */
  .t-name-text {
    display: inline-block;
    transform: translateX(0);
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .t-name-btn.is-active .t-name-text,
  .t-name-btn:hover .t-name-text {
    transform: translateX(28px);
  }

  /* ─── Centre: photo stage ─── */
  .testimonials__photo-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
  }

  .t-photo {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .t-photo.is-active {
    opacity: 1;
  }

  .t-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(1);
    display: block;
  }

  /* ─── Right: quote stage ─── */
  .testimonials__quote-stage {
    position: relative;
    min-height: 280px;
  }

  .t-quote {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .t-quote.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .t-quote blockquote {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 400;
    line-height: 57px;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    font-style: normal;
    margin: 0 0 28px;
  }

  .t-highlight {
    font-style: italic;
    font-weight: 500;
    color: #004f26;
  }

  .t-attribution {
    display: none;
  }

  .t-client-name {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .t-client-role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ─── Mobile: unpin, stack all three ─── */
  @media (max-width: 768px) {
    .testimonials-track {
      height: auto;
    }

    .testimonials-sticky {
      position: static;
      height: auto;
      padding: var(--section-padding-y) 0;
    }

    .testimonials__body {
      grid-template-columns: 1fr;
      gap: 36px 0;
    }

    /* Show all photos and quotes stacked on mobile */
    .t-photo {
      position: static;
      opacity: 1 !important;
    }

    .t-quote {
      position: static;
      opacity: 1 !important;
      pointer-events: auto;
    }

    .testimonials__photo-stage {
      aspect-ratio: 4 / 3;
    }

    .testimonials__quote-stage {
      min-height: 0;
    }

    .testimonials__names {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .t-name-btn {
      padding: 10px 20px 10px 0;
    }
  }
</style>

<script>
  // ─── State ───────────────────────────────────────────────────────────────────
  const btns   = document.querySelectorAll<HTMLButtonElement>('.t-name-btn');
  const photos = document.querySelectorAll<HTMLElement>('.t-photo');
  const quotes = document.querySelectorAll<HTMLElement>('.t-quote');
  const track  = document.getElementById('testimonials') as HTMLElement;

  const TOTAL = testimonials_count(); // resolved at runtime from DOM
  let current  = 0;
  let switching = false;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;

  function testimonials_count() {
    return document.querySelectorAll('.t-name-btn').length;
  }

  // ─── Activate a testimonial ───────────────────────────────────────────────
  function activate(i: number) {
    if (i === current || switching) return;
    switching = true;

    btns.forEach((b, idx) => b.classList.toggle('is-active', idx === i));

    photos[current].classList.remove('is-active');
    quotes[current].classList.remove('is-active');

    current = i;

    setTimeout(() => {
      photos[i].classList.add('is-active');
      quotes[i].classList.add('is-active');
      switching = false;
    }, 120);
  }

  // ─── Scroll-progress driver ───────────────────────────────────────────────
  function onScroll() {
    if (!track) return;

    const rect           = track.getBoundingClientRect();
    const trackH         = track.offsetHeight;          // 300vh
    const vh             = window.innerHeight;
    const totalTravel    = trackH - vh;                 // 200vh — usable scroll range
    const scrolled       = -rect.top;                  // px scrolled into the track

    // Only drive when inside the sticky zone
    if (scrolled < 0 || scrolled > totalTravel) return;

    const progress = scrolled / totalTravel;           // 0 → 1
    const n        = btns.length;
    const idx      = Math.min(n - 1, Math.floor(progress * n));

    activate(idx);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on load

  // ─── Manual click / hover (still works when reading the pinned panel) ─────
  btns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
      activate(i);
    });
    btn.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 200);
    });
    btn.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });
  });
</script>
