---
---

<section class="hero" id="hero">

  <!-- Editorial brand statement -->
  <div class="hero__text container">
    <p class="hero__statement">
      At <em>Beyond the Badge</em>, we believe cultural<br>relevance isn't earned through logos.
    </p>
  </div>

  <!-- Video: starts within content margins, expands to full-bleed on scroll -->
  <div class="hero__image-wrapper" id="heroImageWrapper">
    <video
      class="hero__image"
      autoplay
      muted
      loop
      playsinline
      disablepictureinpicture
      preload="auto"
      poster={`${import.meta.env.BASE_URL}hero-bg.jpg`}
    >
      <source src={`${import.meta.env.BASE_URL}hero-video.webm`} type="video/webm" />
      <source src={`${import.meta.env.BASE_URL}hero-video.mp4`}  type="video/mp4"  />
    </video>
  </div>
  <!-- B logo watermark — behind everything -->
  <img
    src={`${import.meta.env.BASE_URL}b-logo-watermark.png`}
    alt=""
    aria-hidden="true"
    class="hero__watermark"
  />

</section>

<style>
  .hero {
    background: var(--color-cream, #f5f0eb);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    /* Offset by nav height so content starts below the fixed header */
    padding-top: 72px;
  }

  /* Ensure text + video sit above the watermark */
  .hero__text,
  .hero__image-wrapper {
    position: relative;
    z-index: 1;
  }

  /* B logo watermark */
  .hero__watermark {
    position: absolute;
    top: 70px;
    /* Right edge aligns with the content margin (same calc as image-wrapper padding) */
    right: calc(var(--section-padding-x, 40px) + max(0px, (100vw - var(--content-max-width, 1648px)) / 2));
    width:  885.99px;
    height: 892.5px;
    opacity: 0.03;
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }

  /* ── Brand statement ── */
  .hero__text {
    flex-shrink: 0;
    padding-top: 188px;
    padding-bottom: 188px;
  }

  .hero__statement {
    margin: 0;
    font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
    font-size: clamp(20px, 2.5vw + 12px, 36px);
    font-weight: 400;
    font-style: normal;
    line-height: 1.35;
    color: var(--color-text-dark, #052715);
    max-width: 66ch;
  }

  .hero__statement em {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "wght" 500, "hght" 1000;
  }

  /* ── Image wrapper ── */
  /*
   * Initial padding = section-padding-x (inner) PLUS the auto-margin that
   * centres the container on wide viewports — so the image left/right edges
   * line up exactly with the nav logo / nav text.
   *
   * calc(40px + max(0px, (100vw - 1648px) / 2))
   * e.g. at 1728px viewport: 40 + max(0, 40) = 80px each side ✓
   * e.g. at 1440px viewport: 40 + max(0, -104) = 40px each side ✓
   */
  .hero__image-wrapper {
    flex: 1;
    min-height: 320px;
    padding-left:  calc(var(--section-padding-x, 40px) + max(0px, (100vw - var(--content-max-width, 1648px)) / 2));
    padding-right: calc(var(--section-padding-x, 40px) + max(0px, (100vw - var(--content-max-width, 1648px)) / 2));
    overflow: hidden;
    will-change: padding;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center bottom;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 60px;
      padding-bottom: var(--section-padding-y);
      /* Transparent at mobile so the GSAP body background transition shows
         through the hero's bottom padding — eliminates the hard colour seam
         at the hero/about boundary. Body always starts as cream on load. */
      background: transparent;
    }
    .hero__text {
      /* Match Gap 1 & Gap 2: both are 2 × --section-padding-y (~153px at 768px) */
      padding-top: calc(2 * var(--section-padding-y));
      padding-bottom: calc(2 * var(--section-padding-y));
    }
    .hero__image-wrapper {
      min-height: 240px;
    }
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .hero__statement {
      font-size: clamp(20px, 2.5vw + 11px, 34px);  /* max 36 → 34px */
    }
    .hero__watermark {
      width:  797px;   /* 885.99px × 0.90 */
      height: 803px;   /* 892.5px  × 0.90 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .hero__statement {
      font-size: clamp(19px, 2.4vw + 10px, 32px);  /* max 34 → 32px (−5.9%) */
    }
    .hero__watermark {
      width:  717px;  /* 797px × 0.90 */
      height: 723px;  /* 803px × 0.90 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .hero__statement {
      font-size: clamp(17px, 2.2vw + 8px, 30px);  /* max 32 → 30px (−6.25%) */
    }
    .hero__watermark {
      width:  645px;  /* 717px × 0.90 */
      height: 651px;  /* 723px × 0.90 */
    }
  }

  /* ── 768px: must come AFTER the 1024px block so it wins the cascade ── */
  @media (max-width: 768px) {
    .hero__statement {
      font-size: 30px; /* matches .about__intro — overrides 1024px clamp() */
    }
  }
</style>

<script>
  (() => {
    // ── Image padding scroll expansion ──────────────────────────────────
    const wrapper = document.getElementById('heroImageWrapper') as HTMLElement | null;
    if (!wrapper) return;

    let maxPadding = parseFloat(getComputedStyle(wrapper).paddingLeft) || 80;
    const EXPAND_OVER_PX = 220;

    function update() {
      const progress = Math.min(1, window.scrollY / EXPAND_OVER_PX);
      const padding = maxPadding * (1 - progress);
      wrapper!.style.paddingLeft  = padding + 'px';
      wrapper!.style.paddingRight = padding + 'px';
    }

    window.addEventListener('resize', () => {
      wrapper!.style.paddingLeft  = '';
      wrapper!.style.paddingRight = '';
      maxPadding = parseFloat(getComputedStyle(wrapper!).paddingLeft) || 80;
      update();
    });

    window.addEventListener('scroll', update, { passive: true });
    update();

    // ── prefers-reduced-motion + autoplay-blocked handling ──────────────
    // Some browsers (Safari, Firefox) block autoplay when the OS
    // "Reduce Motion" accessibility setting is on, leaving the video
    // element completely blank. We pause immediately in that case so the
    // poster frame (hero-bg.jpg) stays visible as a static image.
    const vid = wrapper.querySelector('video') as HTMLVideoElement | null;
    if (vid) {
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

      const applyMotionPref = () => {
        if (motionQuery.matches) {
          vid.pause();
        } else {
          vid.play().catch(() => { /* autoplay blocked — poster image stays visible */ });
        }
      };

      // Apply once metadata is available (earliest safe point to call pause/play)
      vid.addEventListener('loadedmetadata', applyMotionPref, { once: true });
      // Re-apply if the user changes the OS setting while the page is open
      motionQuery.addEventListener('change', applyMotionPref);
    }
  })();
</script>
