---
---

<section class="hero" id="hero">
  <div
    class="hero__bg"
    aria-hidden="true"
    style={`background-image: url('${import.meta.env.BASE_URL}hero-bg.jpg')`}
  ></div>

  <div class="hero__inner container">
    <div class="hero__content">
      <div class="hero__xfade" aria-live="polite">

        <!-- Wordmark — visible on load, fades OUT -->
        <h1 class="hero-wordmark">
          <img
            src={`${import.meta.env.BASE_URL}logo-full.png`}
            alt="Beyond the Badge"
            class="hero__logo-img"
          />
        </h1>

        <!-- Tagline — hidden on load, fades IN -->
        <p class="hero-tagline" aria-label="Less logo. More legacy.">
          <span class="tagline-plain">Less logo.</span>
          <span class="tagline-italic"> More legacy.</span>
        </p>

      </div>
    </div>


  </div>
</section>

<style>
  /* ── Hero shell ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    height: 100vh;
  }

  .hero__content {
    text-align: left;
  }

  /* ── Crossfade wrapper: stacks wordmark + tagline in the same spot ── */
  .hero__xfade {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
  }

  /* ── Wordmark: visible by default ── */
  .hero-wordmark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin: 0;
    opacity: 1;
    transition: opacity 1.2s ease-in-out;
  }

  .hero__logo-img {
    width: 100%;
    max-width: 195px;
    height: auto;
    display: block;
  }

  /* ── Tagline: hidden by default ── */
  .hero-tagline {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin: 0;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
  }

  .tagline-plain {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-style: normal;
    font-weight: 700;
    font-size: 28px;
    letter-spacing: 0.05em;
    color: #ffffff;
  }

  .tagline-italic {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "HGHT" 1000;
    font-size: 28px;
    letter-spacing: 0.05em;
    color: #8CB7A0;
  }


  /* ── Footer ── */
  .hero__footer {
    position: absolute;
    bottom: 32px;
    width: 100%;
    padding: 0 var(--section-padding-x);
    display: flex;
    justify-content: space-between;
  }

  .hero__contact-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--color-text-cream);
    letter-spacing: 0.02em;
    transition: color var(--transition-base);
  }

  .hero__contact-link:hover {
    opacity: 1;
    color: var(--color-cream);
  }

  @media (max-width: 768px) {
    .hero__footer {
      flex-direction: column;
      align-items: center;
      gap: 8px;
      bottom: 24px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wordmark = document.querySelector<HTMLElement>('.hero-wordmark');
    const tagline  = document.querySelector<HTMLElement>('.hero-tagline');

    if (!wordmark || !tagline) return;

    // t=2s: wordmark fades out
    setTimeout(() => {
      wordmark.style.opacity = '0';
    }, 2000);

    // t=2.8s: tagline fades in (0.4s overlap)
    setTimeout(() => {
      tagline.style.opacity   = '1';
      tagline.style.transform = 'translateY(0)';
    }, 2800);
  });
</script>
