---
---

<section class="hero" id="hero">
  <div
    class="hero__bg"
    aria-hidden="true"
    style={`background-image: url('${import.meta.env.BASE_URL}hero-bg.jpg')`}
  ></div>

  <div class="hero__inner container">
    <div class="hero__content">

      <h1 class="hero__wordmark">
        <img
          src={`${import.meta.env.BASE_URL}logo-full.png`}
          alt="Beyond the Badge"
          class="hero__logo-img"
        />
      </h1>

      <p class="hero__tagline">
        <span class="tagline-plain">Less logo.</span>
        <span class="tagline-italic"> More legacy.</span>
      </p>

    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Wordmark ── */
  .hero__wordmark {
    margin: 0;
    animation: heroEntry 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__logo-img {
    width: 100%;
    max-width: 195px;
    height: auto;
    display: block;
  }

  /* ── Tagline ── */
  .hero__tagline {
    margin: 0;
    animation: heroEntry 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both;
    white-space: nowrap;
  }

  .tagline-plain {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-style: normal;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    letter-spacing: 0.05em;
    color: #ffffff;
  }

  .tagline-italic {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "HGHT" 1000;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    letter-spacing: 0.05em;
    color: #8CB7A0;
  }

  /* ── Luxury entry keyframe ── */
  @keyframes heroEntry {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero__tagline {
      white-space: normal;
    }
  }
</style>
