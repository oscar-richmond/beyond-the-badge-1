---
---

<section class="hero" id="hero">
  <div
    class="hero__bg"
    aria-hidden="true"
    style={`background-image: url('${import.meta.env.BASE_URL}hero-bg.jpg')`}
  ></div>

  <div class="hero__inner container">
    <p class="hero__tagline">
      <span class="tagline-plain">Less logo.</span>
      <!-- Rotating wrapper: fixed height, phrases stack absolutely -->
      <span class="tagline-rotating-wrapper" aria-live="polite">
        <span class="rotating-phrase">More legacy.</span>
        <span class="rotating-phrase">More Partnerships.</span>
        <span class="rotating-phrase">More Sponsorship.</span>
      </span>
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  /* ── Tagline row ── */
  .hero__tagline {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0;
    animation: heroEntry 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
    white-space: nowrap;
  }

  .tagline-plain {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-style: normal;
    font-weight: 700;
    font-size: 32px;
    letter-spacing: 0.05em;
    color: #ffffff;
  }

  /* Fixed-height inline-block so layout never shifts */
  .tagline-rotating-wrapper {
    position: relative;
    display: inline-block;
    /* height and min-width set via JS once first phrase is measured */
    height: 1.25em;       /* matches 32px × 1.25 = 40px */
    min-width: 1px;
    overflow: visible;
    vertical-align: baseline;
  }

  /* All rotating phrases stacked absolutely */
  .rotating-phrase {
    position: absolute;
    left: 7px;
    top: calc(50% - 2px);
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "HGHT" 1000;
    font-size: 32px;
    letter-spacing: 0.05em;
    color: #8CB7A0;
    white-space: nowrap;
    /* default hidden state — entering from below, centred on wrapper midline */
    opacity: 0;
    transform: translateY(calc(-50% + 10px));
  }

  @keyframes heroEntry {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero__tagline { white-space: normal; flex-wrap: wrap; }
  }
</style>

<script>
  const phrases = Array.from(
    document.querySelectorAll<HTMLElement>('.rotating-phrase')
  );
  const wrapper = document.querySelector<HTMLElement>('.tagline-rotating-wrapper');

  if (phrases.length && wrapper) {
    // Size the wrapper to the widest phrase so layout stays stable
    const maxWidth = Math.max(...phrases.map(p => p.offsetWidth));
    wrapper.style.width = `${maxWidth}px`;

    let current = 0;

    function show(el: HTMLElement) {
      el.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
      el.style.opacity = '1';
      el.style.transform = 'translateY(-50%)';
    }

    function exit(el: HTMLElement) {
      el.style.transition = 'opacity 0.5s ease-in, transform 0.5s ease-in';
      el.style.opacity = '0';
      el.style.transform = 'translateY(calc(-50% - 10px))';
    }

    function reset(el: HTMLElement) {
      // Snap back to enter-from-below state without animating
      el.style.transition = 'none';
      el.style.opacity = '0';
      el.style.transform = 'translateY(calc(-50% + 10px))';
    }

    // Show first phrase immediately
    show(phrases[0]);

    function cycle() {
      const outEl = phrases[current];
      const nextIdx = (current + 1) % phrases.length;
      const inEl = phrases[nextIdx];

      // Exit current
      exit(outEl);

      // Enter next after 0.1s overlap (brief near-empty moment)
      setTimeout(() => show(inEl), 100);

      // After exit finishes, reset the old phrase to below-entry position
      setTimeout(() => reset(outEl), 600);

      current = nextIdx;
    }

    // Hold 2.5s, then cycle every 3.3s (2.5s hold + 0.8s transition)
    setTimeout(() => {
      cycle();
      setInterval(cycle, 3300);
    }, 2500);
  }
</script>
