---
const navItems = [
  { href: `${import.meta.env.BASE_URL}about`, label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#testimonials', label: 'Testimonials' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="header at-top">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Beyond the Badge - Home">
      <img src={`${import.meta.env.BASE_URL}/logo-monogram.png`} alt="Beyond the Badge" class="header__logo-img" />
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="header__nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="header__menu-btn" aria-label="Toggle menu" aria-expanded="false">
      <span class="header__menu-line"></span>
      <span class="header__menu-line"></span>
    </button>
  </div>
</header>

<!-- Mobile nav overlay -->
<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <nav aria-label="Mobile navigation">
    <ul class="mobile-nav__list">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav__link">{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 18px 0;
    background-color: rgba(245, 240, 235, 0.95); /* cream — matches site background */
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(0, 79, 38, 0.08);
    transform: translateY(0);
    transition: transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }

  /* State 1 — at top of page */
  .header.at-top {
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }

  /* Slide out on scroll down */
  .header.nav-hidden {
    transform: translateY(-100%);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--section-padding-x);
  }

  .header__logo {
    display: flex;
    align-items: center;
    transition: transform var(--transition-base);
  }

  .header__logo:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .header__logo-img {
    height: 36px;
    width: auto;
    /* At-top: make logo appear white on dark hero */
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease;
  }

  /* Scrolled state — convert white logo to brand green #004f26 */
  .header:not(.at-top) .header__logo-img {
    filter: brightness(0.15) sepia(1) hue-rotate(110deg) saturate(6) brightness(1.1);
  }

  .header__nav-list {
    display: flex;
    gap: 36px;
  }

  /* State 2 (scrolled) — green links */
  .header__nav-link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: #004f26;
    letter-spacing: 0.02em;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .header__nav-link:hover {
    opacity: 1;
    color: #004f26;
  }

  /* State 1 — white links when at top */
  .header.at-top .header__nav-link {
    color: rgba(255, 255, 255, 0.9);
  }

  .header__menu-btn {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    z-index: 101;
  }

  /* State 2 (scrolled) — green hamburger */
  .header__menu-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: #004f26;
    transition: transform var(--transition-base), opacity var(--transition-base), background-color 0.3s ease;
  }

  /* State 1 — white hamburger when at top */
  .header.at-top .header__menu-line {
    background-color: rgba(255, 255, 255, 0.9);
  }

  /* Mobile nav overlay */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: var(--color-forest-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-slow);
  }

  .mobile-nav.active {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav__list {
    display: flex;
    flex-direction: column;
    gap: 32px;
    text-align: center;
  }

  .mobile-nav__link {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--color-text-light);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }

    .header__menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const menuBtn = document.querySelector('.header__menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileLinks = document.querySelectorAll('.mobile-nav__link');

  // Hide on scroll down, reveal on scroll up — plus at-top state
  let lastScrollY = window.scrollY;

  const updateNav = () => {
    const currentScrollY = window.scrollY;

    // Slide behaviour
    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      header?.classList.add('nav-hidden');
    } else {
      header?.classList.remove('nav-hidden');
    }

    // At-top transparent state
    if (currentScrollY < 10) {
      header?.classList.add('at-top');
    } else {
      header?.classList.remove('at-top');
    }

    lastScrollY = currentScrollY;
  };

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav(); // Set correct state on load

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('active');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));

    const lines = menuBtn.querySelectorAll('.header__menu-line');
    if (isOpen) {
      lines[0].style.transform = 'rotate(45deg) translate(3px, 3px)';
      lines[1].style.transform = 'rotate(-45deg) translate(3px, -3px)';
    } else {
      lines[0].style.transform = '';
      lines[1].style.transform = '';
    }
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav?.classList.remove('active');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
      const lines = menuBtn?.querySelectorAll('.header__menu-line');
      lines?.forEach((l) => ((l as HTMLElement).style.transform = ''));
    });
  });
</script>
