---
const base = import.meta.env.BASE_URL;
const navItems = [
  { href: import.meta.env.BASE_URL, label: 'Home',    comma: true  },
  { href: `${base}about`,           label: 'About',   comma: true  },
  { href: `${base}contact`,         label: 'Contact', comma: false },
];
---

<header class="header at-top">
  <div class="header__inner">
    <a href={import.meta.env.BASE_URL} class="header__logo" aria-label="Beyond the Badge - Home">
      <img src={`${import.meta.env.BASE_URL}logo-monogram.png`} alt="Beyond the Badge" class="header__logo-img" />
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="header__nav-link">
              {item.label}{item.comma && <span class="nav-comma" aria-hidden="true">,</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="header__menu-btn" aria-label="Toggle menu" aria-expanded="false">
      <span class="header__menu-line"></span>
      <span class="header__menu-line"></span>
    </button>
  </div>
</header>

<!-- Mobile nav overlay -->
<div class="mobile-nav" id="mobile-nav" aria-hidden="true">

  <!-- Background B watermark -->
  <img
    src={`${base}logo-monogram.png`}
    alt=""
    aria-hidden="true"
    class="mobile-nav__watermark"
  />

  <!-- Primary nav links -->
  <nav aria-label="Mobile navigation" class="mobile-nav__nav">
    <ul class="mobile-nav__list">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav__link">{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Contact details -->
  <div class="mobile-nav__contact">
    <a href="tel:+441768881430" class="mobile-nav__contact-link">01768 881430</a>
    <a href="mailto:hello@beyondthebadge.agency" class="mobile-nav__contact-link">Hello@beyondthebadge.agency</a>
    <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="mobile-nav__contact-link">Follow us on Instagram</a>
  </div>

  <!-- Legal links -->
  <div class="mobile-nav__legal">
    <a href={`${base}privacy`} class="mobile-nav__legal-link">Privacy Policy</a>
    <a href={`${base}terms`}   class="mobile-nav__legal-link">Terms &amp; Conditions</a>
  </div>

</div>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 18px 0;
    background-color: rgba(245, 240, 235, 0.95); /* cream — matches site background */
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(0, 79, 38, 0.08);
    transform: translateY(0);
    transition: transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }

  /* State 1 — at top of page */
  .header.at-top {
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }

  /* Slide out on scroll down */
  .header.nav-hidden {
    transform: translateY(-100%);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--section-padding-x);
  }

  .header__logo {
    display: flex;
    align-items: center;
    transition: transform var(--transition-base);
  }

  .header__logo:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .header__logo-img {
    height: 36px;
    width: auto;
    /* At-top: make logo appear white on dark hero */
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease;
  }

  /* Scrolled state — convert white logo to brand green #004f26 */
  .header:not(.at-top) .header__logo-img {
    filter: brightness(0.15) sepia(1) hue-rotate(110deg) saturate(6) brightness(1.1);
  }

  .header__nav-list {
    display: flex;
    gap: 8px;
  }

  /* State 2 (scrolled) — green links */
  .header__nav-link {
    font-family: var(--font-script);
    font-style: italic;
    font-size: 20px;
    font-weight: 600;
    font-variation-settings: "wght" 600;
    color: #004f26;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .header__nav-link:hover {
    opacity: 1;
    color: #004f26;
  }

  /* State 1 — white links when at top */
  .header.at-top .header__nav-link {
    color: rgba(255, 255, 255, 0.9);
  }

  .header__menu-btn {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    z-index: 101;
  }

  /* State 2 (scrolled) — green hamburger */
  .header__menu-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: #004f26;
    transition: transform var(--transition-base), opacity var(--transition-base), background-color 0.3s ease;
  }

  /* State 1 — white hamburger when at top */
  .header.at-top .header__menu-line {
    background-color: rgba(255, 255, 255, 0.9);
  }

  /* ── Mobile nav overlay ─────────────────────────────────────────────────── */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: #052715;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100px var(--section-padding-x) 48px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
  }

  .mobile-nav.active {
    opacity: 1;
    pointer-events: all;
  }

  /* B watermark — 2× size, top-left anchored at 48px from viewport edges */
  .mobile-nav__watermark {
    position: absolute;
    left: 48px;
    top: 48px;
    width: 144vw;
    height: auto;
    opacity: 0.09;
    filter: brightness(0) invert(1);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* Nav takes the flex centre — grows to fill remaining space */
  .mobile-nav__nav {
    flex: 1;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .mobile-nav__list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav__link {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: "wght" 500, "hght" 1000;
    font-size: clamp(3rem, 8vw, 4.5rem);
    color: #f5f0e8;
    display: block;
    padding: 6px 0;
    transition: opacity 0.2s ease;
    text-decoration: none;
    letter-spacing: 0;
  }

  .mobile-nav__link:hover {
    opacity: 0.7;
  }

  /* Contact section — sits below the nav, centred */
  .mobile-nav__contact {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    text-align: center;
  }

  .mobile-nav__contact-link {
    font-family: var(--font-serif);
    font-variation-settings: normal;
    font-style: normal;
    font-weight: 300;
    font-size: 0.9rem;
    color: rgba(245, 240, 232, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.01em;
  }

  .mobile-nav__contact-link:hover {
    color: #f5f0e8;
    opacity: 1;
  }

  /* Legal row — very bottom */
  .mobile-nav__legal {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .mobile-nav__legal-link {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-nav__legal-link:hover {
    color: rgba(245, 240, 232, 0.75);
    opacity: 1;
  }

  /* ── 1280px: proportional scale-down ─── */
  @media (max-width: 1280px) {
    .header__inner {
      padding-top:    16px;  /* 18px × 0.90 */
      padding-bottom: 16px;
    }
    .header__logo-img {
      height: 32px;   /* 36px × 0.90 */
    }
    .header__nav-link {
      font-size: 19px;  /* 20px × 0.94 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .header__inner {
      padding-top:    14px;  /* 16px × 0.90 */
      padding-bottom: 14px;
    }
    .header__logo-img {
      height: 29px;   /* 32px × 0.90 */
    }
    .header__nav-link {
      font-size: 18px;  /* 19px × 0.94 */
    }
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }

    .header__menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const menuBtn = document.querySelector('.header__menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileLinks = document.querySelectorAll('.mobile-nav__link');

  // Hide on scroll down, reveal on scroll up — plus at-top state
  let lastScrollY = window.scrollY;

  const updateNav = () => {
    const currentScrollY = window.scrollY;

    // Slide behaviour
    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      header?.classList.add('nav-hidden');
    } else {
      header?.classList.remove('nav-hidden');
    }

    // At-top transparent state
    if (currentScrollY < 10) {
      header?.classList.add('at-top');
    } else {
      header?.classList.remove('at-top');
    }

    lastScrollY = currentScrollY;
  };

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav(); // Set correct state on load

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('active');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));

    const lines = menuBtn.querySelectorAll('.header__menu-line');
    if (isOpen) {
      lines[0].style.transform = 'rotate(45deg) translate(3px, 3px)';
      lines[1].style.transform = 'rotate(-45deg) translate(3px, -3px)';
    } else {
      lines[0].style.transform = '';
      lines[1].style.transform = '';
    }
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav?.classList.remove('active');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
      const lines = menuBtn?.querySelectorAll('.header__menu-line');
      lines?.forEach((l) => ((l as HTMLElement).style.transform = ''));
    });
  });
</script>
