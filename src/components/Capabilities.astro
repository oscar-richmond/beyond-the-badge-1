---
const base = import.meta.env.BASE_URL;

const capabilities = [
  {
    key: 'brand-partnerships',
    label: 'Meaningful Partnerships',
    img: 'cap-02.jpg',
    description: 'Connections that move people and shift cultural narratives.',
  },
  {
    key: 'cultural-strategy',
    label: 'Cultural Presence',
    img: 'cap-03.jpg',
    description: 'Showing up in art, sport, and entertainment with a point of view — and a contribution.',
  },
  {
    key: 'art-direction',
    label: 'Legacy Building',
    img: 'cap-04.jpg',
    description: 'Designing deep-rooted social agendas and purpose strategies that endure.',
  },
  {
    key: 'talent-relations',
    label: 'Authentic Storytelling',
    img: 'cap-05.jpg',
    description: 'Moving from loud to considered — every touchpoint deliberate.',
  },
  {
    key: 'event-production',
    label: 'Brand Experience',
    img: 'cap-06.jpg',
    description: 'Transforming global brand moments through bold concept creation.',
  },
  {
    key: 'community',
    label: 'Lifestyle & Licensing',
    img: 'cap-07.jpg',
    description: 'Curating narrative-driven collections and drops designed to tell a story.',
  },
];
---

<section class="capabilities-section" id="capabilities">

  <!-- Background image layers — crossfades via GSAP -->
  <div
    class="cap-bg"
    data-cap="default"
    style={`background-image: url('${base}images/capabilities/cap-01.jpg')`}
  ></div>
  {capabilities.map((c) => (
    <div
      class="cap-bg"
      data-cap={c.key}
      style={`background-image: url('${base}images/capabilities/${c.img}')`}
    ></div>
  ))}

  <!-- Dark scrim -->
  <div class="cap-overlay"></div>

  <!-- ── Content ─────────────────────────────────────────────────────────── -->
  <div class="cap-content container">

    <!-- Eyebrow row -->
    <div class="cap-header">
      <p class="cap-eyebrow">The Categories We're Redefining</p>
      <hr class="cap-rule" />
    </div>

    <!-- Two-column body -->
    <div class="cap-body">

      <!-- Left: description text (bottom-pinned) -->
      <div class="cap-left">
        <p class="cap-description" id="capDescription"></p>
      </div>

      <!-- Right: capability list -->
      <ul class="cap-list" id="capList">
        {capabilities.map((c) => (
          <li
            class="cap-item"
            data-cap={c.key}
            data-desc={c.description}
          >
            {c.label}
          </li>
        ))}
      </ul>

    </div>
  </div>

</section>

<style>
  /* ── Section ────────────────────────────────────────────────────────────── */
  .capabilities-section {
    position: relative;
    min-height: calc(100vh + 48px);
    overflow: hidden;
    background-color: #0a1a14;
    display: flex;
    align-items: center;
  }

  /* ── Background layers ──────────────────────────────────────────────────── */
  .cap-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transform: scale(1.04);
    z-index: 0;
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .cap-bg[data-cap="default"],
  .cap-bg.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Scrim ──────────────────────────────────────────────────────────────── */
  .cap-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.48);
    z-index: 1;
  }

  /* ── Content wrapper ────────────────────────────────────────────────────── */
  .cap-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: clamp(80px, 12vh, 140px);
    padding-bottom: clamp(80px, 12vh, 140px);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Eyebrow row ────────────────────────────────────────────────────────── */
  .cap-header {
    margin-bottom: 0;
  }

  .cap-eyebrow {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(248, 242, 237, 0.5);
    margin: 0 0 18px 0;
  }

  .cap-rule {
    border: none;
    border-top: 1px solid rgba(248, 242, 237, 0.2);
    margin: 0 0 0 0;
  }

  /* ── Body grid ──────────────────────────────────────────────────────────── */
  .cap-body {
    display: grid;
    grid-template-columns: 28% 1fr;
    gap: 0;
    /* Pin description to bottom of the left column */
    align-items: end;
    min-height: 55vh;
    padding-top: 40px;
  }

  /* ── Left: description ──────────────────────────────────────────────────── */
  .cap-left {
    align-self: end;
    padding-bottom: 4px;
  }

  .cap-description {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: calc(0.82rem + 2px);
    line-height: 1.65;
    color: #ffffff;
    max-width: 240px;
    margin: 0;
    min-height: 0;
  }

  /* ── Right: capability list ─────────────────────────────────────────────── */
  .cap-list {
    align-self: end;
    /* Items are right-aligned */
    text-align: right;
  }

  .cap-item {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.2vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    color: #f8f2ed;
    padding: 0.2em 0;
    opacity: 0.35;
    cursor: default;
    display: block;
    transition: opacity 0.35s ease, color 0.35s ease;
    will-change: opacity;
  }

  .cap-list.has-hover .cap-item:not(.is-active) {
    opacity: 0.2;
  }

  .cap-item.is-active {
    opacity: 1;
    color: #ffffff;
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Two-column: list left, description right — mirrors desktop intent */
    .cap-body {
      grid-template-columns: 1fr 38%;
      min-height: auto;
      gap: 24px;
      align-items: end;        /* bottom-aligns both columns */
      padding-top: 40px;
    }

    /* Description: right column, anchored to the bottom, grows upward */
    .cap-left {
      grid-column: 2;
      grid-row: 1;
      order: 2;
      align-self: end;
      text-align: right;
      min-height: 0;           /* no fixed height needed — list drives row height */
      padding-bottom: 4px;
    }

    .cap-description {
      max-width: none;         /* remove 240px cap — let column width govern */
      text-align: right;
    }

    /* List: left column, left-aligned */
    .cap-list {
      grid-column: 1;
      grid-row: 1;
      order: 1;
      text-align: left;
    }

    .cap-item {
      font-size: clamp(2rem, 6vw, 3rem);
      opacity: 0.5;
      cursor: pointer;
    }

    .cap-item.is-active {
      opacity: 1;
    }

    /* No arrow indicator — active state shown by opacity highlight only */
    .cap-item::after {
      display: none;
    }
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .cap-item {
      font-size: clamp(1.8rem, 3vw, 3rem);  /* clamp(1.9rem,3.2vw,3.2rem) × 0.94 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .cap-item {
      font-size: clamp(1.7rem, 2.8vw, 2.82rem);  /* max 3rem × 0.94 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .cap-item {
      font-size: clamp(1.85rem, 2.85vw, 2.9rem);  /* 2.65rem + 4px (user request) */
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const list        = document.getElementById('capList') as HTMLElement | null;
  const descEl      = document.getElementById('capDescription') as HTMLElement | null;
  const bgs         = document.querySelectorAll<HTMLElement>('.cap-bg');

  if (!list) throw new Error('Capabilities list not found');

  // Ensure lr-clip CSS is available (BaseLayout injects it for desktop;
  // we add it here as a guarantee for this component's dynamic usage).
  if (!document.querySelector('#cap-lr-css')) {
    const s = document.createElement('style');
    s.id = 'cap-lr-css';
    s.textContent = [
      '.lr-clip{overflow:hidden;display:block}',
      '.lr-inner{display:block;transform:translateY(110%);will-change:transform}',
      '.lr-clip.lr-visible .lr-inner{transform:translateY(0)}',
    ].join('');
    document.head.appendChild(s);
  }

  const items = list.querySelectorAll<HTMLElement>('.cap-item');
  let activeItem: HTMLElement | null = null;
  let descTimer: ReturnType<typeof setTimeout> | null = null;

  /* ── Background crossfade (CSS class toggle — mirrors About page) ─────── */
  function activateBg(key: string | null): void {
    const target = key ?? 'default';
    bgs.forEach((bg) => {
      bg.classList.toggle('is-active', bg.dataset.cap === target);
    });
  }

  /* ── Description text swap — per-line clip reveal (matches homepage §) ─── */
  function setDescription(text: string | null): void {
    if (!descEl) return;
    if (descTimer) clearTimeout(descTimer);

    // Clear immediately so previous lines don't linger
    descEl.innerHTML = '';
    if (!text) return;

    // ── Step 1: render measure spans so we can read offsetTop ────────────
    const words = text.split(/\s+/).filter(w => w.length > 0);
    const measureSpans: HTMLElement[] = [];
    words.forEach((word, i) => {
      const s = document.createElement('span');
      s.style.display = 'inline-block';
      s.textContent = word;
      descEl.appendChild(s);
      measureSpans.push(s);
      if (i < words.length - 1) descEl.appendChild(document.createTextNode(' '));
    });

    // Force layout so offsetTop is accurate
    void descEl.offsetHeight;

    // ── Step 2: group words by visual line ───────────────────────────────
    const lineGroups: string[][] = [];
    let currentTop = -9999;
    let group: string[] = [];
    measureSpans.forEach(s => {
      const top = s.offsetTop;
      if (Math.abs(top - currentTop) > 3) {
        if (group.length) lineGroups.push(group);
        group = [];
        currentTop = top;
      }
      group.push(s.textContent || '');
    });
    if (group.length) lineGroups.push(group);

    // ── Step 3: rebuild as lr-clip / lr-inner per line ───────────────────
    descEl.innerHTML = '';
    lineGroups.forEach((lineWords, i) => {
      const clip  = document.createElement('div');
      clip.className = 'lr-clip';
      const inner = document.createElement('div');
      inner.className = 'lr-inner';
      inner.style.transition =
        `transform 0.6s cubic-bezier(0.42, 0, 0.24, 1) ${(i * 0.06).toFixed(2)}s`;
      inner.textContent = lineWords.join(' ');
      clip.appendChild(inner);
      descEl.appendChild(clip);
    });

    // ── Step 4: trigger reveal on the next frame ─────────────────────────
    descTimer = setTimeout(() => {
      descEl.querySelectorAll<HTMLElement>('.lr-clip')
        .forEach(clip => clip.classList.add('lr-visible'));
    }, 16);
  }

  /* ── Item hover ───────────────────────────────────────────────────────── */
  items.forEach((item) => {
    item.addEventListener('mouseenter', () => {
      if (activeItem === item) return;

      // Deactivate previous
      activeItem?.classList.remove('is-active');

      // Activate current
      item.classList.add('is-active');
      activeItem = item;

      list.classList.add('has-hover');
      activateBg(item.dataset.cap ?? null);
      setDescription(item.dataset.desc ?? null);
    });
  });

  /* ── List leave ───────────────────────────────────────────────────────── */
  // On touch devices the list-leave must not clear the tapped-active state
  list.addEventListener('mouseleave', () => {
    if (window.innerWidth <= 768) return;
    activeItem?.classList.remove('is-active');
    activeItem = null;
    list.classList.remove('has-hover');
    activateBg(null);
    setDescription(null);
  });

  /* ── Mobile: tap to activate + first item active on load ───────────────────── */
  if (window.innerWidth <= 768) {
    // Activate first item by default
    const firstItem = items[0] as HTMLElement | undefined;
    if (firstItem) {
      firstItem.classList.add('is-active');
      activeItem = firstItem;
      list.classList.add('has-hover');
      activateBg(firstItem.dataset.cap ?? null);
      setDescription(firstItem.dataset.desc ?? null);
    }

    // Tap activates — identical result to hover on desktop
    items.forEach((item) => {
      item.addEventListener('click', () => {
        if (activeItem === item) return;
        activeItem?.classList.remove('is-active');
        item.classList.add('is-active');
        activeItem = item;
        activateBg(item.dataset.cap ?? null);
        setDescription(item.dataset.desc ?? null);
      });
    });
  }
</script>
