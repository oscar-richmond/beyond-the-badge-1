---
const base = import.meta.env.BASE_URL;

const capabilities = [
  {
    key: 'brand-partnerships',
    label: 'Meaningful Partnerships',
    img: 'cap-02.jpg',
    description: 'Connections that move people and shift cultural narratives.',
  },
  {
    key: 'cultural-strategy',
    label: 'Cultural Presence',
    img: 'cap-03.jpg',
    description: 'Showing up in art, sport, and entertainment with a point of view — and a contribution.',
  },
  {
    key: 'art-direction',
    label: 'Legacy Building',
    img: 'cap-04.jpg',
    description: 'Designing deep-rooted social agendas and purpose strategies that endure.',
  },
  {
    key: 'talent-relations',
    label: 'Authentic Storytelling',
    img: 'cap-05.jpg',
    description: 'Moving from loud to considered — every touchpoint deliberate.',
  },
  {
    key: 'event-production',
    label: 'Brand Experience',
    img: 'cap-06.jpg',
    description: 'Transforming global brand moments through bold concept creation.',
  },
  {
    key: 'community',
    label: 'Lifestyle & Licensing',
    img: 'cap-07.jpg',
    description: 'Curating narrative-driven collections and drops designed to tell a story.',
  },
];

const SCROLL_PER_CAP = 600; // px of scroll per category on mobile
const TOTAL_EXTRA    = SCROLL_PER_CAP * (capabilities.length - 1); // 3000px
---

<!--
  cap-scroll-wrapper provides the scroll height for the mobile pin.
  At ≤500px (CSS): wrapper is tall, section is position:sticky inside it.
  Above 500px:     wrapper is display:contents — no layout effect.
-->
<div id="capScrollWrapper" class="cap-scroll-wrapper">

  <section class="capabilities-section" id="capabilities">

    <!-- Background image layers — crossfades via GSAP -->
    <div
      class="cap-bg"
      data-cap="default"
      style={`background-image: url('${base}images/capabilities/cap-01.jpg')`}
    ></div>
    {capabilities.map((c) => (
      <div
        class="cap-bg"
        data-cap={c.key}
        style={`background-image: url('${base}images/capabilities/${c.img}')`}
      ></div>
    ))}

    <!-- Dark scrim -->
    <div class="cap-overlay"></div>

    <!-- ── Content ──────────────────────────────────────────────────────── -->
    <div class="cap-content container">

      <!-- Eyebrow row -->
      <div class="cap-header">
        <p class="cap-eyebrow">The Categories We're Redefining</p>
        <hr class="cap-rule" />
      </div>

      <!-- Two-column body -->
      <div class="cap-body">

        <!-- Left: description text -->
        <div class="cap-left">
          <p class="cap-description" id="capDescription"></p>
        </div>

        <!-- Right: capability list -->
        <ul class="cap-list" id="capList">
          {capabilities.map((c) => (
            <li
              class="cap-item"
              data-cap={c.key}
              data-desc={c.description}
            >
              {c.label}
            </li>
          ))}
        </ul>

      </div>
    </div>

  </section>

</div>

<style define:vars={{ totalExtra: `${TOTAL_EXTRA}px` }}>
  /* ── Scroll-pin wrapper ─────────────────────────────────────────────────── */
  /* At ≤500px the wrapper is a tall spacer; the section is sticky inside it. */
  /* Above 500px it's display:contents — invisible to layout. */
  .cap-scroll-wrapper {
    display: contents; /* no layout effect above 500px */
  }

  /* ── Section ────────────────────────────────────────────────────────────── */
  .capabilities-section {
    position: relative;
    min-height: calc(100vh + 48px);
    overflow: hidden;
    background-color: #0a1a14;
    display: flex;
    align-items: center;
  }

  /* ── Background layers ──────────────────────────────────────────────────── */
  .cap-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transform: scale(1.04);
    z-index: 0;
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .cap-bg[data-cap="default"],
  .cap-bg.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Scrim ──────────────────────────────────────────────────────────────── */
  .cap-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.48);
    z-index: 1;
  }

  /* ── Content wrapper ────────────────────────────────────────────────────── */
  .cap-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: clamp(80px, 12vh, 140px);
    padding-bottom: clamp(80px, 12vh, 140px);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Eyebrow row ────────────────────────────────────────────────────────── */
  .cap-header { margin-bottom: 0; }

  .cap-eyebrow {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(248, 242, 237, 0.5);
    margin: 0 0 18px 0;
  }

  .cap-rule {
    border: none;
    border-top: 1px solid rgba(248, 242, 237, 0.2);
    margin: 0;
  }

  /* ── Body grid ──────────────────────────────────────────────────────────── */
  .cap-body {
    display: grid;
    grid-template-columns: 28% 1fr;
    gap: 0;
    align-items: end;
    min-height: 55vh;
    padding-top: 40px;
  }

  /* ── Left: description ──────────────────────────────────────────────────── */
  .cap-left {
    align-self: end;
    padding-bottom: 4px;
  }

  .cap-description {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: calc(0.82rem + 2px);
    line-height: 1.65;
    color: #ffffff;
    max-width: 240px;
    margin: 0;
    min-height: 0;
  }

  /* ── Right: capability list ─────────────────────────────────────────────── */
  .cap-list {
    align-self: end;
    text-align: right;
  }

  .cap-item {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.2vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    color: #f8f2ed;
    padding: 0.2em 0;
    opacity: 0.35;
    cursor: default;
    display: block;
    transition: opacity 0.35s ease, color 0.35s ease;
    will-change: opacity;
  }

  .cap-list.has-hover .cap-item:not(.is-active) { opacity: 0.2; }

  .cap-item.is-active {
    opacity: 1;
    color: #ffffff;
  }

  /* ── Mobile layout (768px) ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .cap-body {
      grid-template-columns: 1fr 38%;
      min-height: auto;
      gap: 24px;
      align-items: end;
      padding-top: 40px;
    }

    .cap-left {
      grid-column: 2;
      grid-row: 1;
      order: 2;
      align-self: end;
      text-align: right;
      min-height: 0;
      padding-bottom: 4px;
    }

    .cap-description {
      max-width: none;
      text-align: right;
    }

    .cap-list {
      grid-column: 1;
      grid-row: 1;
      order: 1;
      text-align: left;
    }

    .cap-item {
      font-size: clamp(2rem, 6vw, 3rem);
      opacity: 0.5;
      cursor: pointer;
    }

    .cap-item.is-active { opacity: 1; }
    .cap-item::after    { display: none; }
  }

  /* ── Scroll-pin carousel (≤500px) ───────────────────────────────────────── */
  /* Wrapper becomes a tall spacer; section is position:sticky inside it.     */
  /* JS reads scroll progress from the wrapper and advances categories.        */
  @media (max-width: 500px) {
    .cap-scroll-wrapper {
      display: block;   /* back to block so it has layout */
      position: relative;
      /* var(--totalExtra) = 1300px, injected via define:vars */
      height: calc(100vh + var(--totalExtra));
    }

    .capabilities-section {
      position: sticky;
      top: 0;
      height: 100vh;
      min-height: unset; /* override the base calc(100vh + 48px) */
    }
  }

  /* ── Desktop scale-downs ────────────────────────────────────────────────── */
  @media (max-width: 1440px) {
    .cap-item { font-size: clamp(1.8rem, 3vw, 3rem); }
  }
  @media (max-width: 1280px) {
    .cap-item { font-size: clamp(1.7rem, 2.8vw, 2.82rem); }
  }
  @media (max-width: 1024px) {
    .cap-item { font-size: clamp(1.85rem, 2.85vw, 2.9rem); }
  }
</style>

<script>
  import gsap from 'gsap';

  const wrapper = document.getElementById('capScrollWrapper') as HTMLElement | null;
  const list    = document.getElementById('capList')          as HTMLElement | null;
  const descEl  = document.getElementById('capDescription')   as HTMLElement | null;
  const bgs     = document.querySelectorAll<HTMLElement>('.cap-bg');

  if (!list) throw new Error('Capabilities list not found');

  if (!document.querySelector('#cap-lr-css')) {
    const s = document.createElement('style');
    s.id = 'cap-lr-css';
    s.textContent = [
      '.lr-clip{overflow:hidden;display:block}',
      '.lr-inner{display:block;transform:translateY(110%);will-change:transform}',
      '.lr-clip.lr-visible .lr-inner{transform:translateY(0)}',
    ].join('');
    document.head.appendChild(s);
  }

  const items = list.querySelectorAll<HTMLElement>('.cap-item');
  let activeItem: HTMLElement | null = null;
  let descTimer: ReturnType<typeof setTimeout> | null = null;

  /* ── Background crossfade ─────────────────────────────────────────────── */
  function activateBg(key: string | null): void {
    const target = key ?? 'default';
    bgs.forEach((bg) => bg.classList.toggle('is-active', bg.dataset.cap === target));
  }

  /* ── Description text swap — per-line clip reveal ────────────────────── */
  function setDescription(text: string | null): void {
    if (!descEl) return;
    if (descTimer) clearTimeout(descTimer);
    descEl.innerHTML = '';
    if (!text) return;

    const words = text.split(/\s+/).filter(w => w.length > 0);
    const measureSpans: HTMLElement[] = [];
    words.forEach((word, i) => {
      const s = document.createElement('span');
      s.style.display = 'inline-block';
      s.textContent = word;
      descEl.appendChild(s);
      measureSpans.push(s);
      if (i < words.length - 1) descEl.appendChild(document.createTextNode(' '));
    });
    void descEl.offsetHeight;

    const lineGroups: string[][] = [];
    let currentTop = -9999;
    let group: string[] = [];
    measureSpans.forEach(s => {
      const top = s.offsetTop;
      if (Math.abs(top - currentTop) > 3) {
        if (group.length) lineGroups.push(group);
        group = []; currentTop = top;
      }
      group.push(s.textContent || '');
    });
    if (group.length) lineGroups.push(group);

    descEl.innerHTML = '';
    lineGroups.forEach((lineWords, i) => {
      const clip  = document.createElement('div');
      clip.className = 'lr-clip';
      const inner = document.createElement('div');
      inner.className = 'lr-inner';
      inner.style.transition = `transform 0.6s cubic-bezier(0.42,0,0.24,1) ${(i*0.06).toFixed(2)}s`;
      inner.textContent = lineWords.join(' ');
      clip.appendChild(inner);
      descEl.appendChild(clip);
    });

    descTimer = setTimeout(() => {
      descEl.querySelectorAll<HTMLElement>('.lr-clip').forEach(c => c.classList.add('lr-visible'));
    }, 16);
  }

  /* ── Shared activate ──────────────────────────────────────────────────── */
  function activateItem(item: HTMLElement): void {
    if (item === activeItem) return;
    activeItem?.classList.remove('is-active');
    item.classList.add('is-active');
    activeItem = item;
    list.classList.add('has-hover');
    activateBg(item.dataset.cap ?? null);
    setDescription(item.dataset.desc ?? null);
  }

  /* ── Desktop hover ────────────────────────────────────────────────────── */
  items.forEach(item => item.addEventListener('mouseenter', () => activateItem(item)));

  list.addEventListener('mouseleave', () => {
    if (window.innerWidth <= 768) return;
    activeItem?.classList.remove('is-active');
    activeItem = null;
    list.classList.remove('has-hover');
    activateBg(null);
    setDescription(null);
  });

  /* ── Mobile: tap + first-item default ────────────────────────────────── */
  if (window.innerWidth <= 768) {
    const first = items[0] as HTMLElement | undefined;
    if (first) activateItem(first);
    items.forEach(item => item.addEventListener('click', () => activateItem(item)));
  }

  /* ════════════════════════════════════════════════════════════════════════
     SCROLL-PIN CAROUSEL  ·  ≤500px only
     ────────────────────────────────────────────────────────────────────────
     The wrapper is already in the HTML template + CSS makes it the tall
     scroll spacer and the section position:sticky. JS only reads scroll
     progress from wrapper.getBoundingClientRect() and advances categories.
     No DOM manipulation at runtime.
  ════════════════════════════════════════════════════════════════════════ */
  if (window.innerWidth <= 500 && wrapper) {
    const SCROLL_PER_CAP = 600;
    const totalExtra     = SCROLL_PER_CAP * (items.length - 1); // 3000

    let currentScrollIndex = 0;

    gsap.ticker.add(() => {
      const wRect   = wrapper.getBoundingClientRect();
      const scrolled = Math.max(0, -wRect.top);
      const progress = Math.min(1, scrolled / totalExtra);
      const targetIdx = Math.min(items.length - 1, Math.floor(progress * items.length));

      if (targetIdx !== currentScrollIndex) {
        currentScrollIndex = targetIdx;
        const target = items[targetIdx] as HTMLElement;
        if (target) activateItem(target);
      }
    });
  }
</script>
