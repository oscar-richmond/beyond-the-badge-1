---
const base = import.meta.env.BASE_URL + '/';
const navItems = [
  { href: '/terms', label: 'Terms & Conditions' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: 'https://www.instagram.com', label: 'Instagram' },
];
---

<footer class="footer">
  <img
    src={`${base}logo-monogram.png`}
    alt=""
    aria-hidden="true"
    class="footer__watermark"
  />

  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <img src={`${base}logo-full.png`} alt="Beyond the Badge" class="footer__logo-img" />
      </div>
    </div>

    <div class="footer__bottom">
      <a href="mailto:info@beyondthebadge.agency" class="footer__nav-link">info@beyondthebadge.agency</a>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul class="footer__nav-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="footer__nav-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__legal">
        <span>© Beyond The Badge 2026</span>
        <span class="footer__legal-sep">·</span>
        <a href="https://selfhood-studios.com/" target="_blank" rel="noopener noreferrer" class="footer__nav-link footer__legal-link">Site by Selfhood Studios</a>
      </div>
    </div>
  </div>
</footer>
