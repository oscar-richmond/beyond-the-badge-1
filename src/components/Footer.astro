---
interface Props {
  cream?: boolean;
}
const { cream = false } = Astro.props;

const base = import.meta.env.BASE_URL;
const navItems = [
  { href: '/terms', label: 'Terms & Conditions' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: 'https://www.instagram.com', label: 'Instagram' },
];
---

<footer class={`footer${cream ? ' footer--cream' : ''}`}>
  <img
    src={`${base}logo-monogram.png`}
    alt=""
    aria-hidden="true"
    class="footer__watermark"
  />

  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <img src={`${base}logo-full.png`} alt="Beyond the Badge" class="footer__logo-img" />
      </div>
    </div>

    <div class="footer__bottom">
      <a href="mailto:hello@beyondthebadge.agency" class="footer__nav-link">hello@beyondthebadge.agency</a>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul class="footer__nav-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="footer__nav-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__legal">
        <span>© Beyond The Badge 2026</span>
        <span class="footer__legal-sep">·</span>
        <a href="https://selfhood-studios.com/" target="_blank" rel="noopener noreferrer" class="footer__nav-link footer__legal-link">Site by Selfhood Studios</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Cream variant overrides ──────────────────────────────────────────────── */
  .footer--cream {
    background-color: var(--color-cream);
  }

  /* Watermark: dark monogram on cream (no invert) */
  .footer--cream .footer__watermark {
    filter: brightness(0);
    opacity: 0.06 !important;
  }

  /* Logo: natural green colour */
  .footer--cream .footer__logo-img {
    filter: none;
  }

  /* Divider line */
  .footer--cream .footer__bottom {
    border-top-color: rgba(5, 39, 21, 0.15);
  }

  /* Nav + legal links */
  .footer--cream .footer__nav-link {
    color: rgba(5, 39, 21, 0.65);
  }

  .footer--cream .footer__nav-link:hover {
    color: #052715;
  }

  /* Copyright + separator */
  .footer--cream .footer__legal span,
  .footer--cream .footer__legal-sep {
    color: rgba(5, 39, 21, 0.45);
  }
</style>
