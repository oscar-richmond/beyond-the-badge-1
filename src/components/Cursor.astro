---
// Cursor.astro — v3
// · Normal dot: 16 px, no stroke
// · Hover: expands to 36 px, no stroke
// · Turns cream on dark sections (luminance < 0.25), green on light
// · Anti-pixelation: element lives at 36 px, scaled down to 0.444 for normal
---

<div id="btb-cursor-dot" aria-hidden="true"></div>

<style is:global>
  /* ── Hide native cursor ──────────────────────────────────────────────── */
  html { cursor: none !important; }
  input, textarea, [contenteditable="true"] { cursor: text      !important; }
  input[type="range"]                       { cursor: ew-resize !important; }

  /* ── Dot ──────────────────────────────────────────────────────────────── */
  /*
   * Defined at max visual size (36 × 36 px).
   * Normal: GSAP scale(0.444) → 16 px visual.
   * Hover : GSAP scale(1)     → 36 px visual.
   * margin offsets centre the dot on the hotspot.
   */
  #btb-cursor-dot {
    position: fixed;
    top:  0;
    left: 0;
    width:  36px;
    height: 36px;
    margin-top:  -18px;
    margin-left: -18px;
    background:    #052715;
    border-radius: 50%;
    /* No stroke — removed from both normal and hover states */
    pointer-events: none;
    z-index: 999999;
    opacity: 0;
    will-change:         transform, opacity, background-color;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform-origin: center center;
  }
</style>

<script>
  import { gsap } from 'gsap';

  const dot = document.getElementById('btb-cursor-dot') as HTMLElement | null;

  const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
  if (!hasFinePointer || !dot) {
    dot?.remove();
    document.documentElement.style.cursor = '';
  } else {

    /* ── Sizing ─────────────────────────────────────────────────────────── */
    const SCALE_NORMAL   = 16 / 36;      // ≈ 0.444 → 16 px
    const SCALE_EXPAND   = 1;            //           36 px
    const SCALE_PRESS_N  = 0.25;
    const SCALE_PRESS_E  = 0.75;

    /* ── Colour theme ───────────────────────────────────────────────────── */
    const COL_GREEN = '#052715';         // default
    const COL_CREAM = '#F5F0E8';         // over dark / maroon sections

    let cursorColour = COL_GREEN;

    /* Walk up DOM from element to find first non-transparent background */
    function resolveBackground(el: Element | null): string | null {
      let node = el;
      while (node && node !== document.documentElement) {
        const bg = window.getComputedStyle(node as Element).backgroundColor;
        if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') return bg;
        node = (node as Element).parentElement;
      }
      return null;
    }

    /* Relative luminance (simplified BT.601) 0 = black, 1 = white */
    function getLuma(cssRgb: string): number {
      const m = cssRgb.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
      if (!m) return 1;
      return (0.299 * +m[1] + 0.587 * +m[2] + 0.114 * +m[3]) / 255;
    }

    function applyColour(col: string) {
      if (col === cursorColour) return;
      cursorColour = col;
      gsap.to(dot, { backgroundColor: col, duration: 0.3, ease: 'power2.out' });
    }

    /* ── Interaction state ──────────────────────────────────────────────── */
    const INTERACTIVE =
      'a, button, [role="button"], label, select, ' +
      '.services__item, [data-cursor="expand"]';

    let expanded = false;

    gsap.set(dot, { scale: SCALE_NORMAL });

    function expand() {
      if (expanded) return;
      expanded = true;
      gsap.to(dot, { scale: SCALE_EXPAND, opacity: 0.45, duration: 0.35, ease: 'power3.out' });
    }
    function contract() {
      if (!expanded) return;
      expanded = false;
      gsap.to(dot, { scale: SCALE_NORMAL, opacity: 1, duration: 0.25, ease: 'power3.out' });
    }

    /* ── Mouse tracking ─────────────────────────────────────────────────── */
    const xTo = gsap.quickTo(dot, 'x', { duration: 0.10, ease: 'power2.out' });
    const yTo = gsap.quickTo(dot, 'y', { duration: 0.10, ease: 'power2.out' });

    document.addEventListener('mousemove', (e) => {
      xTo(e.clientX);
      yTo(e.clientY);
    }, { passive: true });

    /* Reveal on first move */
    document.addEventListener('mousemove', function reveal() {
      gsap.to(dot, { opacity: 1, duration: 0.3 });
      document.removeEventListener('mousemove', reveal);
    }, { once: true });

    document.addEventListener('mouseleave', () =>
      gsap.to(dot, { opacity: 0, duration: 0.25 }));
    document.addEventListener('mouseenter', () =>
      gsap.to(dot, { opacity: expanded ? 0.45 : 1, duration: 0.25 }));

    /* ── Hover detection (interactive + dark-section colour) ────────────── */
    document.addEventListener('mouseover', (e) => {
      const target = e.target as Element;

      // Interactive expand
      target.closest(INTERACTIVE) ? expand() : contract();

      // Colour: sample background at cursor position
      const bg   = resolveBackground(target);
      const luma = bg ? getLuma(bg) : 1;
      // Dark sections (luma < 0.25) → cream cursor so it's visible
      applyColour(luma < 0.25 ? COL_CREAM : COL_GREEN);
    }, { passive: true });

    /* ── Press feedback ─────────────────────────────────────────────────── */
    document.addEventListener('mousedown', () =>
      gsap.to(dot, { scale: expanded ? SCALE_PRESS_E : SCALE_PRESS_N, duration: 0.1, ease: 'power2.in' }));
    document.addEventListener('mouseup', () =>
      gsap.to(dot, { scale: expanded ? SCALE_EXPAND : SCALE_NORMAL, duration: 0.15, ease: 'power2.out' }));
  }
</script>
