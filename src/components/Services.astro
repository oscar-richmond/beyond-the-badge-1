---
import servicesData from '../../content/services.json';

const base = import.meta.env.BASE_URL;
const img = (p: string) => p ? `${base}${p.replace(/^\//, '')}` : '';

const services = (servicesData.items || []).map(s => ({
  ...s,
  image: img(s.image),
}));

const VIEWER_W = 300;
const VIEWER_H = 375;
---

<section class="services" id="services">
  <div class="container">
    <div class="services__header">
      <h2 class="services__heading">{servicesData.sectionHeading || 'Our approach'}</h2>
    </div>

    <div class="services__list">
      <hr class="services__divider" />
      {services.map((service, index) => (
        <>
          <div
            class="services__item reveal"
            data-index={String(index)}
            data-image={service.image}
            style={`transition-delay: ${index * 0.1}s;`}
          >
            <div class="services__item-left">
              <span class="services__number">{service.number}</span>
              <h3 class="services__title">
                {service.title}
                <img src={`${base}beyond-script.png`} alt="Beyond" class="services__beyond-img" />
                {service.beyondText}
              </h3>
            </div>
            <span class="services__category">{service.category}</span>
            {/* Per-row tap image — position:absolute relative to this row */}
            <div class="services__row-image" aria-hidden="true">
              <img src={service.image} alt="" draggable="false" />
            </div>
          </div>
          <hr class="services__divider" />
        </>
      ))}
    </div>

    {/* Mobile-only image stack: hidden above 390px, shown as vertical squares below */}
    <div class="services__mobile-gallery" aria-hidden="true">
      {services.slice(0, 3).map((service) => (
        <div class="services__mobile-gallery-item">
          <img src={service.image} alt="" loading="lazy" draggable="false" />
        </div>
      ))}
    </div>
  </div>
</section>

<!--
  Persistent image viewer — lives outside the list flow.
  Follows the mouse via GSAP quickTo; strip slides to reveal the active row image.
-->
<div
  class="services__viewer"
  id="servicesViewer"
  aria-hidden="true"
  style={`--viewer-h: ${VIEWER_H}px;`}
>
  <div class="services__viewer-strip" id="servicesStrip">
  {services.map((service) => (
    <div class="services__viewer-item">
      <img src={service.image} alt="" loading="eager" draggable="false" />
    </div>
  ))}
  </div>
</div>

<style>
  /* ── Section ──────────────────────────────────────────────────────────── */
  .services {
    background: transparent;
    padding: var(--section-padding-y) 0;
    position: relative;
    /* Opacity driven by GSAP ticker in sync with body background transition.
       will-change promotes to GPU layer for smooth compositing. */
    will-change: opacity;
  }

  .services__header {
    margin-bottom: 8px;
  }

  .services__heading {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  /* ── List & rows ──────────────────────────────────────────────────────── */
  .services__list {
    margin-top: clamp(48px, 8vw, 120px);
  }

  .services__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 40px 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
    z-index: 1;
  }

  hr.services__divider {
    border: none;
    border-top: 1px solid #6E4142;
    margin: 0;
  }

  /* ── Row hover text colours ───────────────────────────────────────────── */
  .services__item-left {
    display: flex;
    align-items: center;
    gap: 24px;
    position: relative;
    z-index: 2;
  }

  .services__number {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.85rem;
    font-weight: 300;
    color: #6E4142;
    min-width: 32px;
    transition: color 0.4s ease;
  }

  .services__item:hover .services__number { color: #FFFFFF; }

  .services__title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 400;
    color: var(--color-cream);
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    letter-spacing: 0.05em;
    transition: color 0.4s ease;
    overflow: visible;
  }

  .services__item:hover .services__title { color: #6E4142; }

  .services__beyond-img {
    height: 51px;
    width: auto;
    display: inline-block;
    vertical-align: baseline;
    margin: -7.5px 0;
    position: relative;
    top: 8.5px;
    /* Same filter function list as the hover state, evaluated to white.
       Matching lists let CSS interpolate each function individually —
       no blue/purple flash from mismatched hue-rotate mid-transition. */
    filter: brightness(0) saturate(100%) invert(100%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(100%) contrast(100%);
    transition: filter 0.4s ease;
  }

  .services__item:hover .services__beyond-img {
    filter: brightness(0) saturate(100%) invert(24%) sepia(23%) saturate(1005%)
            hue-rotate(314deg) brightness(98%) contrast(92%);
  }

  .services__category {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #6E4142;
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.4s ease;
    position: relative;
    z-index: 2;
  }

  .services__item:hover .services__category { color: #FFFFFF; }

  /* ── Persistent image viewer ──────────────────────────────────────────── */
  /* Fixed to viewport so it can freely follow the cursor.
     All position is managed via GSAP x/y (translateX/Y).              */
  .services__viewer {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: var(--viewer-h, 375px);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    z-index: 90;
    will-change: transform, opacity;
    border-radius: 2px;
  }

  /* Mobile-only image gallery — hidden at all breakpoints above 390px */
  .services__mobile-gallery {
    display: none;
  }

  /* Per-row tap image overlay — hidden on desktop; shown only at ≤768px */
  .services__row-image {
    display: none;
  }

  /* Strip — no CSS transition; GSAP drives all animation for reliability */
  .services__viewer-strip {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .services__viewer-item {
    width: 300px;
    height: var(--viewer-h, 375px);
    flex-shrink: 0;
    overflow: hidden;
  }

  .services__viewer-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Gap 2: about_pb=0, so services_pt=120px is the full cap-image→OUR APPROACH gap */
    /* Gap 3: 120px of breathing room after the last services row divider              */
    .services {
      padding-top: 232px;
      padding-bottom: 0;
    }

    .services__item {
      flex-direction: row;      /* keep category inline — no longer drops below */
      align-items: center;      /* vertically centre number, title & category */
      gap: 16px;
      padding: 36px 0;
    }

    .services__item-left {
      align-items: center;      /* number centres against title height */
      gap: 14px;
      flex: 1;                  /* fill available width, pushing category right */
      min-width: 0;             /* allow title to wrap within its space */
    }

    .services__category {
      flex-shrink: 0;   /* never shrink — stays at natural width */
      margin-left: 0;
      padding-left: 0;
    }

    .services__beyond-img { height: 37px; }

    /* Desktop cursor-following viewer: disabled on mobile */
    .services__viewer { display: none; }

    /* Cancel the double-padding rule — gap is now owned by services padding-top */
    .services__header { margin-top: 0; }

    /* ── Per-row tap image overlay ─────────────────────────────────────── */
    /* position:absolute anchors each image to its own row so it scrolls
       with the page. pointer-events:none means the overlay never blocks
       scroll or taps — only JS-wired row taps trigger show/hide. */
    .services__row-image {
      display: block;
      position: absolute;
      /* Slightly right of centre — feels anchored to its row content */
      left: 55%;
      top: 50%;
      width: min(190px, 46vw);
      aspect-ratio: 4 / 5;
      overflow: hidden;
      border-radius: 2px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.25s ease;
      /* z-index relative to row stacking context — JS raises parent item
         to z-index:5 when active so the image paints above adjacent rows */
      z-index: 2;
      will-change: opacity;
    }

    /* Alternating rotation per row — same angle every time it's tapped.
       nth-of-type counts <div> children only, ignoring <hr> dividers. */
    .services__item:nth-of-type(odd)  .services__row-image {
      transform: translateY(-50%) rotate(5deg);
    }
    .services__item:nth-of-type(even) .services__row-image {
      transform: translateY(-50%) rotate(-5deg);
    }

    .services__row-image.is-visible {
      opacity: 1;
    }

    .services__row-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      user-select: none;
      -webkit-user-drag: none;
    }
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .services__title {
      font-size: clamp(23px, 3.8vw, 34px);  /* max 36 → 34px */
    }
    .services__viewer,
    .services__viewer-item {
      width: 270px;   /* 300px × 0.90 */
    }
    .services__beyond-img {
      height: 46px;   /* 51px × 0.90 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .services__title {
      font-size: clamp(21px, 3.6vw, 32px);  /* max 34px × 0.94 */
    }
    .services__viewer,
    .services__viewer-item {
      width: 243px;   /* 270px × 0.90 */
    }
    .services__beyond-img {
      height: 41px;   /* 46px × 0.90 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .services__title {
      font-size: clamp(20px, 3.4vw, 30px);  /* max 32px × 0.94 */
    }
    .services__viewer,
    .services__viewer-item {
      width: 219px;   /* 243px × 0.90 */
    }
    .services__beyond-img {
      height: 37px;   /* 41px × 0.90 */
    }
  }
  /* ── 390px ─────────────────────────────────────────────────────────── */
  @media (max-width: 390px) {
    /* Hide right-side category labels (PARTNERSHIPS, STORYTELLING, etc.) */
    .services__category {
      display: none;
    }

    /* Keep the full title on one line — reduce font-size so
       "(01) Influence [Beyond] expectation" fits in ~276px */
    .services__title {
      flex-wrap: nowrap;
      font-size: 20px;
    }

    /* Scale the script image to match the smaller font, shift up 3px */
    .services__beyond-img {
      height: 28px;
      top: 5.5px;
    }

    /* Hide the image stack below the table at this breakpoint */
    .services__mobile-gallery {
      display: none;
    }
  }

  /* ── 450px: Pro Max spacing + gap controls ────────────────────────── */
  @media (max-width: 500px) {
    /* Gap 2: about_pb=0 so this 120px is the full cap-image→OUR APPROACH gap */
    /* Gap 3: 120px scroll space from last services divider to testimonials  */
    .services {
      padding-top: 232px;
      padding-bottom: 120px;
    }

    /* Cancel the 768px rule that adds calc(2 × section-padding-y) above header */
    .services__header { margin-top: 0; }

    .services__category { display: none; }
    .services__title { flex-wrap: nowrap; font-size: 20px; }
    .services__beyond-img { height: 28px; top: 5.5px; }
    .services__mobile-gallery { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const VIEWER_W = 300;
  const VIEWER_H = 375;
  const SLIDE_DURATION = 0.55;
  const SLIDE_EASE     = 'power3.inOut';

  const section = document.querySelector<HTMLElement>('.services');
  const viewer  = document.getElementById('servicesViewer')  as HTMLElement | null;
  const strip   = document.getElementById('servicesStrip')   as HTMLElement | null;
  const items   = Array.from(document.querySelectorAll<HTMLElement>('.services__item'));

  // Only run on non-touch desktop
  const isTouch = window.matchMedia('(hover: none)').matches;
  if (!isTouch && section && viewer && strip && items.length) {

    // ── Fix 1: escape Lenis ──────────────────────────────────────────────────
    // Lenis smooth scroll works by applying transform to a wrapper ancestor.
    // CSS position:fixed inside a transformed ancestor is viewport-offset by
    // the scroll position, making the viewer appear far below the cursor.
    // Moving the viewer to <body> escapes all ancestor transforms.
    document.body.appendChild(viewer);

    let currentIndex = -1;
    let stripY = 0; // track GSAP's current Y on the strip

    // ── Mouse tracking: GSAP quickTo for butter-smooth follow ────────────────
    const xTo = gsap.quickTo(viewer, 'x', { duration: 0.55, ease: 'power3.out' });
    const yTo = gsap.quickTo(viewer, 'y', { duration: 0.55, ease: 'power3.out' });

    section.addEventListener('mousemove', (e) => {
      xTo(e.clientX - VIEWER_W / 2);
      yTo(e.clientY - VIEWER_H / 2);
    });

    items.forEach((item, i) => {
      item.addEventListener('mouseenter', (e) => {
        if (currentIndex === i) return;

        const targetY = -i * VIEWER_H;

        // Row rotation: even rows +5°, odd rows −5°
        const targetRotation = i % 2 === 0 ? 5 : -5;

        if (currentIndex === -1) {
          // ── First hover: snap strip + rotation instantly, then fade in ────
          gsap.set(strip, { y: targetY });
          stripY = targetY;

          // Snap viewer to cursor and correct rotation before fading in
          gsap.set(viewer, {
            x: (e as MouseEvent).clientX - VIEWER_W / 2,
            y: (e as MouseEvent).clientY - VIEWER_H / 2,
            rotation: targetRotation,
          });

          gsap.to(viewer, { opacity: 1, duration: 0.25, ease: 'power2.out' });
        } else {
          // ── Subsequent hover: animate strip + viewer rotation together ────
          gsap.to(strip, {
            y: targetY,
            duration: SLIDE_DURATION,
            ease: SLIDE_EASE,
          });
          gsap.to(viewer, {
            rotation: targetRotation,
            duration: SLIDE_DURATION,
            ease: SLIDE_EASE,
          });
          stripY = targetY;
        }

        currentIndex = i;
      });
    });

    // ── Leave section: fade out viewer, reset state for next entry ────────────
    section.addEventListener('mouseleave', () => {
      gsap.to(viewer, { opacity: 0, duration: 0.3, ease: 'power2.out' });
      // Reset immediately (not in onComplete) so fast re-entry snaps vs slides correctly
      currentIndex = -1;
    });
  }

  // ── Mobile tap-to-show image overlay (≤768px, touch devices) ─────────────
  // Each row has its own .services__row-image (position:absolute, pre-loaded).
  // pointer-events:none on the overlay — scroll and outside taps pass through.
  // The active row's z-index is raised to 5 so its image paints above siblings.
  if (isTouch && items.length) {
    const rowImages = Array.from(
      document.querySelectorAll<HTMLElement>('.services__row-image')
    );

    if (rowImages.length) {
      let activeIndex = -1;
      let switching   = false;

      function showForIndex(i: number) {
        rowImages[i].classList.add('is-visible');
        (items[i] as HTMLElement).style.zIndex = '5'; // rise above sibling rows
        activeIndex = i;
      }

      function hideTapViewer() {
        rowImages.forEach((img, i) => {
          img.classList.remove('is-visible');
          (items[i] as HTMLElement).style.zIndex = '';
        });
        activeIndex = -1;
        switching   = false;
      }

      items.forEach((item, i) => {
        item.addEventListener('click', (e) => {
          e.stopPropagation(); // prevent document dismiss listener from also firing

          if (switching) return;

          if (activeIndex === i) {
            // Same row tapped again — dismiss
            hideTapViewer();
          } else if (activeIndex === -1) {
            // Nothing visible — fade in
            showForIndex(i);
          } else {
            // Different row — fade out current, then fade in new
            switching = true;
            const prevIdx = activeIndex;
            rowImages[prevIdx].classList.remove('is-visible');
            (items[prevIdx] as HTMLElement).style.zIndex = '';
            activeIndex = -1;
            setTimeout(() => {
              if (switching) { showForIndex(i); switching = false; }
            }, 200); // matches the 0.25s fade-out, trimmed slightly for snappiness
          }
        });
      });

      // Tap anywhere outside a row → dismiss
      document.addEventListener('click', () => {
        if (activeIndex !== -1 && !switching) hideTapViewer();
      });
    }
  }

  // ── Scroll-linked body background + Testimonials reveal ─────────────────
  //
  // About, Services, and Testimonials all have transparent backgrounds so the
  // body's backgroundColor IS the full-viewport colour — no section seams.
  //
  // Entry  — body goes cream → #1c0e0e as Services enters (over 30% of vh).
  // Dwell  — body holds maroon while Services is the dominant section.
  // Exit   — body returns to cream once Testimonials reaches viewport midpoint
  //          (over 30% of vh). Keyed off Testimonials position, not Services bottom.
  //
  // Testimonials reveal — a maroon overlay covers all Testimonials content
  // while the body is still maroon (exitT == 0 → overlay opacity 1).
  // ── Scroll-linked body background, Services fade, Testimonials fade ─────
  //
  // Both sections have transparent backgrounds — body.backgroundColor IS
  // the full-viewport colour. Content in each section has its opacity driven
  // by the same t/exitT variables as the background, so nothing ever appears
  // on a background colour it doesn't match.
  //
  // Services  : opacity = t      (0 = cream bg, 1 = maroon bg)
  // Testimonials: opacity = exitT (0 = maroon phase, 1 = cream phase)
  //
  const bgEl    = document.querySelector<HTMLElement>('.services');
  const tElem   = document.querySelector<HTMLElement>('#testimonials');
  const stickyEl = tElem?.querySelector<HTMLElement>('.testimonials-sticky');

  // Pre-apply will-change so the browser promotes both to GPU layers
  if (stickyEl) stickyEl.style.willChange = 'opacity';

  if (bgEl) {
    const CREAM  = { r: 245, g: 240, b: 235 }; // #f5f0eb
    const MAROON = { r: 28,  g: 14,  b: 14  }; // #1c0e0e

    gsap.ticker.add(() => {
      const rect  = bgEl.getBoundingClientRect();
      const tRect = tElem?.getBoundingClientRect();
      const vh    = window.innerHeight;

      // Entry fade timing — scoped by breakpoint:
      // ≤768px: starts when Services is 50% into viewport, completes over 15% vh (snappy).
      // >768px:  starts when Services enters viewport bottom, completes over 30% vh (original).
      const isMobile = window.innerWidth <= 768;
      const entryT = isMobile
        ? gsap.utils.clamp(0, 1, (vh * 0.5 - rect.top) / (vh * 0.15))
        : gsap.utils.clamp(0, 1, (vh - rect.top) / (vh * 0.3));

      // Exit: delayed — starts when Testimonials top reaches the viewport midpoint
      // (tRect.top == vh*0.5), completes over 30% of viewport height.
      let exitT = 0;
      if (tRect) {
        exitT = gsap.utils.clamp(0, 1, (vh * 0.5 - tRect.top) / (vh * 0.3));
      } else {
        exitT = gsap.utils.clamp(0, 1, 1 - rect.bottom / (vh * 0.5));
      }

      const t = Math.max(0, entryT - exitT);

      // ── Body background ────────────────────────────────────────────────────
      const r = Math.round(CREAM.r + (MAROON.r - CREAM.r) * t);
      const g = Math.round(CREAM.g + (MAROON.g - CREAM.g) * t);
      const b = Math.round(CREAM.b + (MAROON.b - CREAM.b) * t);
      document.body.style.backgroundColor = `rgb(${r},${g},${b})`;

      // ── Services: fade with t ──────────────────────────────────────────────
      // t=0 (cream bg) → invisible; t=1 (maroon bg) → fully visible.
      // Works for both entry (t rising) and exit (t falling).
      bgEl.style.opacity = String(t);

      // ── Testimonials: fade with exitT ──────────────────────────────────────
      // exitT=0 (still maroon bg) → invisible; exitT=1 (back to cream) → visible.
      // Mirrors the services approach: content matches background, then fades in.
      if (stickyEl) stickyEl.style.opacity = String(exitT);
    });
  }
</script>
