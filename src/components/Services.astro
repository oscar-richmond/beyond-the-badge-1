---
const base = import.meta.env.BASE_URL + '/';
const services = [
  {
    number: '(01)',
    title: 'Influence',
    beyondText: 'expectation',
    category: 'PARTNERSHIPS',
    image: `${base}hover-1.jpg`,
  },
  {
    number: '(02)',
    title: 'Stories',
    beyondText: 'the playbook',
    category: 'STORYTELLING',
    image: `${base}hover-2.jpg`,
  },
  {
    number: '(03)',
    title: 'Connection',
    beyondText: 'the handshake',
    category: 'RELATIONSHIPS',
    image: `${base}hover-3.jpg`,
  },
  {
    number: '(04)',
    title: 'Sponsorship',
    beyondText: 'the signage',
    category: 'CULTURE',
    image: `${base}hover-4.jpg`,
  },
];

const VIEWER_W = 300;
const VIEWER_H = 375;
---

<section class="services" id="services">
  <div class="container">
    <div class="services__header">
      <h2 class="services__heading">Our approach</h2>
    </div>

    <div class="services__list">
      <hr class="services__divider" />
      {services.map((service, index) => (
        <>
          <div
            class="services__item reveal"
            data-index={String(index)}
            style={`transition-delay: ${index * 0.1}s;`}
          >
            <div class="services__item-left">
              <span class="services__number">{service.number}</span>
              <h3 class="services__title">
                {service.title}
                <img src={`${base}beyond-script.png`} alt="Beyond" class="services__beyond-img" />
                {service.beyondText}
              </h3>
            </div>
            <span class="services__category">{service.category}</span>
          </div>
          <hr class="services__divider" />
        </>
      ))}
    </div>
  </div>
</section>

<!--
  Persistent image viewer — lives outside the list flow.
  Follows the mouse via GSAP quickTo; strip slides to reveal the active row image.
-->
<div
  class="services__viewer"
  id="servicesViewer"
  aria-hidden="true"
  style={`--viewer-h: ${VIEWER_H}px;`}
>
  <div class="services__viewer-strip" id="servicesStrip">
    {services.map((service) => (
      <div class="services__viewer-item">
        <img src={service.image} alt="" loading="eager" draggable="false" />
      </div>
    ))}
  </div>
</div>

<style>
  /* ── Section ──────────────────────────────────────────────────────────── */
  .services {
    background-color: var(--color-dark-section);
    padding: var(--section-padding-y) 0;
    position: relative;
  }

  .services__header {
    margin-bottom: 8px;
  }

  .services__heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  /* ── List & rows ──────────────────────────────────────────────────────── */
  .services__list {
    margin-top: clamp(48px, 8vw, 120px);
  }

  .services__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 40px 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
    z-index: 1;
  }

  hr.services__divider {
    border: none;
    border-top: 1px solid #6E4142;
    margin: 0;
  }

  /* ── Row hover text colours ───────────────────────────────────────────── */
  .services__item-left {
    display: flex;
    align-items: center;
    gap: 24px;
    position: relative;
    z-index: 2;
  }

  .services__number {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 300;
    color: #6E4142;
    min-width: 32px;
    transition: color 0.4s ease;
  }

  .services__item:hover .services__number { color: #FFFFFF; }

  .services__title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 400;
    color: var(--color-cream);
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    letter-spacing: 0.05em;
    transition: color 0.4s ease;
    overflow: visible;
  }

  .services__item:hover .services__title { color: #6E4142; }

  .services__beyond-img {
    height: 51px;
    width: auto;
    display: inline-block;
    vertical-align: baseline;
    margin: -7.5px 0;
    position: relative;
    top: 8.5px;
    /* Same filter function list as the hover state, evaluated to white.
       Matching lists let CSS interpolate each function individually —
       no blue/purple flash from mismatched hue-rotate mid-transition. */
    filter: brightness(0) saturate(100%) invert(100%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(100%) contrast(100%);
    transition: filter 0.4s ease;
  }

  .services__item:hover .services__beyond-img {
    filter: brightness(0) saturate(100%) invert(24%) sepia(23%) saturate(1005%)
            hue-rotate(314deg) brightness(98%) contrast(92%);
  }

  .services__category {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #6E4142;
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.4s ease;
    position: relative;
    z-index: 2;
  }

  .services__item:hover .services__category { color: #FFFFFF; }

  /* ── Persistent image viewer ──────────────────────────────────────────── */
  /* Fixed to viewport so it can freely follow the cursor.
     All position is managed via GSAP x/y (translateX/Y).              */
  .services__viewer {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: var(--viewer-h, 375px);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    z-index: 90;
    will-change: transform, opacity;
    border-radius: 2px;
  }

  /* Strip — no CSS transition; GSAP drives all animation for reliability */
  .services__viewer-strip {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .services__viewer-item {
    width: 300px;
    height: var(--viewer-h, 375px);
    flex-shrink: 0;
    overflow: hidden;
  }

  .services__viewer-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .services__item {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 24px 0;
    }

    .services__item-left { gap: 14px; }

    .services__category {
      margin-left: 0;
      padding-left: 0;
    }

    .services__beyond-img { height: 37px; }

    /* Viewer disabled on mobile — touch has no hover */
    .services__viewer { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const VIEWER_W = 300;
  const VIEWER_H = 375;
  const SLIDE_DURATION = 0.55;
  const SLIDE_EASE     = 'power3.inOut';

  const section = document.querySelector<HTMLElement>('.services');
  const viewer  = document.getElementById('servicesViewer')  as HTMLElement | null;
  const strip   = document.getElementById('servicesStrip')   as HTMLElement | null;
  const items   = Array.from(document.querySelectorAll<HTMLElement>('.services__item'));

  // Only run on non-touch desktop
  const isTouch = window.matchMedia('(hover: none)').matches;
  if (!isTouch && section && viewer && strip && items.length) {

    // ── Fix 1: escape Lenis ──────────────────────────────────────────────────
    // Lenis smooth scroll works by applying transform to a wrapper ancestor.
    // CSS position:fixed inside a transformed ancestor is viewport-offset by
    // the scroll position, making the viewer appear far below the cursor.
    // Moving the viewer to <body> escapes all ancestor transforms.
    document.body.appendChild(viewer);

    let currentIndex = -1;
    let stripY = 0; // track GSAP's current Y on the strip

    // ── Mouse tracking: GSAP quickTo for butter-smooth follow ────────────────
    const xTo = gsap.quickTo(viewer, 'x', { duration: 0.55, ease: 'power3.out' });
    const yTo = gsap.quickTo(viewer, 'y', { duration: 0.55, ease: 'power3.out' });

    section.addEventListener('mousemove', (e) => {
      xTo(e.clientX - VIEWER_W / 2);
      yTo(e.clientY - VIEWER_H / 2);
    });

    items.forEach((item, i) => {
      item.addEventListener('mouseenter', (e) => {
        if (currentIndex === i) return;

        const targetY = -i * VIEWER_H;

        if (currentIndex === -1) {
          // ── First hover: snap strip instantly, then fade viewer in ──────────
          // Fix 2: Use gsap.set (not inline style + reflow trick) for instant snap.
          // The CSS-transition restore trick is unreliable; GSAP is deterministic.
          gsap.set(strip, { y: targetY });
          stripY = targetY;

          // Snap viewer position to cursor before fading in (no skate from 0,0)
          gsap.set(viewer, {
            x: (e as MouseEvent).clientX - VIEWER_W / 2,
            y: (e as MouseEvent).clientY - VIEWER_H / 2,
          });

          gsap.to(viewer, { opacity: 1, duration: 0.25, ease: 'power2.out' });
        } else {
          // ── Subsequent hover: animated slide to new row ──────────────────────
          gsap.to(strip, {
            y: targetY,
            duration: SLIDE_DURATION,
            ease: SLIDE_EASE,
          });
          stripY = targetY;
        }

        currentIndex = i;
      });
    });

    // ── Leave section: fade out viewer, reset state for next entry ────────────
    section.addEventListener('mouseleave', () => {
      gsap.to(viewer, { opacity: 0, duration: 0.3, ease: 'power2.out' });
      // Reset immediately (not in onComplete) so fast re-entry snaps vs slides correctly
      currentIndex = -1;
    });
  }
</script>
