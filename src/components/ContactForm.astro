---
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact__header">
      <span class="contact__tag">GET IN TOUCH</span>
      <h2 class="contact__heading">
        Let's build something<br />
        <em class="contact__heading-em">worth remembering.</em>
      </h2>
    </div>

    <div class="contact__body">
      <div class="contact__info">
        <p class="contact__subtext">
          We're selective about who we work with — and we think that's a good thing.
          If you believe in the power of culture to move people, let's talk.
        </p>
        <div class="contact__details">
          <a href="tel:+441234567890" class="contact__detail-link">
            <span class="contact__detail-label">Phone</span>
            <span class="contact__detail-value">+44 (0) 123 456 7890</span>
          </a>
          <a href="mailto:hello@beyondthebadge.co.uk" class="contact__detail-link">
            <span class="contact__detail-label">Email</span>
            <span class="contact__detail-value">hello@beyondthebadge.co.uk</span>
          </a>
        </div>
      </div>

      <form
        class="contact__form reveal--right"
        style="transition-delay: 0.15s;"
        action="mailto:hello@beyondthebadge.co.uk"
        method="POST"
        enctype="text/plain"
        id="contact-form"
        novalidate
      >
        <div class="contact__field-row">
          <div class="contact__field">
            <label for="contact-name" class="contact__label">Name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              class="contact__input"
              placeholder="Your name"
              required
            />
          </div>
          <div class="contact__field">
            <label for="contact-email" class="contact__label">Email</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              class="contact__input"
              placeholder="your@email.com"
              required
            />
          </div>
        </div>

        <div class="contact__field">
          <label for="contact-company" class="contact__label">Company / Brand</label>
          <input
            type="text"
            id="contact-company"
            name="company"
            class="contact__input"
            placeholder="Company name"
          />
        </div>

        <div class="contact__field">
          <label for="contact-message" class="contact__label">Message</label>
          <textarea
            id="contact-message"
            name="message"
            class="contact__input contact__textarea"
            placeholder="Tell us about your brand and what you're looking to achieve..."
            rows="5"
            required
          ></textarea>
        </div>

        <div class="contact__form-footer">
          <p class="contact__privacy">
            We'll only use your information to respond to your enquiry.
          </p>
          <button type="submit" class="contact__submit" id="contact-submit">
            <span class="contact__submit-text">Send message</span>
            <span class="contact__submit-arrow">→</span>
          </button>
        </div>

        <div class="contact__success" id="contact-success" aria-live="polite">
          <span class="contact__success-icon">✓</span>
          <p>Message sent — we'll be in touch shortly.</p>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-dark-maroon);
    padding: var(--section-padding-y) 0;
  }

  .contact__header {
    margin-bottom: 80px;
  }

  .contact__tag {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(232, 224, 212, 0.45);
    text-transform: uppercase;
    display: block;
    margin-bottom: 20px;
  }

  .contact__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    font-weight: 400;
    color: var(--color-cream);
    line-height: 1.08;
    overflow: visible;
  }

  /*
   * The line-reveal script wraps each line in .lr-clip { overflow: hidden }.
   * With line-height: 1.08, the clip box is too tight for the descenders on
   * 'g' in 'something' and 'remembering'. padding-bottom extends the boundary.
   */
  :global(.contact__heading .lr-clip) {
    padding-bottom: 0.22em;
  }

  .contact__heading-em {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "wght" 400, "HGHT" 1000;
    color: rgba(232, 224, 212, 0.6);
  }

  .contact__body {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(48px, 8vw, 120px);
    align-items: stretch;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .contact__subtext {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(232, 224, 212, 0.55);
    margin-bottom: 48px;
    max-width: 320px;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact__detail-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: opacity var(--transition-base);
  }

  .contact__detail-link:hover {
    opacity: 1;
  }

  .contact__detail-link:hover .contact__detail-value {
    color: var(--color-cream);
  }

  .contact__detail-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 224, 212, 0.35);
  }

  .contact__detail-value {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: rgba(232, 224, 212, 0.75);
    transition: color var(--transition-base);
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .contact__field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact__label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(232, 224, 212, 0.4);
  }

  .contact__input {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-cream);
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(232, 224, 212, 0.18);
    padding: 12px 0;
    outline: none;
    width: 100%;
    transition: border-color var(--transition-base);
    caret-color: var(--color-cream);
  }

  .contact__input::placeholder {
    color: rgba(232, 224, 212, 0.22);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .contact__input:focus {
    border-bottom-color: rgba(232, 224, 212, 0.55);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-serif);
    line-height: 1.6;
  }

  .contact__form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 12px;
    gap: 24px;
  }

  .contact__privacy {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: rgba(232, 224, 212, 0.3);
    line-height: 1.5;
    max-width: 220px;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-dark-maroon);
    background-color: var(--color-cream);
    border: none;
    padding: 14px 28px;
    cursor: pointer;
    transition: background-color var(--transition-base), transform var(--transition-base);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .contact__submit:hover {
    background-color: var(--color-cream-warm);
    transform: translateY(-1px);
  }

  .contact__submit-arrow {
    transition: transform var(--transition-base);
    display: inline-block;
  }

  .contact__submit:hover .contact__submit-arrow {
    transform: translateX(4px);
  }

  /* Success state */
  .contact__success {
    display: none;
    align-items: center;
    gap: 12px;
    color: var(--color-cream);
    font-family: var(--font-serif);
    font-size: 1rem;
    padding: 16px 0;
    border-top: 1px solid rgba(232, 224, 212, 0.15);
  }

  .contact__success.visible {
    display: flex;
  }

  .contact__success-icon {
    font-size: 1.1rem;
    color: #8CB7A0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .contact__body {
      grid-template-columns: 1fr 1.4fr;
    }
  }

  @media (max-width: 768px) {
    .contact__body {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .contact__field-row {
      grid-template-columns: 1fr;
    }

    .contact__form-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .contact__submit {
      width: 100%;
      justify-content: center;
    }

    .contact__subtext {
      max-width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('contact-success');

  // Simple client-side validation before mailto
  form?.addEventListener('submit', (e) => {
    const name = (document.getElementById('contact-name') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement)?.value.trim();
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement)?.value.trim();

    if (!name || !email || !message) {
      e.preventDefault();
      // Shake invalid fields
      [document.getElementById('contact-name'), document.getElementById('contact-email'), document.getElementById('contact-message')].forEach((el) => {
        if (el && !(el as HTMLInputElement).value.trim()) {
          el.style.borderBottomColor = '#916364';
          setTimeout(() => ((el as HTMLElement).style.borderBottomColor = ''), 2000);
        }
      });
      return;
    }

    // Show success after mailto opens
    setTimeout(() => {
      successMsg?.classList.add('visible');
      form?.reset();
    }, 500);
  });
</script>
