---
const marqueeItems = [
  "Brand Strategy",
  "Cultural Programming",
  "Purpose, Impact & Legacy",
  "Brand Partnerships",
  "Talent Integration",
  "Cinematic Product Integration",
  "Brand Experience",
  "Lifestyle Licensing",
  "Collections",
  "Network & Talent Introductions",
  "Content & Storytelling",
  "Community Building",
  "Trend & Cultural Intelligence",
];

const base = import.meta.env.BASE_URL;
---

<!--
  CTA: two distinct blocks —
  1. The image-over-marquee section (original appearance)
  2. A full-width bordered bar sitting underneath it
-->

<!-- ① Image over rolling text -->
<section class="cta" id="cta">
  <div class="cta__marquee-container" aria-hidden="true">
    <div class="cta__marquee">
      <div class="cta__marquee-track">
        {marqueeItems.map(item => <span class="cta__marquee-item">{item}</span>)}
        {marqueeItems.map(item => <span class="cta__marquee-item">{item}</span>)}
        {marqueeItems.map(item => <span class="cta__marquee-item">{item}</span>)}
      </div>
    </div>
  </div>

  <div class="cta__image-wrap reveal">
    <div class="cta__layer cta__layer--active" style={`background-image: url('${base}cta-slide-1.jpg')`}></div>
    <div class="cta__layer" style={`background-image: url('${base}cta-slide-2.jpg')`}></div>
    <div class="cta__layer" style={`background-image: url('${base}cta-slide-3.jpg')`}></div>
    <div class="cta__layer" style={`background-image: url('${base}cta-slide-4.jpg')`}></div>
    <div class="cta__layer" style={`background-image: url('${base}cta-slide-5.jpg')`}></div>
    <div class="cta__layer" style={`background-image: url('${base}cta-slide-6.jpg')`}></div>
  </div>
</section>

<!-- ② CTA bar — sits below the section, aligned to page margins -->
<div class="cta__bar-outer container">
  <a href={`${base}contact`} class="cta__bar">
    <p class="cta__bar-text">Let's build something together.</p>
    <span class="cta__bar-btn">
      <span class="cta__bar-btn-label">Get in touch</span>
      <svg class="cta__bar-btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</div>

<style>
  /* ── ① Section: image centred over scrolling marquee ─────────────────── */
  .cta {
    position: relative;
    background-color: var(--color-cream);
    padding-top: 53px; /* equalized: bar-outer adds 53px below section, so T must = 53px for symmetry */
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }

  /* Marquee — absolute, fills section, behind image */
  .cta__marquee-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    z-index: 0;
    margin-top: 32px; /* shifted down to align with vertical centre of the image */
  }

  .cta__marquee {
    width: 100%;
    overflow-x: clip;
    white-space: nowrap;
  }

  .cta__marquee-track {
    display: inline-flex;
    gap: 40px;
    animation: marquee 85s linear infinite;
  }

  .cta__marquee-item {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 700;
    color: var(--color-text-dark);
    line-height: 1;
    white-space: nowrap;
  }

  .cta__marquee-item::after {
    content: "•";
    margin-left: 40px;
    opacity: 0.3;
  }

  /* Image wrap — fixed size + clip, mirrors .about-images__photo */
  .cta__image-wrap {
    position: relative;
    z-index: 1;
    width: 280px;
    height: 350px;
    overflow: hidden;
    background-color: var(--color-cream); /* safety net: never see marquee through layers */
  }

  /* Layered image system — exact same pattern as About page keyword hover */
  .cta__layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity   0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .cta__layer--active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── ② Bar — sits below the section ───────────────────────────────────── */
  .cta__bar-outer {
    position: relative;
    z-index: 2;
    background-color: var(--color-cream);
    padding-bottom: 80px;
    margin-top: -112px;
    box-sizing: border-box;
  }

  /* ── Bar ─────────────────────────────────────────────────────────────── */
  .cta__bar {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 85px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 0 28px;
    border: 1px solid #D9D0C8;
    background: transparent;
    box-sizing: border-box;
    cursor: pointer;
    text-decoration: none;   /* strip <a> underline */
    color: inherit;          /* prevent browser link-colour shift on hover */
    /* Border transition on hover */
    transition: border-color 0.6s cubic-bezier(0.77, 0, 0.175, 1);
  }

  /* Sweep fill — expands left→right on hover */
  .cta__bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.65s cubic-bezier(0.77, 0, 0.175, 1);
    z-index: 0;
  }

  .cta__bar:hover {
    border-color: #052715;
    opacity: 1; /* cancel global a:hover { opacity: 0.8 } */
  }

  .cta__bar:hover::before {
    transform: scaleX(1);
  }

  /* ── Bar text ─────────────────────────────────────────────────────────── */
  .cta__bar-text {
    position: relative;
    z-index: 1;
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 200;
  font-variation-settings: "wght" 200;
    color: var(--color-forest);
    margin: 0;
    transition: color 0.45s cubic-bezier(0.77, 0, 0.175, 1) 0.1s;
  }

  .cta__bar:hover .cta__bar-text {
    color: var(--color-cream);
  }

  /* ── Button ───────────────────────────────────────────────────────────── */
  .cta__bar-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    height: calc(85px - 32px);
    margin: 16px 16px 16px 0;
    padding: 0 24px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-cream);
    background-color: #052715;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background-color 0.45s cubic-bezier(0.77, 0, 0.175, 1) 0.1s,
      border-color     0.45s cubic-bezier(0.77, 0, 0.175, 1) 0.1s,
      color            0.45s cubic-bezier(0.77, 0, 0.175, 1) 0.1s;
  }

  /* On bar hover: button inverts to outlined cream */
  .cta__bar:hover .cta__bar-btn {
    background-color: transparent;
    border-color: rgba(245, 240, 232, 0.55);
    color: var(--color-cream);
  }

  .cta__bar-btn-icon {
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0.15s;
  }

  .cta__bar:hover .cta__bar-btn-icon {
    transform: translateX(6px);
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(calc(-33.33% - 13.3px)); }
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .cta {
      /* Symmetry formula: padding-top = bar-outer extension below section.
         Extension = padding-bottom(80) + bar-height(85) - abs(margin-top).
         70px = 80 + 85 - 95. Increasing from 53px baseline gives more room
         between the image bottom and the CTA strip. */
      padding-top: 70px;
    }
    .cta__bar-outer {
      margin-top: -95px;  /* was -112px: less overlap = more gap above bar */
    }
    .cta__marquee-item {
      font-size: 45px;      /* 48px × 0.9375 */
    }
    .cta__bar-text {
      font-size: 1.6rem;    /* 1.7rem × 0.941 */
    }
    .cta__image-wrap {
      width:  252px;  /* 280px × 0.90 */
      height: 315px;  /* 350px × 0.90 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .cta {
      /* Symmetry check: padding-top(63) + abs(margin-top)(94) = 157
         = padding-bottom(72) + bar-height(85). Balanced ✓ */
      padding-top: 63px;  /* 70px × 0.90 */
    }
    .cta__bar-outer {
      margin-top:    -94px;  /* -95px × 0.90 → -85.5, adjusted to keep symmetry */
      padding-bottom: 72px;  /* 80px × 0.90 */
    }
    .cta__marquee-item {
      font-size: 42px;     /* 45px × 0.933 */
    }
    .cta__bar-text {
      font-size: 1.5rem;   /* 1.6rem × 0.9375 */
    }
    .cta__image-wrap {
      width:  227px;  /* 252px × 0.90 */
      height: 284px;  /* 315px × 0.90 */
    }
  }

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .cta {
      /* Symmetry: padding-top(57) + abs(margin-top)(93) = 150
         = padding-bottom(65) + bar-height(85). Balanced ✓ */
      padding-top: 57px;  /* 63px × 0.90 */
    }
    .cta__bar-outer {
      margin-top:    -93px;  /* adjusted to balance: 57 + 93 = 150 = 65 + 85 */
      padding-bottom: 65px;  /* 72px × 0.90 */
    }
    .cta__marquee-item {
      font-size: 39px;     /* 42px × 0.929 */
    }
    .cta__bar-text {
      font-size: 1.4rem;   /* 1.5rem × 0.933 */
    }
    .cta__image-wrap {
      width:  204px;  /* 227px × 0.90 */
      height: 256px;  /* 284px × 0.90 */
    }
  }

  /* ── 390px: stack CTA bar text above button ─────────────────────────── */
  @media (max-width: 390px) {
    /* Bar: switch to column so text sits above button */
    .cta__bar {
      flex-direction: column;
      align-items: flex-start;
      height: auto;          /* override fixed 85px */
      padding: 24px 20px;    /* uniform padding replaces the desktop 0 0 0 28px */
      gap: 20px;
    }

    .cta__bar-text {
      font-size: 1.4rem;     /* comfortable on 332px content width */
    }

    /* Button: full width, centred label, no inherited desktop margin */
    .cta__bar-btn {
      width: 100%;
      height: 52px;
      margin: 0;
      justify-content: center;
      box-sizing: border-box;
    }

    /* Bar-outer: ease off the negative overlap since bar is now taller */
    .cta__bar-outer {
      margin-top: -40px;
      padding-bottom: 40px;
    }
  }

  /* ── 430px: identical to 390px — covers iPhone Pro Max ──────────────── */
  @media (max-width: 450px) {
    .cta__bar {
      flex-direction: column;
      align-items: flex-start;
      height: auto;
      padding: 24px 20px;
      gap: 20px;
    }

    .cta__bar-text {
      font-size: 1.4rem;
    }

    .cta__bar-btn {
      width: 100%;
      height: 52px;
      margin: 0;
      justify-content: center;
      box-sizing: border-box;
    }

    .cta__bar-outer {
      margin-top: -40px;
      padding-bottom: 40px;
    }
  }
</style>

<script>
  const layers = Array.from(
    document.querySelectorAll<HTMLElement>('.cta__layer')
  );
  let current = 0;
  const TRANSITION_MS = 750; // must match CSS transition duration

  if (layers.length > 1) {
    setInterval(() => {
      const prev = layers[current];

      // Advance to next layer
      current = (current + 1) % layers.length;
      const next = layers[current];

      // Activate next — it fades IN on top of prev (which stays fully visible)
      next.classList.add('cta__layer--active');

      // Only deactivate prev AFTER the incoming transition is complete,
      // so there is never a gap where both layers are partially transparent
      setTimeout(() => {
        prev.classList.remove('cta__layer--active');
      }, TRANSITION_MS);
    }, 3000);
  }
</script>
