---
import processData from '../../content/process.json';

const processes = processData.items || [];
---

<section class="process section" id="process">
  <div class="process__watermark" aria-hidden="true">
    <img src={`${import.meta.env.BASE_URL}logo-monogram.png`} alt="" class="process__watermark-img" />
  </div>
  
  <div class="container">
    <div class="process__header">
      <h2 class="process__heading">
        What we do<br /><span class="process__heading-highlight">{processData.headingHighlight || 'Differently.'}</span>
      </h2>
      <p class="process__intro">
        {processData.intro || 'Four ways we help brands move beyond surface-level marketing into meaningful cultural participation.'}
      </p>
    </div>

    <div class="process__grid" data-reveal-group>
      {processes.map((process, index) => (
        <div
          class={`process__card reveal--scale`}
          style={`transition-delay: ${index * 0.12}s;`}
        >
          <span class="process__number">0{index + 1}</span>
          <h3 class="process__title">{process.title}</h3>
          <p class="process__text">{process.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    position: relative;
    z-index: 10;
    background-color: var(--color-cream);
    padding: var(--section-padding-y) 0;
    overflow: visible;
  }

  .process__watermark {
    position: absolute;
    top: calc(-10% + 8px);
    right: var(--section-padding-x, 5%);
    height: 120%;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .process__watermark-img {
    height: 100%;
    width: auto;
    opacity: 0.08;
    filter: invert(1);
  }

  .process__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    position: relative;
    z-index: 2;
  }

  .process__heading {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    color: var(--color-text-dark);
    line-height: 1.1;
    overflow: visible;
  }

  /*
   * The line-reveal script wraps each line in .lr-clip { overflow: hidden }.
   * That clips the italic descenders on 'Differently.' (the ff and y tails).
   * padding-bottom extends the clipping box downward so descenders are visible.
   * Uses :global because .lr-clip is injected by JS and has no Astro scope attr.
   */
  :global(.process__heading .lr-clip) {
    padding-bottom: 0.22em;
  }

  .process__heading-highlight {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "hght" 1000;
    color: #8CB7A0;
  }

  .process__intro {
    font-family: var(--font-script);
    font-style: italic;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 24px;
    color: var(--color-text-muted);
    max-width: 300px;
    text-align: right;
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    position: relative;
    z-index: 2;
  }

  .process__card {
    background-color: #edeae5;
    padding: 32px;
    border: none;
    display: flex;
    flex-direction: column;
    min-height: 280px;
    transition: background-color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__card:hover {
    background-color: var(--color-forest);
  }

  .process__card:hover .process__title,
  .process__card:hover .process__text,
  .process__card:hover .process__number {
    color: var(--color-cream);
  }

  .process__card:hover .process__text {
    opacity: 0.8;
  }

  .process__card:hover .process__number {
    opacity: 0.5;
  }

  .process__number {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    color: var(--color-text-dark);
    opacity: 0.5;
    margin-bottom: auto;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__title {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    margin-bottom: 12px;
    margin-top: 48px;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__text {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 1.7;
    color: #004f26;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  
  @media (max-width: 1024px) {

    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  

    .process__heading {
      font-size: clamp(27px, 4.3vw, 54px);  /* max 57px × 0.94 */
    }
    .process__header {
      margin-bottom: 47px;  /* 52px × 0.90 */
    }
    .process__card {
      padding: 22px;        /* 25px × 0.90 */
    }
    .process__title {
      font-size: 22px;      /* 23px × 0.94 */
      margin-top: 35px;     /* 39px × 0.90 */
    }
  
  }


  
  @media (max-width: 768px) {

    .process__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .process__intro {
      text-align: left;
    }

    .process__grid {
      grid-template-columns: 1fr;
    }
  
  }


  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  
  @media (max-width: 1440px) {

    .process__heading {
      font-size: clamp(34px, 4.7vw, 60px);  /* max 64 → 60px */
    }
    .process__header {
      margin-bottom: 58px;  /* 64px × 0.90 */
    }
    .process__card {
      padding: 28px;        /* 32px × 0.90 */
    }
    .process__title {
      font-size: 24px;      /* 26px × 0.923 */
      margin-top: 43px;     /* 48px × 0.90 */
    }
  
  }


  /* ── 1280px: proportional scale-down from 1440px ─── */
  
  @media (max-width: 1280px) {

    .process__heading {
      font-size: clamp(30px, 4.5vw, 57px);  /* max 60px × 0.94 */
    }
    .process__header {
      margin-bottom: 52px;  /* 58px × 0.90 */
    }
    .process__card {
      padding: 25px;        /* 28px × 0.90 */
    }
    .process__title {
      font-size: 23px;      /* 24px × 0.94 */
      margin-top: 39px;     /* 43px × 0.90 */
    }
  
  }


  /* ── 1024px: proportional scale-down from 1280px ─── */
  
</style>
