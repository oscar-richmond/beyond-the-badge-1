---
const processes = [
  {
    title: 'Shared Partnerships.',
    text: 'We don\'t just sell sponsorships, we broker relationships that build mutual value for brands and cultural spaces.'
  },
  {
    title: 'Culture First, always.',
    text: 'Authenticity isn\'t a buzzword for us. It is the starting point for every conversation, activation, and campaign.'
  },
  {
    title: 'Elevated Productions.',
    text: 'Curated experiences that transcend traditional marketing, creating lasting memories for your target audience.'
  },
  {
    title: 'End-to-End Delivery.',
    text: 'From initial strategy to final execution, we handle every detail so you can focus on the big picture.'
  }
];
---

<section class="process section" id="process">
  <div class="process__watermark" aria-hidden="true">
    <img src={`${import.meta.env.BASE_URL}/logo-monogram.png`} alt="" class="process__watermark-img" />
  </div>
  
  <div class="container">
    <div class="process__header reveal--left">
      <h2 class="process__heading">
        What we do<br /><span class="process__heading-highlight">Differently.</span>
      </h2>
      <p class="process__intro">
        Our approach is rooted in authentic relationships, not transactional exchanges.
      </p>
    </div>

    <div class="process__grid" data-reveal-group>
      {processes.map((process, index) => (
        <div
          class={`process__card reveal--scale`}
          style={`transition-delay: ${index * 0.12}s;`}
        >
          <span class="process__number">0{index + 1}</span>
          <h3 class="process__title">{process.title}</h3>
          <p class="process__text">{process.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    position: relative;
    z-index: 10;
    background-color: #ffffff;
    padding: var(--section-padding-y) 0;
    overflow: visible;
  }

  .process__watermark {
    position: absolute;
    top: calc(-10% + 8px);
    right: var(--section-padding-x, 5%);
    height: 120%;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .process__watermark-img {
    height: 100%;
    width: auto;
    opacity: 0.08;
    filter: invert(1);
  }

  .process__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    position: relative;
    z-index: 2;
  }

  .process__heading {
    font-family: var(--font-serif);
    font-size: 64px;
    font-weight: 500;
    color: var(--color-text-dark);
    line-height: 1.1;
  }

  .process__heading-highlight {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: "wght" 700, "HGHT" 1000;
    color: #8CB7A0;
  }

  .process__intro {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 24px;
    color: var(--color-text-muted);
    max-width: 300px;
    text-align: right;
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    position: relative;
    z-index: 2;
  }

  .process__card {
    background-color: #F7F7F7;
    padding: 32px;
    border: none;
    display: flex;
    flex-direction: column;
    min-height: 280px;
    transition: background-color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__card:hover {
    background-color: var(--color-forest);
  }

  .process__card:hover .process__title,
  .process__card:hover .process__text,
  .process__card:hover .process__number {
    color: var(--color-cream);
  }

  .process__card:hover .process__text {
    opacity: 0.8;
  }

  .process__card:hover .process__number {
    opacity: 0.5;
  }

  .process__number {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-dark);
    opacity: 0.5;
    margin-bottom: auto;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__title {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
    margin-bottom: 12px;
    margin-top: 48px;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__text {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 1.7;
    color: #004f26;
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 1024px) {
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .process__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .process__intro {
      text-align: left;
    }

    .process__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
