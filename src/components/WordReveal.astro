---
const paragraphs = [
  `We connect brands with the spaces where culture is created — art, sport, entertainment and community. Not to chase the moment, but to shape what comes next.`,
  `We build emotional resonance, not just recognition. Through bold partnerships, authentic storytelling, cultural programming, and meaningful conversations with talent and communities, we help brands earn their place in culture — not by playing the corporate playbook, but by showing up with purpose, humility, and a point of view.`,
  `Less logo. More legacy.`,
];
---

<!-- Outer scroll track: 400vh -->
<div class="wr-track" id="wr-track">
  <!-- Sticky inner display -->
  <div class="wr-stage">
    <div class="wr-content">
      {paragraphs.map((text, pi) => (
        <p class={`wr-paragraph${pi === 0 ? ' wr-paragraph--active' : ''}`} data-para={String(pi)}>
          {text.split(' ').map((word, wi) => (
            <span class="wr-word" data-para={String(pi)} data-word={String(wi)}>
              {word}{' '}
            </span>
          ))}
        </p>
      ))}
    </div>
  </div>
</div>

<style>
  /* ─── Outer track (scroll distance) ─── */
  .wr-track {
    height: 400vh;
    background-color: #f8f2ed;
    position: relative;
  }

  /* ─── Sticky display panel ─── */
  .wr-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f8f2ed;
    overflow: hidden;
  }

  /* ─── Text container ─── */
  .wr-content {
    position: relative;
    max-width: 820px;
    width: 100%;
    padding: 0 40px;
    text-align: center;
  }

  /* ─── Paragraph ─── */
  .wr-paragraph {
    position: absolute;
    inset: auto;
    left: 0;
    right: 0;
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 1.25;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    /* paragraph crossfade */
    transition: opacity 0.6s ease;
  }

  .wr-paragraph--active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  /* ─── Words start ghosted ─── */
  .wr-word {
    color: rgba(0, 0, 0, 0.12);
    transition: color 0.15s ease;
    display: inline;
  }

  /* ─── Mobile: disable pinning, show all paragraphs at full opacity ─── */
  @media (max-width: 768px) {
    .wr-track {
      height: auto;
    }

    .wr-stage {
      position: static;
      height: auto;
      padding: 80px 0;
    }

    .wr-content {
      position: static;
    }

    .wr-paragraph {
      position: static;
      opacity: 1 !important;
      pointer-events: auto;
      margin-bottom: 48px;
    }

    .wr-paragraph:last-child {
      margin-bottom: 0;
    }

    .wr-word {
      color: rgba(0, 0, 0, 0.85) !important;
    }
  }
</style>

<script>
  const track   = document.getElementById('wr-track') as HTMLElement;
  const paras   = Array.from(document.querySelectorAll<HTMLElement>('.wr-paragraph'));
  const N_PARAS = paras.length;

  // Pre-collect word spans per paragraph
  const wordsByPara: HTMLElement[][] = paras.map(p =>
    Array.from(p.querySelectorAll<HTMLElement>('.wr-word'))
  );

  let currentPara = 0;

  /* ── Activate paragraph (crossfade) ─────────────────────────────── */
  function switchPara(idx: number) {
    if (idx === currentPara) return;
    paras[currentPara].classList.remove('wr-paragraph--active');
    paras[idx].classList.add('wr-paragraph--active');
    currentPara = idx;
  }

  /* ── Reveal words in a paragraph based on local 0→1 progress ────── */
  function revealWords(paraIdx: number, localProgress: number) {
    const words  = wordsByPara[paraIdx];
    const N      = words.length;
    // Window size = 1.2 * slot width — creates ~20% overlap for a flowing feel
    const slot   = 1 / N;
    const window = slot * 1.2;

    words.forEach((word, i) => {
      const wordStart = (i / N);
      const local     = Math.max(0, Math.min(1, (localProgress - wordStart) / window));
      const alpha     = 0.12 + (0.85 - 0.12) * local;
      word.style.color = `rgba(0,0,0,${alpha.toFixed(3)})`;
    });
  }

  /* ── Reset paragraph words to a fixed state ─────────────────────── */
  function setParaAlpha(paraIdx: number, alpha: number) {
    const col = `rgba(0,0,0,${alpha})`;
    wordsByPara[paraIdx].forEach(w => { w.style.color = col; });
  }

  /* ── Main scroll handler ─────────────────────────────────────────── */
  function onScroll() {
    if (!track) return;

    const rect       = track.getBoundingClientRect();
    const trackH     = track.offsetHeight;       // 400vh
    const vh         = window.innerHeight;
    const totalTravel = trackH - vh;             // 300vh usable
    const scrolled   = -rect.top;

    // Clamp global progress 0→1
    const gp = Math.max(0, Math.min(1, scrolled / totalTravel));

    // Which paragraph segment?
    const paraIdx   = Math.min(N_PARAS - 1, Math.floor(gp * N_PARAS));
    // Local progress within that segment (0→1)
    const localProg = (gp * N_PARAS) - Math.floor(gp * N_PARAS);

    switchPara(paraIdx);

    // Reveal current paragraph words
    revealWords(paraIdx, localProg);

    // Past paragraphs: all fully revealed
    for (let i = 0; i < paraIdx; i++) setParaAlpha(i, 0.85);
    // Future paragraphs: all ghosted
    for (let i = paraIdx + 1; i < N_PARAS; i++) setParaAlpha(i, 0.12);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // initialise on load
</script>
