---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — Beyond the Badge"
  description="Get in touch with Beyond the Badge. We connect brands with the spaces where culture is created."
>
  <style is:global>
    /* ── Contact section → cream background + dark text ───────────────────── */
    body.page-contact .contact {
      background-color: var(--color-cream);
    }
    body.page-contact .contact__tag {
      color: rgba(5, 39, 21, 0.62); /* was 0.45 */
    }
    body.page-contact .contact__heading {
      color: #052715;
    }
    body.page-contact .contact__heading-em {
      color: rgba(5, 39, 21, 0.38);
    }
    body.page-contact .contact__subtext {
      color: rgba(5, 39, 21, 0.70); /* was 0.55 */
    }
    body.page-contact .contact__detail-label {
      color: rgba(5, 39, 21, 0.52); /* was 0.35 */
    }
    body.page-contact .contact__detail-value {
      color: rgba(5, 39, 21, 0.88); /* was 0.75 */
    }
    body.page-contact .contact__detail-link:hover .contact__detail-value {
      color: #052715 !important; /* beat Astro-scoped cream hover from ContactForm.astro */
    }
    body.page-contact .contact__label {
      color: rgba(5, 39, 21, 0.58); /* was 0.40 */
    }
    body.page-contact .contact__input {
      color: #052715;
      border-bottom-color: rgba(5, 39, 21, 0.58); /* was 0.40 */
      caret-color: #052715;
    }
    body.page-contact .contact__input::placeholder {
      color: #052715;
    }
    body.page-contact .contact__input:focus {
      border-bottom-color: rgba(5, 39, 21, 0.72); /* was 0.55 */
    }
    body.page-contact .contact__privacy {
      color: rgba(5, 39, 21, 0.46); /* was 0.30 */
    }
    body.page-contact .contact__required {
      color: rgba(28, 80, 52, 0.5);
    }
    body.page-contact .contact__submit {
      background-color: #052715;
      color: var(--color-cream);
    }
    body.page-contact .contact__submit:hover:not(:disabled) {
      background-color: #052715;
    }
    /* Success panel */
    body.page-contact .contact__success-headline {
      color: #052715;
    }
    body.page-contact .contact__success-sub {
      color: rgba(5, 39, 21, 0.5);
    }
    /* Input placeholder dark override */
    body.page-contact .contact__input::placeholder {
      color: rgba(5, 39, 21, 0.46); /* was 0.30 */
    }
    /* Send error on cream bg */
    body.page-contact .contact__send-error {
      border-top-color: rgba(145, 99, 100, 0.2);
    }

    /* ── Footer → forest-green background + cream text ───────────────────── */
    body.page-contact .footer {
      background-color: var(--color-forest);
    }
    body.page-contact .footer__bottom {
      border-top-color: rgba(245, 240, 232, 0.12);
    }
    body.page-contact .footer__watermark {
      filter: brightness(0) invert(1);
      opacity: 0.07 !important;
    }
    body.page-contact .footer__logo-img {
      filter: brightness(0) invert(1);
    }
    body.page-contact .footer__nav-link {
      color: rgba(245, 240, 232, 0.7);
    }
    body.page-contact .footer__nav-link:hover {
      opacity: 1;
      color: var(--color-cream);
    }
    body.page-contact .footer__legal span,
    body.page-contact .footer__legal-sep {
      color: rgba(245, 240, 232, 0.5);
    }

    /* ── Header → always dark links on this cream page ─────────────────── */
    body.page-contact .header__nav-link {
      color: #052715 !important;
    }
    /* at-top: keep transparent background (same as home/about) so the cream
       "expanding" header only appears after scrolling. Nav links, logo and
       hamburger are styled dark so they're readable on the cream background. */
    body.page-contact .header.at-top .header__nav-link {
      color: #052715 !important;
    }
    body.page-contact .header.at-top .header__logo-img {
      filter: brightness(0) saturate(100%) invert(10%) sepia(60%) saturate(1200%) hue-rotate(118deg) brightness(0.75);
    }
    body.page-contact .header.at-top .header__menu-line {
      background-color: #052715;
    }

    /* Contact page: cream border in default state, switches after fill retracts */
    body.page-contact .contact__submit {
      border-color: var(--color-cream);
      /* On hover-OUT: wait for cream fill to fully retract (0.55s) before border snaps to cream */
      transition:
        color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        letter-spacing 0.4s ease,
        border-color 0.01s ease 0.55s;
    }
    body.page-contact .contact__submit:hover:not(:disabled) {
      border-color: var(--color-dark-maroon);
      color: var(--color-dark-maroon);
      /* On hover-IN: border switches to dark-maroon immediately before fill arrives */
      transition:
        color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        letter-spacing 0.4s ease,
        border-color 0.01s ease 0s;
    }
  </style>

  <script>
    document.body.classList.add('page-contact');
  </script>

  <Header />

  <main>
    <ContactForm />
  </main>

  <Footer />
</BaseLayout>
