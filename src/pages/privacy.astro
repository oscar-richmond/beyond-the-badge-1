---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = 'April 2026';
---

<BaseLayout
  title="Privacy Policy — Beyond the Badge"
  description="Privacy policy for Beyond the Badge. Learn how we collect, use, and protect your personal information."
>
  <script>
    document.body.classList.add('page-legal');
  </script>

  <style is:global>
    /* ── Header: dark links on cream background ─────────────────────────── */
    .page-legal .header__nav-link,
    .page-legal .header.at-top .header__nav-link {
      color: #052715 !important;
    }
    .page-legal .header__logo-img,
    .page-legal .header:not(.at-top) .header__logo-img {
      filter: brightness(0) saturate(100%) invert(10%) sepia(60%) saturate(1200%) hue-rotate(118deg) brightness(0.75) !important;
    }
    .page-legal .header.at-top .header__logo-img {
      filter: brightness(0) saturate(100%) invert(10%) sepia(60%) saturate(1200%) hue-rotate(118deg) brightness(0.75) !important;
    }
    .page-legal .header__menu-line,
    .page-legal .header.at-top .header__menu-line {
      background-color: #052715 !important;
    }
  </style>

  <Header />

  <main class="legal-page">

    <!-- Hero -->
    <section class="legal-hero">
      <div class="legal-hero__inner">
        <div class="legal-hero__meta">
          <span class="legal-eyebrow">Legal</span>
          <span class="legal-updated">Last updated: {lastUpdated}</span>
        </div>
        <h1 class="legal-hero__title">Privacy<br />Policy</h1>
      </div>
      <hr class="legal-hero__rule" />
    </section>

    <!-- Intro statement -->
    <div class="legal-intro">
      <p>At Beyond The Badge, your privacy is important to us. This policy explains what personal data we collect, why we collect it, and how we use it. We are committed to handling your information with care and in compliance with applicable data protection law, including the UK GDPR.</p>
    </div>

    <!-- Body -->
    <article class="legal-body">

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">01</span>
          <h2 class="legal-section__heading">Who We Are</h2>
        </div>
        <div class="legal-section__content">
          <p>Beyond The Badge is a cultural brand partnership agency based in the United Kingdom. For the purposes of this privacy policy, we are the data controller responsible for your personal data.</p>
          <p>If you have any questions about this policy or your personal data, please contact us at <a href="mailto:hello@beyondthebadge.agency" class="legal-email">hello@beyondthebadge.agency</a>.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">02</span>
          <h2 class="legal-section__heading">Information We Collect</h2>
        </div>
        <div class="legal-section__content">
          <p>We may collect and process the following categories of personal data:</p>
          <p><strong>Information you provide directly</strong> — When you contact us through our website or by email, we collect your name, email address, and the content of your message.</p>
          <p><strong>Usage data</strong> — We may collect anonymised information about how you interact with our website, including pages visited, time spent on pages, and referring URLs. This data does not identify you personally.</p>
          <p><strong>Technical data</strong> — This includes your IP address, browser type and version, operating system, and device information, collected automatically when you visit our Site.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">03</span>
          <h2 class="legal-section__heading">How We Use Your Information</h2>
        </div>
        <div class="legal-section__content">
          <p>We use the information we collect for the following purposes:</p>
          <p><strong>To respond to your enquiries</strong> — When you contact us, we use your details to respond to your message and manage our relationship with you.</p>
          <p><strong>To improve our website</strong> — We use anonymised usage data to understand how visitors interact with our Site and to make improvements to content and user experience.</p>
          <p><strong>To comply with legal obligations</strong> — In certain circumstances we may be required to process your data to comply with applicable laws and regulations.</p>
          <p>We will not sell, rent, or otherwise share your personal data with third parties for marketing purposes.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">04</span>
          <h2 class="legal-section__heading">Legal Basis for Processing</h2>
        </div>
        <div class="legal-section__content">
          <p>Under UK GDPR, we process your personal data on the following legal bases:</p>
          <p><strong>Legitimate interests</strong> — When you make an enquiry, it is in our legitimate interest to respond and maintain business communications with you.</p>
          <p><strong>Consent</strong> — Where we process data for marketing or non-essential purposes, we will ask for your explicit consent beforehand.</p>
          <p><strong>Legal obligation</strong> — We may be required to process certain data to comply with our legal and regulatory responsibilities.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">05</span>
          <h2 class="legal-section__heading">Cookies</h2>
        </div>
        <div class="legal-section__content">
          <p>Our website may use cookies — small text files stored on your device — to enhance your browsing experience. We use only the cookies necessary to operate the Site effectively.</p>
          <p>You can control and manage cookies through your browser settings. Please note that disabling cookies may affect the functionality of certain parts of the Site. We do not use third-party advertising or tracking cookies.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">06</span>
          <h2 class="legal-section__heading">Sharing Your Data</h2>
        </div>
        <div class="legal-section__content">
          <p>We do not sell or trade your personal data. We may share your information in the following limited circumstances:</p>
          <p><strong>Service providers</strong> — We may share data with trusted third-party service providers who assist us in operating our website and business, subject to strict confidentiality agreements.</p>
          <p><strong>Legal requirements</strong> — We may disclose your data where required to do so by law, or in response to valid requests by public authorities.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">07</span>
          <h2 class="legal-section__heading">Your Rights</h2>
        </div>
        <div class="legal-section__content">
          <p>Under UK GDPR, you have the following rights in relation to your personal data:</p>
          <p><strong>The right to access</strong> — You may request a copy of the personal data we hold about you.</p>
          <p><strong>The right to rectification</strong> — You may ask us to correct inaccurate or incomplete data.</p>
          <p><strong>The right to erasure</strong> — You may request that we delete your personal data in certain circumstances.</p>
          <p><strong>The right to restrict processing</strong> — You may ask us to limit how we use your data.</p>
          <p><strong>The right to data portability</strong> — You may request a copy of your data in a structured, machine-readable format.</p>
          <p><strong>The right to object</strong> — You may object to processing based on our legitimate interests.</p>
          <p>To exercise any of these rights, please contact us at <a href="mailto:hello@beyondthebadge.agency" class="legal-email">hello@beyondthebadge.agency</a>. You also have the right to lodge a complaint with the Information Commissioner's Office (ICO) at <a href="https://ico.org.uk" target="_blank" rel="noopener noreferrer" class="legal-email">ico.org.uk</a>.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">08</span>
          <h2 class="legal-section__heading">Data Retention</h2>
        </div>
        <div class="legal-section__content">
          <p>We retain personal data only for as long as necessary to fulfil the purpose for which it was collected, or as required by applicable law. When your data is no longer needed, we will securely delete or anonymise it.</p>
          <p>Enquiry and contact data is generally retained for up to two years unless an ongoing relationship warrants a longer period.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">09</span>
          <h2 class="legal-section__heading">Changes to This Policy</h2>
        </div>
        <div class="legal-section__content">
          <p>We may update this Privacy Policy from time to time. The most current version will always be available on this page, along with the date it was last updated. We encourage you to review this policy periodically.</p>
        </div>
      </section>

      <hr />

      <section class="legal-section">
        <div class="legal-section__label">
          <span class="legal-section__num">10</span>
          <h2 class="legal-section__heading">Contact Us</h2>
        </div>
        <div class="legal-section__content">
          <p>If you have any questions, concerns, or requests regarding this Privacy Policy or our data practices, please reach out to us:</p>
          <p><a href="mailto:hello@beyondthebadge.agency" class="legal-email">hello@beyondthebadge.agency</a></p>
        </div>
      </section>

    </article>
  </main>

  <Footer cream />

</BaseLayout>

<style>
  /* ── Page base ──────────────────────────────────────────────────────── */
  .legal-page {
    background: var(--color-cream);
    min-height: 100vh;
  }

  /* ── Hero ───────────────────────────────────────────────────────────── */
  .legal-hero {
    padding: 160px var(--section-padding-x) 0;
  }

  .legal-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 32px;
    padding-bottom: 56px;
  }

  .legal-hero__meta {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }

  .legal-eyebrow {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #BBB1A7;
  }

  .legal-updated {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: #BBB1A7;
    white-space: nowrap;
  }

  .legal-hero__title {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-serif);
    font-size: clamp(52px, 7vw, 96px);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #052715;
    margin: 0;
  }

  .legal-hero__rule {
    border: none;
    border-top: 1px solid #D9D0C8;
    margin: 0;
  }

  /* ── Intro ──────────────────────────────────────────────────────────── */
  .legal-intro {
    padding: clamp(40px, 6vh, 72px) var(--section-padding-x);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .legal-intro p {
    font-family: var(--font-serif);
    font-size: clamp(18px, 1.6vw, 24px);
    line-height: 1.65;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #052715;
    max-width: 72ch;
    margin: 0;
  }

  /* ── Body ───────────────────────────────────────────────────────────── */
  .legal-body {
    padding: 0 var(--section-padding-x) clamp(80px, 12vh, 160px);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* Internal hr: section dividers */
  .legal-body hr {
    border: none;
    border-top: 1px solid #D9D0C8;
    margin: 0;
  }

  /* ── Section ────────────────────────────────────────────────────────── */
  .legal-section {
    display: grid;
    grid-template-columns: clamp(160px, 22%, 280px) 1fr;
    gap: 0 clamp(32px, 5vw, 72px);
    padding: clamp(40px, 6vh, 80px) 0;
  }

  .legal-section__label {
    padding-top: 4px;
  }

  .legal-section__num {
    display: block;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #BBB1A7;
    margin-bottom: 10px;
  }

  .legal-section__heading {
    font-family: var(--font-serif);
    font-size: clamp(18px, 1.6vw, 24px);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: #052715;
    margin: 0;
  }

  /* ── Body text ──────────────────────────────────────────────────────── */
  .legal-section__content p {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 16px;
    line-height: 1.75;
    font-weight: 400;
    color: rgba(5, 39, 21, 0.75);
    margin: 0 0 1.25em;
    max-width: 68ch;
  }

  .legal-section__content p:last-child {
    margin-bottom: 0;
  }

  .legal-section__content strong {
    font-weight: 600;
    color: rgba(5, 39, 21, 0.9);
  }

  /* ── Links ──────────────────────────────────────────────────────────── */
  .legal-email {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 16px;
    color: #052715;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(5, 39, 21, 0.3);
    transition: text-decoration-color 0.2s ease;
  }

  .legal-email:hover {
    opacity: 1;
    text-decoration-color: #052715;
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .legal-hero {
      padding-top: 110px;
    }

    .legal-hero__inner {
      grid-template-columns: 1fr;
      gap: 16px;
      padding-bottom: 40px;
    }

    .legal-hero__meta {
      grid-column: 1;
      grid-row: 2;
      align-items: flex-start;
      flex-direction: row;
      gap: 20px;
    }

    .legal-hero__title {
      grid-row: 1;
    }

    .legal-section {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: clamp(32px, 5vh, 56px) 0;
    }

    .legal-section__label {
      display: flex;
      align-items: baseline;
      gap: 12px;
    }

    .legal-section__num {
      margin-bottom: 0;
    }
  }
</style>
