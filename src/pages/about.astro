  }

  .about-bio__label {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #052715;
