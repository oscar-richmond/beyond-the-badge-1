---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import CTA from '../components/CTA.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About — Beyond the Badge"
  description="Learn about Beyond the Badge — the cultural brand partnership agency led by Laura Wood."
>
  <Header />
  <main class="about-page">

    <!-- 1. Hero -->
    <section class="about-hero">
      <h1 class="about-hero__text" data-reveal-delay="-0.4">
        We connect brands with the spaces where culture is created —
        <em data-keyword="art">art</em>,
        <em data-keyword="sport">sport</em>, <em data-keyword="film">film</em>, <em data-keyword="entertainment">entertainment</em>, <em data-keyword="adventure">adventure</em> and <em data-keyword="community">community</em>.
        Not to chase the moment, but to shape what comes next.
      </h1>
      <span class="about-hero__label">About Us</span>
    </section>

    <!-- 2. Image pair with caption -->
    <section class="about-images">
      <div class="about-images__cta-col">
        <a href="#contact" class="about-images__link"><span>Get in touch →</span></a>
      </div>
      <div class="about-images__photos-col" data-reveal-group>
        <div class="about-images__item reveal--scale" data-reveal-immediate>
          <span class="about-images__num">
            <span class="about-images__num-inner is-visible" data-state="default">(01)</span>
            <span class="about-images__num-inner" data-state="art">(03)</span>
            <span class="about-images__num-inner" data-state="sport">(05)</span>
            <span class="about-images__num-inner" data-state="film">(07)</span>
            <span class="about-images__num-inner" data-state="entertainment">(09)</span>
            <span class="about-images__num-inner" data-state="adventure">(11)</span>
            <span class="about-images__num-inner" data-state="community">(13)</span>
          </span>
          <div class="about-images__photo" id="about-photo-1">
            <div class="about-images__layer is-active" data-state="default"      style={`background-image: url('${base}about-1.jpg')`}></div>
            <div class="about-images__layer" data-state="art"           style={`background-image: url('${base}about-3.jpg')`}></div>
            <div class="about-images__layer" data-state="sport"         style={`background-image: url('${base}about-2.jpg')`}></div>
            <div class="about-images__layer" data-state="film"          style={`background-image: url('${base}about-2.jpg')`}></div>
            <div class="about-images__layer" data-state="entertainment" style={`background-image: url('${base}hero-bg.jpg')`}></div>
            <div class="about-images__layer" data-state="adventure"     style={`background-image: url('${base}about-3.jpg')`}></div>
            <div class="about-images__layer" data-state="community"     style={`background-image: url('${base}about-3.jpg')`}></div>
          </div>
        </div>
        <div class="about-images__item reveal--scale" data-reveal-immediate>
          <span class="about-images__num">
            <span class="about-images__num-inner is-visible" data-state="default">(02)</span>
            <span class="about-images__num-inner" data-state="art">(04)</span>
            <span class="about-images__num-inner" data-state="sport">(06)</span>
            <span class="about-images__num-inner" data-state="film">(08)</span>
            <span class="about-images__num-inner" data-state="entertainment">(10)</span>
            <span class="about-images__num-inner" data-state="adventure">(12)</span>
            <span class="about-images__num-inner" data-state="community">(14)</span>
          </span>
          <div class="about-images__photo" id="about-photo-2">
            <div class="about-images__layer is-active" data-state="default"      style={`background-image: url('${base}hero-bg.jpg')`}></div>
            <div class="about-images__layer" data-state="art"           style={`background-image: url('${base}about-2.jpg')`}></div>
            <div class="about-images__layer" data-state="sport"         style={`background-image: url('${base}about-3.jpg')`}></div>
            <div class="about-images__layer" data-state="film"          style={`background-image: url('${base}about-1.jpg')`}></div>
            <div class="about-images__layer" data-state="entertainment" style={`background-image: url('${base}about-2.jpg')`}></div>
            <div class="about-images__layer" data-state="adventure"     style={`background-image: url('${base}about-1.jpg')`}></div>
            <div class="about-images__layer" data-state="community"     style={`background-image: url('${base}about-1.jpg')`}></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Statement + tagline -->
    <section class="about-statement">
      <img class="about-statement__watermark" src={`${base}logo-monogram.png`} alt="" aria-hidden="true" />
      <div class="about-statement__inner">
        <p class="about-statement__text" data-reveal-delay="0.3">
          We build emotional resonance, not just recognition. Through bold partnerships,
          authentic storytelling, cultural programming, and meaningful conversations with
          talent and communities, we help brands earn their place in culture — not by
          playing the corporate playbook, but by showing up with purpose, humility, and
          a point of view.
        </p>
        <p class="about-statement__tagline">
          <span class="about-tagline-plain">Less logo.</span>
          <span class="about-tagline-rotating-wrapper" aria-live="polite">
            <span class="about-rotating-phrase">More legacy.</span>
            <span class="about-rotating-phrase">More Partnerships.</span>
            <span class="about-rotating-phrase">More Sponsorship.</span>
          </span>
        </p>
      </div>
    </section>

    <!-- 4. Four-image strip -->
    <section class="about-image-grid" data-reveal-group>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}about-1.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}about-2.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}hero-bg.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item about-image-grid__item--labeled reveal--scale">
        <span class="about-image-grid__index">(01)</span>
        <img src={`${base}about-3.jpg`} alt="" loading="lazy" />
      </div>
    </section>

    <!-- 5. Founder bio -->
    <section class="about-bio">
      <div class="about-bio__inner">
        <div class="about-bio__content">
          <h2 class="about-bio__headline">
            After 25 years at the intersection of luxury, culture, and communication,
            <em>Laura Wood</em> knows that a brand is not a <span style="white-space:nowrap">badge—it's</span> a feeling.
            Following a decade as Global Director at JLR, where she led a team of <span style="white-space:nowrap">70<sup>+</sup></span>
            to redefine brand experience &amp; culture.
          </h2>
          <p class="about-bio__body">
            She specializes in moving brands past surface-level marketing and into meaningful
            cultural participation. From managing £80M+ global budgets to curating world-class
            collaborations, her work is defined by one goal: helping brands stop marketing and
            start mattering.
          </p>
          <a href="#contact" class="about-bio__btn"><span>Read more +</span></a>
          <img
            class="about-bio__portrait"
            src={`${base}laura-portrait.png`}
            alt="Laura Wood"
            aria-hidden="true"
          />
        </div>
        <span class="about-bio__label">The Founder</span>
      </div>
    </section>

  </main>

  <ContactForm />
  <Footer />
</BaseLayout>

<!-- Global: active nav state + about-page header overrides -->
<style is:global>
  .header__nav-link--active {
    opacity: 1 !important;
    border-bottom: 1px solid currentColor;
  }

  /* ── About page: force logo + nav links to #052715 ── */
  /* Covers both at-top (transparent) and scrolled states */
  .page-about .header__logo-img,
  .page-about .header:not(.at-top) .header__logo-img {
    /* CSS filter approximating #052715 (very dark forest green) from a black source image */
    filter: brightness(0) saturate(100%) invert(10%) sepia(60%) saturate(1200%) hue-rotate(118deg) brightness(0.75) !important;
  }

  .page-about .header__nav-link,
  .page-about .header.at-top .header__nav-link {
    color: #052715 !important;
  }

  .page-about .header__menu-line,
  .page-about .header.at-top .header__menu-line {
    background-color: #052715 !important;
  }
</style>

<style>
  /* ── Base ─────────────────────────────────────────── */
  .about-page {
    background: var(--color-cream);
  }

  /* ── 1. Hero ──────────────────────────────────────── */
  .about-hero {
    padding: 160px var(--section-padding-x) 96px;
    background: var(--color-cream);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 32px;
  }

  .about-hero__label {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    align-self: start;
    margin-top: 8px;
    white-space: nowrap;
  }

  .about-hero__text {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw + 8px, 36px);
    line-height: clamp(28px, 3.2vw + 12px, 48px);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #1a3a2a;
    max-width: 952px;
    margin: 0;
  }

  .about-hero__text em {
    font-style: italic;
    font-weight: 500;
    text-decoration: underline dotted;
    text-underline-offset: 5px;
    text-decoration-thickness: 6%;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .about-hero__text em:hover {
    color: #8CB7A0;
    text-decoration-color: #8CB7A0;
    cursor: default;
  }

  /* ── 2. Image pair ────────────────────────────────── */
  .about-images {
    display: grid;
    grid-template-columns: 1fr 2fr;
    background: var(--color-cream);
    min-height: 600px;
  }

  .about-images__cta-col {
    display: flex;
    align-items: flex-end;
    padding: 60px var(--section-padding-x);
    padding-bottom: 68px;
  }

  .about-images__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    border: 1px solid #052715;
    padding: 12px 20px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.4s ease,
      letter-spacing 0.4s ease;
  }

  .about-images__link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .about-images__link span {
    position: relative;
    z-index: 2;
  }

  .about-images__link:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .about-images__link:hover {
    color: #f5f0e8;
    transform: translateX(3px);
    letter-spacing: 0.11em;
    border-color: #052715;
  }

  .about-images__photos-col {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 16px;
    padding: 60px 40px 60px 0;
  }

  .about-images__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-images__num {
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #004f26;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
    overflow: hidden;
    height: 1.25em;
    vertical-align: bottom;
  }

  .about-images__num-inner {
    position: absolute;
    top: 0;
    left: 0;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(110%);
    transition:
      opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .about-images__num-inner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* exiting state — slides up */
  .about-images__num-inner.is-exiting {
    opacity: 0;
    transform: translateY(-110%);
    transition:
      opacity 0.4s cubic-bezier(0.55, 0, 1, 0.45),
      transform 0.4s cubic-bezier(0.55, 0, 1, 0.45);
  }

  .about-images__photo {
    position: relative;
    width: 100%;
    height: 440px;
    overflow: hidden;
  }

  /* Layered image system for keyword hover */
  .about-images__layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .about-images__layer.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── 3. Statement ─────────────────────────────────── */
  .about-statement {
    position: relative;
    padding: 120px var(--section-padding-x) 180px;
    background: var(--color-cream);
  }

  .about-statement__watermark {
    position: absolute;
    right: var(--section-padding-x);
    top: 16px;
    width: 1135px;
    height: auto;
    opacity: 0.04;
    filter: invert(1) sepia(1) saturate(2) hue-rotate(90deg) brightness(0.2);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .about-statement__inner {
    position: relative;
    z-index: 1;
    max-width: 952px;
  }

  .about-statement__text {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 32px;
    font-weight: 400;
    letter-spacing: 0;
    color: #1a3a2a;
    margin: 0 0 120px;
    max-width: 952px;
  }

  .about-statement__tagline {
    margin: 0;
    font-size: 36px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 0;
  }

  .about-tagline-plain {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 500;
    color: #1a3a2a;
  }

  /* Rotating wrapper — fixed height so layout never shifts */
  .about-tagline-rotating-wrapper {
    position: relative;
    display: inline-block;
    height: 1.25em;
    min-width: 1px;
    overflow: visible;
    vertical-align: baseline;
    top: 9px;
  }

  .about-rotating-phrase {
    position: absolute;
    left: 7px;
    top: calc(50% - 2px);
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: "wght" 500, "HGHT" 1000;
    color: #8CB7A0;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(calc(-50% + 10px));
  }

  /* ── 4. Image strip ───────────────────────────────── */
  /* ── 4. Image grid ────────────────────────────────── */
  .about-image-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr 1fr;
    gap: 16px;
    padding: 64px var(--section-padding-x);
    /* No background — cream comes from .about-page so watermark shows through */
    /* No position:relative — (01) label is relative to its own item */
  }

  .about-image-grid__item {
    height: 440px;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .about-image-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Last item: label floats 16px above, left-aligned to the image */
  .about-image-grid__item--labeled {
    position: relative;
    overflow: visible; /* allow label to show above the image */
  }

  .about-image-grid__item--labeled img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-image-grid__index {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 0;
    font-family: 'Awesome Serif VAR', var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #004f26;
  }

  /* Image grid responsive */
  @media (max-width: 900px) {
    .about-image-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .about-image-grid__item {
      height: 280px;
    }

    /* 3rd item spans both columns to keep the 2x feel */
    .about-image-grid__item:nth-child(4) {
      grid-column: 1 / -1;
      height: 320px;
    }
  }

  @media (max-width: 480px) {
    .about-image-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .about-image-grid__item {
      height: 260px;
    }

    .about-image-grid__item:nth-child(4) {
      grid-column: auto;
      height: 260px;
    }
  }

  /* ── 5. Founder bio ───────────────────────────────── */
  .about-bio {
    padding: 120px var(--section-padding-x);
    background: var(--color-cream);
  }

  .about-bio__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 64px;
  }

  .about-bio__content {
    max-width: 952px;
    position: relative;
  }

  .about-bio__portrait {
    position: absolute;
    left: calc(100% + 192px);
    top: 140px;
    width: 312px;
    height: auto;
    transform: rotate(5deg) translateY(20px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
    z-index: 10;
  }

  .about-bio__portrait.is-visible {
    opacity: 1;
    transform: rotate(5deg) translateY(0) scale(1);
  }

  .about-bio__headline {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw + 8px, 36px);
    line-height: clamp(28px, 3.2vw + 12px, 48px);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #1a3a2a;
    margin: 0 0 64px;
    max-width: 952px;
    text-wrap: pretty;
    hyphens: none;
  }

  .about-bio__headline em {
    font-style: italic;
    font-weight: 500;
    text-decoration: underline dotted;
    text-underline-offset: 5px;
    text-decoration-thickness: 6%;
    color: #052715;
    text-decoration-color: #052715;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
    /* Spacing survives the line-reveal DOM rewrite; &nbsp; entities do not */
    padding-right: 0.21em;
  }

  .about-bio__headline em:hover {
    color: #8CB7A0;
    text-decoration-color: #8CB7A0;
    cursor: default;
  }

  .about-bio__headline sup {
    font-family: 'Inter', var(--font-sans);
    font-size: 0.55em;
    font-weight: 600;
    vertical-align: super;
    line-height: 0;
  }

  .about-bio__body {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 32px;
    font-weight: 400;
    letter-spacing: 0;
    color: #1a3a2a;
    margin: 0;
    max-width: 952px;
  }

  .about-bio__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    border: 1px solid #052715;
    padding: 12px 24px;
    margin-top: 48px;
    margin-bottom: 180px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.4s ease,
      letter-spacing 0.4s ease;
  }

  .about-bio__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .about-bio__btn span {
    position: relative;
    z-index: 2;
  }

  .about-bio__btn:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .about-bio__btn:hover {
    color: #f5f0e8;
    transform: translateX(3px);
    border-color: #052715;
    letter-spacing: 0.11em;
  }

  .about-bio__label {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    white-space: nowrap;
  }

  /* ── Responsive: Tablet 768px ─────────────────────── */
  @media (max-width: 900px) {
    .about-images {
      grid-template-columns: 1fr;
    }

    .about-images__cta-col {
      padding: 40px var(--section-padding-x) 0;
      align-items: flex-start;
    }

    .about-images__photos-col {
      padding: 40px var(--section-padding-x);
      grid-template-columns: 1.4fr 1fr;
    }

    .about-images__photo {
      min-height: 320px;
    }


  }

  /* ── Responsive: Mobile 480px ─────────────────────── */
  @media (max-width: 480px) {
    .about-hero {
      padding-top: 110px;
      padding-bottom: 60px;
      grid-template-columns: 1fr;
    }

    .about-hero__label {
      grid-row: 2;
      grid-column: 1;
      margin-top: 16px;
    }

    .about-images__photos-col {
      grid-template-columns: 1fr;
    }

    .about-images__photo {
      min-height: 260px;
    }

    .about-statement {
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .about-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-strip__photo {
      height: 180px;
    }

    .about-bio {
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .about-bio__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-bio__label {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }

  /* ── Responsive: Tablet range 481-900px ───────────── */
  @media (min-width: 481px) and (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr auto;
    }

    .about-bio__inner {
      grid-template-columns: 1fr auto;
    }

    .about-bio__headline {
      font-size: clamp(20px, 3vw, 28px);
    }
  }

  /* ── Wide screen clamp ────────────────────────────── */
  @media (min-width: 1600px) {
    .about-hero,
    .about-images__cta-col,
    .about-statement,
    .about-image-grid,
    .about-bio {
      padding-left: calc((100vw - var(--content-max-width)) / 2 + 40px);
      padding-right: calc((100vw - var(--content-max-width)) / 2 + 40px);
    }

    .about-statement__watermark {
      right: calc((100vw - var(--content-max-width)) / 2 + 40px);
    }

    .about-images__photos-col {
      padding-right: calc((100vw - var(--content-max-width)) / 2 + 40px);
    }
  }
</style>

<script>
  // Mark the About nav link as active
  document.querySelectorAll<HTMLAnchorElement>('.header__nav-link, .mobile-nav__link').forEach(link => {
    if (link.textContent?.trim() === 'About') {
      link.classList.add('header__nav-link--active');
    }
  });

  // Add body class so about-page header overrides are scoped correctly
  document.body.classList.add('page-about');

  // Rotating tagline — same logic as home hero
  const aboutPhrases = Array.from(
    document.querySelectorAll<HTMLElement>('.about-rotating-phrase')
  );
  const aboutWrapper = document.querySelector<HTMLElement>('.about-tagline-rotating-wrapper');

  if (aboutPhrases.length && aboutWrapper) {
    // Size wrapper to widest phrase so layout stays stable
    const maxWidth = Math.max(...aboutPhrases.map(p => p.offsetWidth));
    aboutWrapper.style.width = `${maxWidth}px`;

    let current = 0;

    function showPhrase(el: HTMLElement) {
      el.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
      el.style.opacity = '1';
      el.style.transform = 'translateY(-50%)';
    }

    function exitPhrase(el: HTMLElement) {
      el.style.transition = 'opacity 0.5s ease-in, transform 0.5s ease-in';
      el.style.opacity = '0';
      el.style.transform = 'translateY(calc(-50% - 10px))';
    }

    function resetPhrase(el: HTMLElement) {
      el.style.transition = 'none';
      el.style.opacity = '0';
      el.style.transform = 'translateY(calc(-50% + 10px))';
    }

    // Show first phrase immediately
    showPhrase(aboutPhrases[0]);

    function cycle() {
      const outEl = aboutPhrases[current];
      const nextIdx = (current + 1) % aboutPhrases.length;
      const inEl = aboutPhrases[nextIdx];

      exitPhrase(outEl);
      setTimeout(() => showPhrase(inEl), 100);
      setTimeout(() => resetPhrase(outEl), 600);

      current = nextIdx;
    }

    // Hold 2.5s, then cycle every 3.3s
    setTimeout(() => {
      cycle();
      setInterval(cycle, 3300);
    }, 2500);
  }

  // ── Keyword → image + number swap ─────────────────────────────────────
  // Use event delegation on the stable h1 parent — NOT direct listeners on
  // em nodes. The BaseLayout line-reveal script may rewrite em nodes after
  // document.fonts.ready, which would destroy any directly-attached listeners.
  const heroText       = document.querySelector<HTMLElement>('.about-hero__text');
  const photoContainers = document.querySelectorAll<HTMLElement>('.about-images__photo');
  const numContainers  = document.querySelectorAll<HTMLElement>('.about-images__num');

  function swapToKeyword(keyword: string) {
    photoContainers.forEach(photo => {
      photo.querySelectorAll<HTMLElement>('.about-images__layer').forEach(layer => {
        if (layer.dataset.state === 'default') layer.classList.remove('is-active');
        else if (layer.dataset.state === keyword) layer.classList.add('is-active');
      });
    });
    numContainers.forEach(num => {
      const current = num.querySelector<HTMLElement>('.about-images__num-inner.is-visible');
      const next    = num.querySelector<HTMLElement>(`.about-images__num-inner[data-state="${keyword}"]`);
      if (current) { current.classList.remove('is-visible'); current.classList.add('is-exiting'); }
      if (next)    { next.classList.add('is-visible'); }
      if (current) current.addEventListener('transitionend', () => current.classList.remove('is-exiting'), { once: true });
    });
  }

  function resetToDefault() {
    photoContainers.forEach(photo => {
      photo.querySelectorAll<HTMLElement>('.about-images__layer').forEach(layer => {
        if (layer.dataset.state === 'default') layer.classList.add('is-active');
        else layer.classList.remove('is-active');
      });
    });
    numContainers.forEach(num => {
      const current = num.querySelector<HTMLElement>('.about-images__num-inner.is-visible');
      const dflt    = num.querySelector<HTMLElement>('.about-images__num-inner[data-state="default"]');
      if (current && current !== dflt) { current.classList.remove('is-visible'); current.classList.add('is-exiting'); }
      if (dflt && !dflt.classList.contains('is-visible')) { dflt.classList.add('is-visible'); }
      if (current && current !== dflt) current.addEventListener('transitionend', () => current.classList.remove('is-exiting'), { once: true });
    });
  }

  // Delegated: listen on the h1, check if the event target is a keyword em
  if (heroText) {
    heroText.addEventListener('mouseover', (e) => {
      const em = (e.target as Element).closest<HTMLElement>('em[data-keyword]');
      if (em && heroText.contains(em)) swapToKeyword(em.dataset.keyword!);
    });
    heroText.addEventListener('mouseout', (e) => {
      const em = (e.target as Element).closest<HTMLElement>('em[data-keyword]');
      // Only reset when leaving a keyword em (not moving between child nodes of it)
      if (em && !em.contains(e.relatedTarget as Node)) resetToDefault();
    });
  }

  // ── Laura Wood portrait reveal ──────────────────────────────────────────
  // Delegate on the bio content wrapper for the same reason
  const bioContent = document.querySelector<HTMLElement>('.about-bio__content');
  const portrait   = document.querySelector<HTMLElement>('.about-bio__portrait');

  if (bioContent && portrait) {
    bioContent.addEventListener('mouseover', (e) => {
      if ((e.target as Element).closest('.about-bio__headline em')) {
        portrait.classList.add('is-visible');
      }
    });
    bioContent.addEventListener('mouseout', (e) => {
      const em = (e.target as Element).closest('.about-bio__headline em');
      if (em && !em.contains(e.relatedTarget as Node)) {
        portrait.classList.remove('is-visible');
      }
    });
  }
</script>


