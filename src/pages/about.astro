---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — Beyond the Badge"
  description="Learn about Beyond the Badge — the cultural brand partnership agency led by Laura Wood."
>
  <Header />
  <main class="about-page">
    <section class="about-hero">
      <span class="about-hero__label">About Us</span>
      <h1 class="about-hero__text">
        We connect brands with the spaces where culture is created —
        <em>art, sport, entertainment</em> and <em>community</em>.
        Not to chase the moment, but to shape what comes next.
      </h1>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .header__nav-link--active {
    opacity: 1 !important;
    border-bottom: 1px solid currentColor;
  }
</style>

<style>
  .about-page {
    padding-top: 0;
  }

  .about-hero {
    padding: 160px 48px 100px;
    background: #ffffff;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 24px;
    border-bottom: 1px solid rgba(0,79,38,0.15);
  }

  .about-hero__label {
    grid-column: 2;
    grid-row: 1;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #004f26;
    align-self: start;
    margin-top: 6px;
  }

  .about-hero__text {
    grid-column: 1;
    grid-row: 1;
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 1.2;
    color: #004f26;
    font-weight: 400;
    max-width: 55vw;
    margin: 0;
  }

  .about-hero__text em {
    font-style: italic;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>

<script>
  // Mark the "About" nav link as active on this page
  document.querySelectorAll<HTMLAnchorElement>('.header__nav-link, .mobile-nav__link').forEach(link => {
    if (link.textContent?.trim() === 'About') {
      link.classList.add('header__nav-link--active');
    }
  });
</script>
