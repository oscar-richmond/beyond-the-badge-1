  }

  /* Text is always fully visible — the grid expansion does the revealing */
  .about-bio__expand-para .bio-inner {
    display: block;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 18px;
    line-height: 32px;
    font-weight: 400;
    letter-spacing: 0;
    color: #052715;
  }

  /* ── 1440px: proportional scale-down from 1522px baseline ─── */
  @media (max-width: 1440px) {
    .about-hero__text {
      font-size: clamp(19px, 2.3vw + 7px, 34px);  /* max 36 → 34px */
    }
    .about-statement__tagline {
      font-size: 34px;   /* 36px × 0.944 */
    }
    .about-bio__headline {
      font-size: clamp(19px, 2.3vw + 7px, 34px);  /* max 36 → 34px */
    }
    .about-images__cta-col {
      padding-bottom: 61px;  /* 68px × 0.90 */
    }
    .about-bio__inner {
      gap: 58px;   /* 64px × 0.90 */
    }
    .about-images__photo {
      height: 396px;  /* 440px × 0.90 */
    }
    .about-bio__portrait {
      /* Target: visual right edge = 1404px (page's standard 36px right margin).
         DevTools confirmed: .about-bio__content width = 952px, left = 36px from viewport.
         5° rotation adds ~14.5px to the rendered right bound.
         CSS right = 1404 − 14.5 = 1389.5px from viewport.
         left = 1389.5 − 36 (padding) − 288 (width) = 1065.5px ≈ calc(100% + 113px) */
      width: 288px;
      left: calc(100% + 113px);
      right: auto;
      top: 140px;
    }
    .about-statement__watermark {
      width: 1022px;  /* 1135px × 0.90 */
    }
  }

  /* ── 1280px: proportional scale-down from 1440px ─── */
  @media (max-width: 1280px) {
    .about-hero__text {
      font-size: clamp(18px, 2.2vw + 6px, 32px);  /* max 34 → 32px */
    }
    .about-statement__tagline {
      font-size: 32px;   /* 34px × 0.941 */
    }
    .about-bio__headline {
      font-size: clamp(18px, 2.2vw + 6px, 32px);  /* max 34 → 32px */
    }
    .about-images__cta-col {
      padding-bottom: 55px;  /* 61px × 0.90 */
    }
    .about-bio__inner {
      gap: 52px;   /* 58px × 0.90 */
    }
    .about-images__photo {
      height: 356px;  /* 396px × 0.90 */
    }
    .about-bio__portrait {
      /* Target: visual right edge = 1248px (1280 − 32px right margin).
         .about-bio__content = 952px wide, left = 32px from viewport.
         5° rotation adds ~13px. CSS right = 1235px.
         left = 1235 − 32 − 259 = 944px from content = calc(100% − 8px) */
      width: 259px;   /* 288px × 0.90 */
      left: calc(100% - 8px);
    }
    .about-statement__watermark {
      width: 920px;  /* 1022px × 0.90 */
    }
  }  /* 1022px × 0.90 */

  /* ── 1024px: proportional scale-down from 1280px ─── */
  @media (max-width: 1024px) {
    .about-hero__text {
      font-size: clamp(17px, 2.1vw + 5px, 30px);  /* max 32 → 30px (−6.25%) */
      max-width: 762px;  /* 952px × 4/5 — text column narrowed by 1/5th */
    }
    .about-statement__tagline {
      font-size: 30px;   /* 32px × 0.94 */
    }
    .about-bio__headline {
      font-size: clamp(17px, 2.1vw + 5px, 30px);  /* max 32 → 30px */
      max-width: 762px;  /* 952px × 4/5 — text column narrowed by 1/5th */
    }
    /* Bio body + expandable: narrow text column, .about-bio__content stays at 952px
       so the portrait left calc (which uses 100% of the content) remains correct. */
    .about-bio__body,
    .about-bio__expand {
      max-width: 762px;  /* 952px × 4/5 */
    }
    .about-images {
      min-height: 0;  /* base 600px forces section taller than photos — remove so CTA aligns with photo bottom */
    }
    .about-images__cta-col {
      padding-bottom: 60px;  /* matches photos-col padding-bottom — aligns button bottom with photo bottom */
    }
    .about-bio__inner {
      gap: 47px;   /* 52px × 0.90 */
    }
    .about-images__photo {
      height: 280px;  /* 320px → 280px: restores 1440px portrait ratio on narrower 1024px columns */
    }
    .about-bio__portrait {
      /* 100vw-based so position is viewport-relative — independent of how wide
         the 1fr grid cell actually is (.about-bio__content is narrower than
         952px at 1024px because the auto "The Founder" column eats into the row).
         100vw − right-margin(29px) − width(233px) − 5°-rotation(13px) − left-padding(29px) */
      width: 233px;
      left: calc(100vw - 304px);
    }
    .about-statement__watermark {
      width: 828px;  /* 920px × 0.90 */
    }
    /* Four-image strip: had no prior scaling (still 440px at 1024px). At 1024px
       the 1fr cols are ~184px wide. Matching 1440px ratio (440/264 = 1.67):
       184 × 1.67 ≈ 307px. */
    .about-image-grid__item {
      height: 307px;  /* 440px baseline scaled to match 1440px portrait ratio */
    }
    }

  /* ── Responsive: ≤768px ─────────────────────────────────────────── */
  @media (max-width: 768px) {

    /* --- Small titles above paragraphs, 16px gap --- */

    /* Hero: collapse grid to flex-column so label can be reordered above h1 */
    .about-hero {
      display: flex;
      flex-direction: column;
      gap: 0;             /* base has gap:32px — zero it so only label margin controls spacing */
    }

    .about-hero__label {
      order: -1;          /* lift "About Us" above the paragraph */
      margin-bottom: 16px;
      margin-top: 0;
    }

    /* Bio: collapse grid to flex-column so label can be reordered above content */
    .about-bio__inner {
      display: flex;
      flex-direction: column;
      gap: 0;             /* base has gap:64px — zero it so only label margin controls spacing */
    }

    .about-bio__label {
      order: -1;          /* lift "The Founder" above the headline */
      margin-bottom: 16px;
    }

    /* --- Full-width body text — remove max-width caps --- */
    .about-hero__text {
      max-width: none;
      font-size: 30px;    /* from previous request */
      line-height: 1.5;
    }

    .about-bio__content  { max-width: none; }
    .about-bio__headline {
      max-width: none;
      font-size: 30px;    /* from previous request */
      line-height: 1.5;
    }
    .about-bio__body         { max-width: none; }
    .about-statement__inner  { max-width: none; }
    .about-statement__text   { max-width: none; }
    /* Keywords are tappable on mobile */
    .about-hero__text em[data-keyword] {
      cursor: pointer;
    }

    /* --- Image grid: 2×2 — bring 4th image into the same row --- */
    .about-image-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    /* All 4 items uniform height */
    .about-image-grid__item {
      height: 180px;
    }

    /* Remove the full-width span set by the ≤900px block */
    .about-image-grid__item:nth-child(4) {
      grid-column: auto;
      height: 180px;
    }
  }

</style>

