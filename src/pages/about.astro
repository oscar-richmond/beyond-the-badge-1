  /* ── Bio expandable content ────────────────── */
  button.about-bio__btn {
    background: none;
    cursor: pointer;
  }

  /* Grid-based height reveal: 0fr→1fr animates proportionally to
     actual content height — no max-height estimation needed */
  .about-bio__expand {
    display: grid;
    grid-template-rows: 0fr;
    /* Open speed (0.75s × 1.25): this transition fires when is-open is added */
    transition: grid-template-rows 0.94s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-bio__expand.is-open {
    grid-template-rows: 1fr;
    /* Close speed: this transition fires when is-open is removed */
    transition: grid-template-rows 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Required for the 0fr trick: clips overflow at zero height */
  .about-bio__expand-inner {
    overflow: hidden;
  }

  .about-bio__expand-para {
    padding-top: 28px;
  }

  .about-bio__expand-para:first-child {
