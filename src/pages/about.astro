---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import CTA from '../components/CTA.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About — Beyond the Badge"
  description="Learn about Beyond the Badge — the cultural brand partnership agency led by Laura Wood."
>
  <Header />
  <main class="about-page">

    <!-- 1. Hero -->
    <section class="about-hero">
      <h1 class="about-hero__text">
        We connect brands with the spaces where culture is created —
        <em>art</em>,
        <em>sport</em>, <em>entertainment</em> and <em>community</em>.
        Not to chase the moment, but to shape what comes next.
      </h1>
      <span class="about-hero__label">About Us</span>
    </section>

    <!-- 2. Image pair with caption -->
    <section class="about-images">
      <div class="about-images__cta-col">
        <a href="#contact" class="about-images__link">Get in touch →</a>
      </div>
      <div class="about-images__photos-col">
        <div class="about-images__item">
          <span class="about-images__num">(01)</span>
          <div class="about-images__photo" style={`background-image: url('${base}about-1.jpg')`}></div>
        </div>
        <div class="about-images__item">
          <span class="about-images__num">(02)</span>
          <div class="about-images__photo" style={`background-image: url('${base}hero-bg.jpg')`}></div>
        </div>
      </div>
    </section>

    <!-- 3. Statement + tagline -->
    <section class="about-statement">
      <div class="about-statement__watermark" aria-hidden="true">B</div>
      <div class="about-statement__inner">
        <p class="about-statement__text">
          We build emotional resonance, not just recognition. Through bold partnerships,
          authentic storytelling, cultural programming, and meaningful conversations with
          talent and communities, we help brands earn their place in culture — not by
          playing the corporate playbook, but by showing up with purpose, humility, and
          a point of view.
        </p>
        <p class="about-statement__tagline">
          <span class="about-tagline-plain">Less logo.</span>
          <span class="about-tagline-italic"> More legacy.</span>
        </p>
      </div>
    </section>

    <!-- 4. Four-image strip -->
    <section class="about-strip">
      <div class="about-strip__grid">
        <div class="about-strip__photo" style={`background-image: url('${base}about-1.jpg')`}></div>
        <div class="about-strip__photo" style={`background-image: url('${base}about-2.jpg')`}></div>
        <div class="about-strip__photo" style={`background-image: url('${base}hero-bg.jpg')`}></div>
        <div class="about-strip__photo" style={`background-image: url('${base}about-3.jpg')`}></div>
      </div>
    </section>

    <!-- 5. Founder bio -->
    <section class="about-bio">
      <div class="about-bio__inner">
        <div class="about-bio__content">
          <h2 class="about-bio__headline">
            After 25 years at the intersection of luxury, culture, and communication,
            <em>Laura Wood</em> knows that a brand is not a badge—it's a feeling.
            Following a decade as Global Director at JLR, where she led a team of 70<sup>+</sup>
            to redefine brand experience &amp; culture.
          </h2>
          <p class="about-bio__body">
            She specializes in moving brands past surface-level marketing and into meaningful
            cultural participation. From managing £80M+ global budgets to curating world-class
            collaborations, her work is defined by one goal: helping brands stop marketing and
            start mattering.
          </p>
          <a href="#contact" class="about-bio__btn">Read more +</a>
        </div>
        <span class="about-bio__label">The Founder</span>
      </div>
    </section>

  </main>

  <CTA />
  <ContactForm />
  <Footer />
</BaseLayout>

<!-- Global: active nav state -->
<style is:global>
  .header__nav-link--active {
    opacity: 1 !important;
    border-bottom: 1px solid currentColor;
  }
</style>

<style>
  /* ── Base ─────────────────────────────────────────── */
  .about-page {
    background: var(--color-cream);
  }

  /* ── 1. Hero ──────────────────────────────────────── */
  .about-hero {
    padding: 160px var(--section-padding-x) 96px;
    background: var(--color-cream);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 32px;
    border-bottom: 1px solid rgba(0, 79, 38, 0.12);
  }

  .about-hero__label {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    align-self: start;
    margin-top: 8px;
    white-space: nowrap;
  }

  .about-hero__text {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.35;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #1a3a2a;
    max-width: 900px;
    margin: 0;
  }

  .about-hero__text em {
    font-style: italic;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }

  /* ── 2. Image pair ────────────────────────────────── */
  .about-images {
    display: grid;
    grid-template-columns: 1fr 2fr;
    background: var(--color-cream);
    border-bottom: 1px solid rgba(0, 79, 38, 0.12);
    min-height: 600px;
  }

  .about-images__cta-col {
    display: flex;
    align-items: flex-end;
    padding: 60px var(--section-padding-x);
  }

  .about-images__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a3a2a;
    border: 1px solid rgba(26, 58, 42, 0.35);
    padding: 12px 20px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .about-images__link:hover {
    background: #1a3a2a;
    color: #fff;
    opacity: 1;
  }

  .about-images__photos-col {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 16px;
    padding: 60px 40px 60px 0;
  }

  .about-images__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-images__num {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: #004f26;
    text-transform: uppercase;
  }

  .about-images__photo {
    width: 100%;
    flex: 1;
    min-height: 440px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ── 3. Statement ─────────────────────────────────── */
  .about-statement {
    position: relative;
    padding: 120px var(--section-padding-x);
    background: var(--color-cream);
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 79, 38, 0.12);
  }

  .about-statement__watermark {
    position: absolute;
    right: -4%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 42vw;
    font-weight: 700;
    color: rgba(0, 79, 38, 0.05);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .about-statement__inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }

  .about-statement__text {
    font-family: var(--font-serif);
    font-size: clamp(18px, 1.8vw, 24px);
    line-height: 1.7;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #1a3a2a;
    margin: 0 0 64px;
  }

  .about-statement__tagline {
    margin: 0;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .about-tagline-plain {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 500;
    color: #1a3a2a;
  }

  .about-tagline-italic {
    font-family: 'Awesome Serif Italic VAR', var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: "wght" 500, "HGHT" 1000;
    color: #8CB7A0;
  }

  /* ── 4. Image strip ───────────────────────────────── */
  .about-strip {
    background: var(--color-cream);
  }

  .about-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .about-strip__photo {
    height: 420px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ── 5. Founder bio ───────────────────────────────── */
  .about-bio {
    padding: 120px var(--section-padding-x);
    background: var(--color-cream);
    border-top: 1px solid rgba(0, 79, 38, 0.12);
    border-bottom: 1px solid rgba(0, 79, 38, 0.12);
  }

  .about-bio__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 64px;
  }

  .about-bio__content {
    max-width: 700px;
  }

  .about-bio__headline {
    font-family: var(--font-serif);
    font-size: clamp(22px, 2.5vw, 36px);
    line-height: 1.45;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #1a3a2a;
    margin: 0 0 40px;
  }

  .about-bio__headline em {
    font-style: italic;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    color: inherit;
  }

  .about-bio__headline sup {
    font-size: 0.55em;
    vertical-align: super;
    line-height: 0;
  }

  .about-bio__body {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.75;
    font-weight: 400;
    color: #1a3a2a;
    opacity: 0.7;
    margin: 0 0 48px;
    max-width: 620px;
  }

  .about-bio__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: none;
    color: #1a3a2a;
    border: 1px solid rgba(26, 58, 42, 0.35);
    padding: 12px 24px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .about-bio__btn:hover {
    background: #1a3a2a;
    color: #ffffff;
    opacity: 1;
  }

  .about-bio__label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #004f26;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    margin-top: 8px;
    white-space: nowrap;
  }

  /* ── Responsive: Tablet 768px ─────────────────────── */
  @media (max-width: 900px) {
    .about-images {
      grid-template-columns: 1fr;
    }

    .about-images__cta-col {
      padding: 40px var(--section-padding-x) 0;
      align-items: flex-start;
    }

    .about-images__photos-col {
      padding: 40px var(--section-padding-x);
      grid-template-columns: 1.4fr 1fr;
    }

    .about-images__photo {
      min-height: 320px;
    }

    .about-strip__photo {
      height: 260px;
    }
  }

  /* ── Responsive: Mobile 480px ─────────────────────── */
  @media (max-width: 480px) {
    .about-hero {
      padding-top: 110px;
      padding-bottom: 60px;
      grid-template-columns: 1fr;
    }

    .about-hero__label {
      grid-row: 2;
      grid-column: 1;
      margin-top: 16px;
    }

    .about-images__photos-col {
      grid-template-columns: 1fr;
    }

    .about-images__photo {
      min-height: 260px;
    }

    .about-statement {
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .about-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-strip__photo {
      height: 180px;
    }

    .about-bio {
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .about-bio__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-bio__label {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }

  /* ── Responsive: Tablet range 481-900px ───────────── */
  @media (min-width: 481px) and (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr auto;
    }

    .about-bio__inner {
      grid-template-columns: 1fr auto;
    }

    .about-bio__headline {
      font-size: clamp(20px, 3vw, 28px);
    }
  }

  /* ── Wide screen clamp ────────────────────────────── */
  @media (min-width: 1600px) {
    .about-hero,
    .about-images__cta-col,
    .about-statement,
    .about-bio {
      padding-left: calc((100vw - var(--content-max-width)) / 2 + 40px);
      padding-right: calc((100vw - var(--content-max-width)) / 2 + 40px);
    }

    .about-images__photos-col {
      padding-right: calc((100vw - var(--content-max-width)) / 2 + 40px);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.header__nav-link, .mobile-nav__link').forEach(link => {
    if (link.textContent?.trim() === 'About') {
      link.classList.add('header__nav-link--active');
    }
  });
</script>
