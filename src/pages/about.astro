---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import CTA from '../components/CTA.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About — Beyond the Badge"
  description="Learn about Beyond the Badge — the cultural brand partnership agency led by Laura Wood."
>
  <Header />
  <main class="about-page">

    <!-- 1. Hero -->
    <section class="about-hero">
      <h1 class="about-hero__text" data-reveal-delay="-0.4">
        We connect brands with the spaces where culture is created —
        <em data-keyword="art">art</em>,
        <em data-keyword="sport">sport</em>, <em data-keyword="film">film</em>, <em data-keyword="entertainment">entertainment</em>, <em data-keyword="adventure">adventure</em> and <em data-keyword="community">community</em>.
        Not to chase the moment, but to shape what comes next.
      </h1>
      <span class="about-hero__label">About Us</span>
    </section>

    <!-- 2. Image pair with caption -->
    <section class="about-images">
      <div class="about-images__cta-col">
        <a href="#contact" class="about-images__link"><span>Get in touch →</span></a>
      </div>
      <div class="about-images__photos-col" data-reveal-group>
        <div class="about-images__item reveal--scale" data-reveal-immediate>
          <span class="about-images__num">
            <span class="about-images__num-inner is-visible" data-state="default">(01)</span>
            <span class="about-images__num-inner" data-state="art">(03)</span>
            <span class="about-images__num-inner" data-state="sport">(05)</span>
            <span class="about-images__num-inner" data-state="film">(07)</span>
            <span class="about-images__num-inner" data-state="entertainment">(09)</span>
            <span class="about-images__num-inner" data-state="adventure">(11)</span>
            <span class="about-images__num-inner" data-state="community">(13)</span>
          </span>
          <div class="about-images__photo" id="about-photo-1">
            <div class="about-images__layer is-active" data-state="default"      style={`background-image: url('${base}about-page-1.jpg')`}></div>
            <div class="about-images__layer" data-state="art"           style={`background-image: url('${base}about-art-1.jpg')`}></div>
            <div class="about-images__layer" data-state="sport"         style={`background-image: url('${base}about-sport-1.jpg')`}></div>
            <div class="about-images__layer" data-state="film"          style={`background-image: url('${base}about-film-1.jpg')`}></div>
            <div class="about-images__layer" data-state="entertainment" style={`background-image: url('${base}about-entertainment-1.jpg')`}></div>
            <div class="about-images__layer" data-state="adventure"     style={`background-image: url('${base}about-adventure-2.jpg')`}></div>
            <div class="about-images__layer" data-state="community"     style={`background-image: url('${base}about-community-1.jpg')`}></div>
          </div>
        </div>
        <div class="about-images__item reveal--scale" data-reveal-immediate>
          <span class="about-images__num">
            <span class="about-images__num-inner is-visible" data-state="default">(02)</span>
            <span class="about-images__num-inner" data-state="art">(04)</span>
            <span class="about-images__num-inner" data-state="sport">(06)</span>
            <span class="about-images__num-inner" data-state="film">(08)</span>
            <span class="about-images__num-inner" data-state="entertainment">(10)</span>
            <span class="about-images__num-inner" data-state="adventure">(12)</span>
            <span class="about-images__num-inner" data-state="community">(14)</span>
          </span>
          <div class="about-images__photo" id="about-photo-2">
            <div class="about-images__layer is-active" data-state="default"      style={`background-image: url('${base}about-page-right-default.jpg')`}></div>
            <div class="about-images__layer" data-state="art"           style={`background-image: url('${base}about-art-2.jpg')`}></div>
            <div class="about-images__layer" data-state="sport"         style={`background-image: url('${base}about-sport-2.jpg')`}></div>
            <div class="about-images__layer" data-state="film"          style={`background-image: url('${base}about-film-2.jpg')`}></div>
            <div class="about-images__layer" data-state="entertainment" style={`background-image: url('${base}about-adventure-1.jpg')`}></div>
            <div class="about-images__layer" data-state="adventure"     style={`background-image: url('${base}about-entertainment-2.jpg')`}></div>
            <div class="about-images__layer" data-state="community"     style={`background-image: url('${base}about-community-2.jpg')`}></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Statement + tagline -->
    <section class="about-statement">
      <img class="about-statement__watermark" src={`${base}logo-monogram.png`} alt="" aria-hidden="true" />
      <div class="about-statement__inner">
        <p class="about-statement__text" data-reveal-delay="0.3">
          We build emotional resonance, not just recognition. Through bold partnerships,
          authentic storytelling, cultural programming, and meaningful conversations with
          talent and communities, we help brands earn their place in culture — not by
          playing the corporate playbook, but by showing up with purpose, humility, and
          a point of view.
        </p>
        <div class="about-statement__tagline">
          <span class="about-tagline-plain">Less logo.</span>
          <span class="about-tagline-rotating-wrapper" aria-live="polite">
            <span class="about-rotating-phrase">More legacy.</span>
            <span class="about-rotating-phrase">More Partnerships.</span>
            <span class="about-rotating-phrase">More Sponsorship.</span>
          </span>
        </div>
      </div>
    </section>

    <!-- 4. Four-image strip -->
    <section class="about-image-grid" data-reveal-group>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}about-grid-1.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}about-grid-2.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item reveal--scale">
        <img src={`${base}hero-bg.jpg`} alt="" loading="lazy" />
      </div>
      <div class="about-image-grid__item about-image-grid__item--labeled reveal--scale">
        <span class="about-image-grid__index">(01)</span>
        <img src={`${base}about-grid-4.jpg`} alt="" loading="lazy" />
      </div>
    </section>

    <!-- 5. Founder bio -->
    <section class="about-bio" id="founder">
      <div class="about-bio__inner">
        <div class="about-bio__content">
          <h2 class="about-bio__headline">
            After 25 years at the intersection of luxury, culture, and communication,
            <em>Laura Wood</em> knows that a brand is not a <span style="white-space:nowrap">badge—it's</span> a feeling.
            Following a decade as Global Director at JLR, where she led a team of <span style="white-space:nowrap">70<sup>+</sup></span>
            to redefine brand experience &amp; culture.
          </h2>
          <p class="about-bio__body">
            She specializes in moving brands past surface-level marketing and into meaningful
            cultural participation. From managing £80M+ global budgets to curating world-class
            collaborations, her work is defined by one goal: helping brands stop marketing and
            start mattering.
          </p>

          <div class="about-bio__expand" id="bio-expand" aria-hidden="true">
            <div class="about-bio__expand-inner">
              <div class="about-bio__expand-para">
                <div class="bio-inner">Having spent over two decades building world-class teams and narratives for some of the most recognisable names in the world, Laura now helps brands navigate the complexities of cultural affinity and strategic growth.</div>
              </div>
              <div class="about-bio__expand-para">
                <div class="bio-inner">As Director of Brand Partnerships, Experience &amp; Collections at JLR (Jaguar Land Rover), she led a team of incredible professionals to redefine the cultural strategy for the "House of Brands," curating high-profile collaborations and reimagining global brand experiences for Range Rover, Defender, Discovery &amp; Jaguar. Her corporate tenure was preceded by a successful entrepreneurial career as a Partner at The Brooklyn Brothers and Co-Founder of Golden Goose PR, where she launched over 30 businesses.</div>
              </div>
              <div class="about-bio__expand-para">
                <div class="bio-inner">Outside of Beyond The Badge, Laura extends her expertise into the humanitarian sector, where she serves as an External Committee Member for the British Red Cross Donations Acceptance Committee. In this role, she leverages her strategic judgment and experience in risk and governance to help the organization navigate complex ethical decisions regarding donations.</div>
              </div>
              <div class="about-bio__expand-para">
                <div class="bio-inner">An award-winning strategist with a Cannes Lions Gold and PR Week Global Awards to her name, Laura's leadership is defined by the principles of empowerment and growth. Through Beyond The Badge, she brings her "big brand" expertise and entrepreneurial agility to help clients build meaningful connections that go far deeper than a logo.</div>
              </div>
            </div>
          </div>

          <button type="button" id="bio-read-more-btn" class="about-bio__btn">
            <span id="bio-btn-text">Read more +</span>
          </button>
          <img
            class="about-bio__portrait"
            src={`${base}laura-portrait.png`}
            alt="Laura Wood"
            aria-hidden="true"
          />
        </div>
        <span class="about-bio__label">The Founder</span>
      </div>
    </section>

  </main>

  <ContactForm />
  <Footer cream />
</BaseLayout>

<!-- Global: active nav state + about-page header overrides -->
<style is:global>
  .header__nav-link--active {
    opacity: 1 !important;
    border-bottom: 1px solid currentColor;
  }

  /* ── About page: force logo + nav links to #052715 ── */
  /* Covers both at-top (transparent) and scrolled states */
  .page-about .header__logo-img,
  .page-about .header:not(.at-top) .header__logo-img {
    /* CSS filter approximating #052715 (very dark forest green) from a black source image */
    filter: brightness(0) saturate(100%) invert(10%) sepia(60%) saturate(1200%) hue-rotate(118deg) brightness(0.75) !important;
  }

  .page-about .header__nav-link,
  .page-about .header.at-top .header__nav-link {
    color: #052715 !important;
  }

  .page-about .header__menu-line,
  .page-about .header.at-top .header__menu-line {
    background-color: #052715 !important;
  }
</style>

<style>
  /* ── Base ─────────────────────────────────────────── */
  .about-page {
    background: var(--color-cream);
  }

  /* ── 1. Hero ──────────────────────────────────────── */
  .about-hero {
    padding: 160px var(--section-padding-x) 96px;
    background: var(--color-cream);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 32px;
  }

  .about-hero__label {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #052715;
    align-self: start;
    margin-top: 8px;
    white-space: nowrap;
  }

  .about-hero__text {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw + 8px, 36px);
    line-height: clamp(28px, 3.2vw + 12px, 48px);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #052715;
    max-width: 952px;
    margin: 0;
  }

  .about-hero__text em {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "wght" 500, "hght" 1000;
    text-decoration: underline dotted;
    text-underline-offset: 5px;
    text-decoration-thickness: 6%;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .about-hero__text em:hover {
    color: #8CB7A0;
    text-decoration-color: #8CB7A0;
    cursor: default;
  }

  /* ── 2. Image pair ────────────────────────────────── */
  .about-images {
    display: grid;
    grid-template-columns: 1fr 2fr;
    background: var(--color-cream);
    min-height: 600px;
  }

  .about-images__cta-col {
    display: flex;
    align-items: flex-end;
    padding: 60px var(--section-padding-x);
    padding-bottom: 68px;
  }

  .about-images__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #052715;
    border: 1px solid #052715;
    padding: 12px 20px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.4s ease,
      letter-spacing 0.4s ease;
  }

  .about-images__link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .about-images__link span {
    position: relative;
    z-index: 2;
  }

  .about-images__link:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .about-images__link:hover {
    color: #f5f0e8;
    transform: translateX(3px);
    letter-spacing: 0.11em;
    border-color: #052715;
    opacity: 1; /* cancel global a:hover { opacity: 0.8 } */
  }

  .about-images__photos-col {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 16px;
    padding: 60px var(--section-padding-x) 60px 0;  /* was hardcoded 40px — now tracks the global padding token */
  }

  .about-images__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-images__num {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #004f26;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
    overflow: hidden;
    height: 1.25em;
    vertical-align: bottom;
  }

  .about-images__num-inner {
    position: absolute;
    top: 0;
    left: 0;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(110%);
    transition:
      opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .about-images__num-inner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* exiting state — slides up */
  .about-images__num-inner.is-exiting {
    opacity: 0;
    transform: translateY(-110%);
    transition:
      opacity 0.4s cubic-bezier(0.55, 0, 1, 0.45),
      transform 0.4s cubic-bezier(0.55, 0, 1, 0.45);
  }

  .about-images__photo {
    position: relative;
    width: 100%;
    height: 440px;
    overflow: hidden;
  }

  /* Layered image system for keyword hover */
  .about-images__layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
  }

  .about-images__layer.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── 3. Statement ─────────────────────────────────── */
  .about-statement {
    position: relative;
    padding: var(--section-padding-y) var(--section-padding-x);
    background: var(--color-cream);
  }

  .about-statement__watermark {
    position: absolute;
    right: var(--section-padding-x);
    top: 16px;
    width: 1135px;
    height: auto;
    opacity: 0.04;
    filter: invert(1) sepia(1) saturate(2) hue-rotate(90deg) brightness(0.2);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .about-statement__inner {
    position: relative;
    z-index: 1;
    max-width: 952px;
  }

  .about-statement__text {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 18px;
    line-height: 32px;
    font-weight: 400;
    letter-spacing: 0;
    color: #052715;
    margin: 0 0 var(--section-padding-y);
    max-width: 952px;
  }

  .about-statement__tagline {
    margin: 0;
    font-size: 36px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 0;
  }

  .about-tagline-plain {
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 500;
    color: #052715;
  }

  /* Rotating wrapper — inline-block with generous height so the phrase
   * bounding box (incl. deep italic descenders) fits entirely within the
   * wrapper's stacking context on older WebKit builds. */
  .about-tagline-rotating-wrapper {
    position: relative;
    display: inline-block;
    height: 1.5em;
    min-width: 1px;
    overflow: visible;
    vertical-align: baseline;
    top: 14px;
  }

  .about-rotating-phrase {
    position: absolute;
    left: 7px;
    top: calc(50% - 2px);
    transform: translateY(calc(-50% + 10px)); /* initial: slides in from below */
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: "wght" 500, "hght" 1000;
    line-height: 1.5;   /* wider box so descenders (g,y,p) don't clip */
    color: #8CB7A0;
    white-space: nowrap;
    opacity: 0;
  }

  /* ── 4. Image strip ───────────────────────────────── */
  /* ── 4. Image grid ────────────────────────────────── */
  .about-image-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr 1fr;
    gap: 16px;
    padding: 64px var(--section-padding-x);
    /* No background — cream comes from .about-page so watermark shows through */
    /* No position:relative — (01) label is relative to its own item */
  }

  .about-image-grid__item {
    height: 440px;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .about-image-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Last item: label floats 16px above, left-aligned to the image */
  .about-image-grid__item--labeled {
    position: relative;
    overflow: visible; /* allow label to show above the image */
  }

  .about-image-grid__item--labeled img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-image-grid__index {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 0;
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #004f26;
  }

  /* ── 5. Founder bio ───────────────────────────────── */
  .about-bio {
    padding: 120px var(--section-padding-x);
    background: var(--color-cream);
    overflow: hidden;  /* contain the absolutely-positioned portrait so it never
                         widens the document past the viewport — which would cause
                         position:fixed elements (nav) to drift rightward */
  }

  .about-bio__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 64px;
  }

  .about-bio__content {
    max-width: 952px;
    position: relative;
  }

  .about-bio__portrait {
    position: absolute;
    left: calc(100% + 192px);
    top: 140px;
    width: 329px;
    height: auto;
    transform: rotate(5deg) translateY(20px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity, transform;
    z-index: 10;
  }

  .about-bio__portrait.is-visible {
    opacity: 1;
    transform: rotate(5deg) translateY(0) scale(1);
  }

  .about-bio__headline {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw + 8px, 36px);
    line-height: clamp(28px, 3.2vw + 12px, 48px);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #052715;
    margin: 0 0 32px;
    max-width: 952px;
    text-wrap: pretty;
    hyphens: none;
  }

  .about-bio__headline em {
    font-family: var(--font-script);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: "wght" 500, "hght" 0;
    text-decoration: underline dotted;
    text-underline-offset: 5px;
    text-decoration-thickness: 6%;
    color: #052715;
    text-decoration-color: #052715;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
    /* Spacing survives the line-reveal DOM rewrite; &nbsp; entities do not */
    padding-right: 0.21em;
  }

  .about-bio__headline em:hover {
    color: #8CB7A0;
    text-decoration-color: #8CB7A0;
    cursor: default;
  }

  .about-bio__headline sup {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 0.55em;
    font-weight: 600;
    vertical-align: super;
    line-height: 0;
  }

  .about-bio__body {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 18px;
    line-height: 32px;
    font-weight: 400;
    letter-spacing: 0;
    color: #052715;
    margin: 0;
    max-width: 952px;
  }

  .about-bio__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #052715;
    border: 1px solid #052715;
    padding: 12px 24px;
    margin-top: 48px;
    margin-bottom: var(--section-padding-y);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.4s ease,
      letter-spacing 0.4s ease;
  }

  .about-bio__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #052715;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 1;
  }

  .about-bio__btn span {
    position: relative;
    z-index: 2;
  }

  .about-bio__btn:hover::before {
    clip-path: inset(0 0% 0 0);
  }

  .about-bio__btn:hover {
    color: #f5f0e8;
    transform: translateX(3px);
    border-color: #052715;
